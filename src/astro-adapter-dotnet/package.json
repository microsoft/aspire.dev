{
  "name": "astro-adapter-dotnet",
  "version": "0.1.0",
  "description": "Astro adapter for ASP.NET Core hybrid rendering",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./server.js": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp src/server.ts dist/server.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "withastro",
    "astro-adapter",
    "dotnet",
    "aspnetcore"
  ],
  "peerDependencies": {
    "astro": "^5.0.0 || ^6.0.0-alpha.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "astro": "^5.17.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}

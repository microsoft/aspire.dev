 import { fileURLToPath, pathToFileURL } from "node:url";
 import colors from "piccolore";
 import * as vite from "vite";
+
+// Retries `fs.promises.rename` on Windows when a freshly-written file is still
+// being held by another handle (typically a virus scanner or the file-system
+// indexer). Without retries, the very next `astro build` after a fresh write
+// can fail with EBUSY/EPERM during the asset-move phase of the build, which
+// makes back-to-back rebuilds on Windows unreliable. The retry is a no-op on
+// platforms that don't surface these errors.
+async function renameWithRetry(from, to) {
+  const transient = new Set(["EBUSY", "EPERM", "ENOTEMPTY"]);
+  const maxAttempts = 8;
+  let delay = 25;
+  for (let attempt = 1; attempt <= maxAttempts; attempt++) {
+    try {
+      return await fs.promises.rename(from, to);
+    } catch (err) {
+      if (attempt === maxAttempts || !transient.has(err && err.code)) throw err;
+      await new Promise((r) => setTimeout(r, delay));
+      delay = Math.min(delay * 2, 500);
+    }
+  }
+}
 import { LINKS_PLACEHOLDER } from "../../content/consts.js";
 import { contentAssetsBuildPostHook } from "../../content/vite-plugin-content-assets.js";
 import { createBuildInternals } from "../../core/build/internal.js";

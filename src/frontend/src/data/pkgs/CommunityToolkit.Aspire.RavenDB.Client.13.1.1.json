                        "kind": "cref",
                        "value": "T:Raven.Client.Documents.Session.IAsyncDocumentSession"
                      },
                      {
                        "kind": "text",
                        "text": " are registered per request to ensure short-lived session instances for each use."
                      }
                    ]
                  }
                ]
              }
            ],

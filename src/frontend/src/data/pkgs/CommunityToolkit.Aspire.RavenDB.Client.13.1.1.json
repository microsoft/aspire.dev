                "kind": "text",
                "text": " instances for connecting to an existing or new RavenDB database with RavenDB.Client, identified by a unique service key. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": "Notes: "
              },
              {
                "kind": "list",
                "style": "bullet",
                "items": [
                  {
                    "description": [
                      {

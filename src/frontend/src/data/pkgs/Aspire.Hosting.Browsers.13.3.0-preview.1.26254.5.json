        {
          "name": "WithBrowserLogs",
          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<T> BrowserLogsBuilderExtensions.WithBrowserLogs<T>(this IResourceBuilder<T> builder, string? browser = null, string? profile = null, BrowserUserDataMode? userDataMode = null)",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<T>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",
              "type": "Aspire.Hosting.ApplicationModel.IResourceBuilder<T>",
              "modifier": "this"
            },
            {
              "name": "browser",
              "type": "string?",
              "isNullable": true,
              "isOptional": true
            },
            {
              "name": "profile",
              "type": "string?",
              "isNullable": true,
              "isOptional": true
            },
            {
              "name": "userDataMode",
              "type": "Aspire.Hosting.BrowserUserDataMode?",
              "isNullable": true,
              "isOptional": true
            }
          ],
          "genericParameters": [
            {
              "name": "T",
              "constraints": [
                "Aspire.Hosting.ApplicationModel.IResourceWithEndpoints"
              ]
            }
          ],
          "attributes": [
            {
              "name": "System.Diagnostics.CodeAnalysis.ExperimentalAttribute",
              "constructorArguments": [
                "ASPIREBROWSERLOGS001"
              ],
              "arguments": {
                "UrlFormat": "https://aka.ms/aspire/diagnostics/{0}"
              }
            },
            {
              "name": "Aspire.Hosting.AspireExportAttribute"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a child resource that can open the application's primary browser endpoint in a tracked browser session, surface browser diagnostics, and capture screenshots. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " This method adds a child browser logs resource beneath the parent resource represented by "
                  },
                  {
                    "kind": "paramref",
                    "value": "builder"
                  },
                  {
                    "kind": "text",
                    "text": ". The child resource exposes a dashboard command that launches a Chromium-based browser in a tracked mode, attaches to the browser's debugging protocol, forwards browser console, error, exception, and network output to the child resource's console log stream, and can capture screenshots as command artifacts. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " The tracked browser session uses the "
                  },
                  {
                    "kind": "href",
                    "text": "Chrome DevTools\n             Protocol (CDP)",
                    "value": "https://chromedevtools.github.io/devtools-protocol/"
                  },
                  {
                    "kind": "text",
                    "text": " to subscribe to browser runtime, log, page, and network events. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " The parent resource must expose at least one HTTP or HTTPS endpoint. HTTPS endpoints are preferred over HTTP endpoints when selecting the browser target URL. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " Browser, profile, and user data mode settings can also be supplied from configuration using "
                  },
                  {
                    "kind": "code",
                    "text": "Aspire:Hosting:BrowserLogs:Browser"
                  },
                  {
                    "kind": "text",
                    "text": ", "
                  },
                  {
                    "kind": "code",
                    "text": "Aspire:Hosting:BrowserLogs:Profile"
                  },
                  {
                    "kind": "text",
                    "text": ", and "
                  },
                  {
                    "kind": "code",
                    "text": "Aspire:Hosting:BrowserLogs:UserDataMode"
                  },
                  {
                    "kind": "text",
                    "text": ", or scoped to a specific resource with "
                  },
                  {
                    "kind": "code",
                    "text": "Aspire:Hosting:BrowserLogs:{ResourceName}:Browser"
                  },
                  {
                    "kind": "text",
                    "text": ", "
                  },
                  {
                    "kind": "code",
                    "text": "Aspire:Hosting:BrowserLogs:{ResourceName}:Profile"
                  },
                  {
                    "kind": "text",
                    "text": ", and "
                  },
                  {
                    "kind": "code",
                    "text": "Aspire:Hosting:BrowserLogs:{ResourceName}:UserDataMode"
                  },
                  {
                    "kind": "text",
                    "text": ". Explicit method arguments override configuration. "
                  }
                ]
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the original "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " for further chaining."
              }
            ],
            "parameters": {
              "browser": [
                {
                  "kind": "text",
                  "text": " The browser to launch. When not specified, the tracked browser uses the configured value from "
                },
                {
                  "kind": "code",
                  "text": "Aspire:Hosting:BrowserLogs"
                },
                {
                  "kind": "text",
                  "text": " and otherwise prefers an installed "
                },
                {
                  "kind": "code",
                  "text": "\"msedge\""
                },
                {
                  "kind": "text",
                  "text": " browser in shared user data mode, an installed "
                },
                {
                  "kind": "code",
                  "text": "\"chrome\""
                },
                {
                  "kind": "text",
                  "text": " browser in isolated user data mode, and finally falls back to "
                },
                {
                  "kind": "code",
                  "text": "\"chrome\""
                },
                {
                  "kind": "text",
                  "text": ". Supported values include logical browser names such as "
                },
                {
                  "kind": "code",
                  "text": "\"msedge\""
                },
                {
                  "kind": "text",
                  "text": " and "
                },
                {
                  "kind": "code",
                  "text": "\"chrome\""
                },
                {
                  "kind": "text",
                  "text": ", or an explicit browser executable path. "
                }
              ],
              "builder": [
                {
                  "kind": "text",
                  "text": "The resource builder."
                }
              ],
              "profile": [
                {
                  "kind": "text",
                  "text": " Optional Chromium profile name or directory name to use. Only valid when the effective user data mode is "
                },
                {
                  "kind": "cref",
                  "value": "F:Aspire.Hosting.BrowserUserDataMode.Shared"
                },
                {
                  "kind": "text",
                  "text": ". When not specified, the tracked browser uses the configured value from "
                },
                {
                  "kind": "code",
                  "text": "Aspire:Hosting:BrowserLogs"
                },
                {
                  "kind": "text",
                  "text": " if present. "
                }
              ],
              "userDataMode": [
                {
                  "kind": "text",
                  "text": " Optional "
                },
                {
                  "kind": "cref",
                  "value": "T:Aspire.Hosting.BrowserUserDataMode"
                },
                {
                  "kind": "text",
                  "text": " that selects whether the tracked browser launches against a persistent Aspire-managed user data directory shared across all AppHosts on the machine ("
                },
                {
                  "kind": "cref",
                  "value": "F:Aspire.Hosting.BrowserUserDataMode.Shared"
                },
                {
                  "kind": "text",
                  "text": ", the default) or a per-AppHost persistent user data directory ("
                },
                {
                  "kind": "cref",
                  "value": "F:Aspire.Hosting.BrowserUserDataMode.Isolated"
                },
                {
                  "kind": "text",
                  "text": "). Both modes use Aspire-managed paths under "
                },
                {
                  "kind": "code",
                  "text": "%LocalAppData%\\Aspire\\BrowserData"
                },
                {
                  "kind": "text",
                  "text": " on Windows (or platform equivalents); the user's normal browser profile is never used. When not specified, the tracked browser uses the configured value from "
                },
                {
                  "kind": "code",
                  "text": "Aspire:Hosting:BrowserLogs"
                },
                {
                  "kind": "text",
                  "text": " and otherwise defaults to "
                },
                {
                  "kind": "cref",
                  "value": "F:Aspire.Hosting.BrowserUserDataMode.Shared"
                },
                {
                  "kind": "text",
                  "text": ". "
                }
              ]
            },
            "typeParameters": {
              "T": [
                {
                  "kind": "text",
                  "text": "The type of resource being configured."
                }
              ]
            },
            "examples": [
              {
                "code": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             builder.AddProject<Projects.WebFrontend>(\"web\")\n                 .WithExternalHttpEndpoints()\n                 .WithBrowserLogs();\n             ",
                "language": "csharp",
                "description": [
                  {
                    "kind": "text",
                    "text": "Add tracked browser logs for a web front end:"
                  }
                ]
              }
            ]
          },
          "sourceFile": "src/Aspire.Hosting.Browsers/BrowserLogsBuilderExtensions.cs",
          "sourceLines": "122-283"
        }

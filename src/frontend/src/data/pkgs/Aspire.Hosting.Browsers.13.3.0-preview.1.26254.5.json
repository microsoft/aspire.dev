    {
      "name": "BrowserUserDataMode",
      "fullName": "Aspire.Hosting.BrowserUserDataMode",
      "namespace": "Aspire.Hosting",
      "kind": "enum",
      "accessibility": "public",
      "docs": {
        "summary": [
          {
            "kind": "text",
            "text": " Selects the Chromium user data directory used by tracked browser sessions. "
          }
        ]
      },
      "enumMembers": [
        {
          "name": "Shared",
          "value": 0,
          "description": "Use a persistent Aspire-managed user data directory shared across all AppHosts on the machine. State such as cookies, sign-ins, and extensions persist across runs and are visible to every AppHost using the same browser."
        },
        {
          "name": "Isolated",
          "value": 1,
          "description": "Use a persistent Aspire-managed user data directory scoped to the current AppHost project. Each AppHost gets its own state that persists across runs but is not shared with other AppHosts."
        }
      ],
      "attributes": [
        {
          "name": "System.Diagnostics.CodeAnalysis.ExperimentalAttribute",
          "constructorArguments": [
            "ASPIREBROWSERLOGS001"
          ],
          "arguments": {
            "UrlFormat": "https://aka.ms/aspire/diagnostics/{0}"
          }
        }
      ],
      "sourceFile": "src/Aspire.Hosting.Browsers/BrowserUserDataMode.cs",
      "sourceLines": "12-12",
      "members": []
    }
  ]

            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds an Azure AI Search service resource to the application model. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " By default references to the Azure AI Search service resource will be assigned the following roles: - "
              },
              {
                "kind": "cref",
                "value": "P:Azure.Provisioning.Search.SearchBuiltInRole.SearchIndexDataContributor"
              },
              {
                "kind": "text",
                "text": " - "
              },
              {
                "kind": "cref",
                "value": "P:Azure.Provisioning.Search.SearchBuiltInRole.SearchServiceContributor"
              },
              {
                "kind": "text",
                "text": " These can be replaced by calling "
              },
              {
                "kind": "cref",
                "value": "M:Aspire.Hosting.AzureSearchExtensions.WithRoleAssignments``1(Aspire.Hosting.ApplicationModel.IResourceBuilder{``0},Aspire.Hosting.ApplicationModel.IResourceBuilder{Aspire.Hosting.Azure.AzureSearchResource},Azure.Provisioning.Search.SearchBuiltInRole[])"
              },
              {
                "kind": "text",
                "text": ". "
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The builder for the distributed application."
                }
              ],
              "name": [
                {
                  "kind": "text",
                  "text": "The name of the Azure AI Search resource."
                }
              ]
            }
          },
          "sourceFile": "src/Aspire.Hosting.Azure.Search/AzureSearchExtensions.cs",
          "sourceLines": "36-45"
        },
        {
          "name": "WithRoleAssignments",
          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<T> AzureSearchExtensions.WithRoleAssignments<T>(this IResourceBuilder<T> builder, IResourceBuilder<AzureSearchResource> target, params SearchBuiltInRole[] roles)",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<T>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",
              "type": "Aspire.Hosting.ApplicationModel.IResourceBuilder<T>",
              "modifier": "this"
            },
            {
              "name": "target",
              "type": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.Azure.AzureSearchResource>"
            },
            {
              "name": "roles",
              "type": "Azure.Provisioning.Search.SearchBuiltInRole[]",
              "modifier": "params"
            }
          ],
          "genericParameters": [
            {
              "name": "T",
              "constraints": [
                "Aspire.Hosting.ApplicationModel.IResource"
              ]
            }
          ],
          "attributes": [
            {
              "name": "Aspire.Hosting.AspireExportIgnoreAttribute"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Assigns the specified roles to the given resource, granting it the necessary permissions on the target Azure AI Search service resource. This replaces the default role assignments for the resource. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Assigns the SearchIndexDataReader role to the 'Projects.Api' project. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var search = builder.AddAzureSearch(\"search\");\n             \n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithRoleAssignments(search, SearchBuiltInRole.SearchIndexDataReader)\n               .WithReference(search);\n             ",
                "language": "csharp"
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "The updated "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " with the applied role assignments."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The resource to which the specified roles will be assigned."
                }
              ],
              "roles": [
                {
                  "kind": "text",
                  "text": "The built-in AI Search roles to be assigned."
                }
              ],
              "target": [
                {
                  "kind": "text",
                  "text": "The target Azure AI Search service resource."
                }
              ]
            }
          },
          "sourceFile": "src/Aspire.Hosting.Azure.Search/AzureSearchExtensions.cs"
        }
      ]

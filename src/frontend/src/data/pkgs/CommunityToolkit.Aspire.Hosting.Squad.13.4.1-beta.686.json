          {
            "kind": "cref",
            "value": "T:Aspire.Hosting.ApplicationModel.IResourceWithConnectionString"
          },
          {
            "kind": "text",
            "text": " so that downstream services can reference the team with "
          },
          {
            "kind": "code",
            "text": ".WithReference(squad)"
          },
          {
            "kind": "text",
            "text": " and receive a custom "
          },
          {
            "kind": "code",
            "text": "squad://"
          },
          {
            "kind": "text",
            "text": " descriptor that encodes the resource name, team root, and agent roster. The resource is a logical Aspire resource; it does not start a listener by itself. "
          }
        ]
      },

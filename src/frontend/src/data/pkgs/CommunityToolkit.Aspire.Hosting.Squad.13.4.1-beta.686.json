        ]
      },
      "sourceFile": "src/CommunityToolkit.Aspire.Hosting.Squad/SquadBuilderExtensions.cs",
      "sourceLines": "16-16",
      "members": [
        {
          "name": "AddSquad",
          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<SquadResource> SquadBuilderExtensions.AddSquad(this IDistributedApplicationBuilder builder, string name, string? teamRoot = null)",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.SquadResource>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",
              "type": "Aspire.Hosting.IDistributedApplicationBuilder",
              "modifier": "this"
            },
            {
              "name": "name",
              "type": "string"
            },
            {
              "name": "teamRoot",
              "type": "string?",
              "isNullable": true,
              "isOptional": true
            }
          ],
          "attributes": [
            {
              "name": "Aspire.Hosting.AspireExportAttribute"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a Squad AI-agent team to the distributed application. The lifecycle hook discovers agents from "
              },
              {
                "kind": "code",
                "text": ".squad/team.md"
              },
              {
                "kind": "text",
                "text": " (or the default roster when the file does not exist), publishes "
              },
              {
                "kind": "code",
                "text": "Spawning"
              },
              {
                "kind": "text",
                "text": " to "
              },
              {
                "kind": "code",
                "text": "Active"
              },
              {
                "kind": "text",
                "text": " state transitions visible in the Aspire dashboard, and injects a custom "
              },
              {
                "kind": "code",
                "text": "squad://"
              },
              {
                "kind": "text",
                "text": " descriptor that downstream services can consume as metadata. The Squad resource is a logical dashboard/resource-graph entry; it does not start a server process by itself. "
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "An "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " for further configuration."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The "
                },
                {
                  "kind": "cref",
                  "value": "T:Aspire.Hosting.IDistributedApplicationBuilder"
                },
                {
                  "kind": "text",
                  "text": " to add the resource to."
                }
              ],
              "name": [
                {
                  "kind": "text",
                  "text": "The Aspire resource name."
                }
              ],
              "teamRoot": [
                {
                  "kind": "text",
                  "text": " Absolute path to the workspace root - the directory that contains the "
                },
                {
                  "kind": "code",
                  "text": ".squad/"
                },
                {
                  "kind": "text",
                  "text": " folder. Defaults to "
                },
                {
                  "kind": "cref",
                  "value": "M:System.IO.Directory.GetCurrentDirectory"
                },
                {
                  "kind": "text",
                  "text": " when not specified. "
                }
              ]
            },
            "examples": [
              {
                "code": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var squad = builder.AddSquad(\"research-squad\",\n                 teamRoot: @\"C:\\repos\\my-project\");\n            \n             builder.AddProject<Projects.IncidentWorkflow>(\"workflow\")\n                 .WithReference(squad);\n            \n             builder.Build().Run();\n             ",
                "language": "csharp"
              }
            ]
          },
          "sourceFile": "src/CommunityToolkit.Aspire.Hosting.Squad/SquadBuilderExtensions.cs",
          "sourceLines": "53-197"
        }
      ]

            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Assigns the AppConfigurationDataReader role to the 'Projects.Api' project. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var appStore = builder.AddAzureAppConfiguration(\"appStore\");\n             \n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithRoleAssignments(appStore, AppConfigurationBuiltInRole.AppConfigurationDataReader)\n               .WithReference(appStore);\n             ",

        {
          "name": "WithDataBindMount",
          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<MinioContainerResource> MinioBuilderExtensions.WithDataBindMount(this IResourceBuilder<MinioContainerResource> builder, string source)",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.MinioContainerResource>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",
              "type": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.MinioContainerResource>",
              "modifier": "this"
            },
            {
              "name": "source",
              "type": "string"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a bind mount for the data folder to a MinIO container resource. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Add an MinIO container to the application model and reference it in a .NET project. Additionally, in this example a bind mount is added to the container to allow data to be persisted across container restarts. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var minio = builder.AddMinio(\"minio\")\n             .WithDataBindMount(\"./data/minio/data\");\n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithReference(minio);\n              \n             builder.Build().Run(); \n             ",
                "language": "csharp"
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "The "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The resource builder."
                }
              ],
              "source": [
                {
                  "kind": "text",
                  "text": "The source directory on the host to mount into the container."
                }
              ]
            }
          },
          "sourceFile": "src/CommunityToolkit.Aspire.Hosting.Minio/MinioBuilderExtensions.cs",
          "sourceLines": "169-172"
        },

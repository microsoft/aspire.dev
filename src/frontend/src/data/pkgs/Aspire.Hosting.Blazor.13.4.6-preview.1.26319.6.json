      "members": [
        {
          "name": "ProxyBlazorService",
          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<ProjectResource> BlazorHostedExtensions.ProxyBlazorService(this IResourceBuilder<ProjectResource> host, IResourceBuilder<IResourceWithServiceDiscovery> service, string apiPrefix = \"_api\")",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.ProjectResource>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "host",
              "type": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.ProjectResource>",
              "modifier": "this"
            },
            {
              "name": "service",
              "type": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.IResourceWithServiceDiscovery>"
            },
            {
              "name": "apiPrefix",
              "type": "string",
              "isOptional": true,
              "defaultValue": "_api"
            }
          ],
          "attributes": [
            {
              "name": "Aspire.Hosting.AspireExportIgnoreAttribute",
              "arguments": {
                "Reason": "Blazor hosted APIs are not yet stable for ATS export."
              }
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Configures the host to proxy requests from the WebAssembly client to the specified service. The WASM client can reach this service via "
              },
              {
                "kind": "code",
                "text": "/{apiPrefix}/{serviceName}/{path}"
              },
              {
                "kind": "text",
                "text": ". YARP routes and clusters are emitted as environment variables. A "
              },
              {
                "kind": "code",
                "text": "/_blazor/_configuration"
              },
              {
                "kind": "text",
                "text": " response is built so the WASM client gets the proxy URL. This is an explicit opt-in — "
              },
              {
                "kind": "code",
                "text": "WithReference"
              },
              {
                "kind": "text",
                "text": " makes the service available to the server, while "
              },
              {
                "kind": "code",
                "text": "ProxyBlazorService"
              },
              {
                "kind": "text",
                "text": " additionally makes it available to the WASM client. "
              }
            ],
            "parameters": {
              "apiPrefix": [
                {
                  "kind": "text",
                  "text": "The URL path prefix for API proxy routes. Defaults to "
                },
                {
                  "kind": "code",
                  "text": "\"_api\""
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "host": [
                {
                  "kind": "text",
                  "text": "The host resource builder."
                }
              ],
              "service": [
                {
                  "kind": "text",
                  "text": "The service to proxy."
                }
              ]
            }
          },
          "sourceFile": "src/Aspire.Hosting.Blazor/BlazorHostedExtensions.cs",
          "sourceLines": "34-46"
        },
        {
          "name": "ProxyBlazorTelemetry",
          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<ProjectResource> BlazorHostedExtensions.ProxyBlazorTelemetry(this IResourceBuilder<ProjectResource> host, string otlpPrefix = \"_otlp\")",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.ProjectResource>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "host",
              "type": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.ProjectResource>",
              "modifier": "this"
            },
            {
              "name": "otlpPrefix",
              "type": "string",
              "isOptional": true,
              "defaultValue": "_otlp"
            }
          ],
          "attributes": [
            {
              "name": "Aspire.Hosting.AspireExportIgnoreAttribute",
              "arguments": {
                "Reason": "Blazor hosted APIs are not yet stable for ATS export."
              }
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Configures the host to proxy OpenTelemetry data from the WebAssembly client to the Aspire dashboard. The WASM client sends OTLP data to "
              },
              {
                "kind": "code",
                "text": "/{otlpPrefix}/{path}"
              },
              {
                "kind": "text",
                "text": " which gets forwarded to the dashboard. Also sets the "
              },
              {
                "kind": "code",
                "text": "OTEL_SERVICE_NAME"
              },
              {
                "kind": "text",
                "text": " in the client configuration so telemetry from the WASM client appears with the correct service name in the dashboard. "
              }
            ],
            "parameters": {
              "host": [
                {
                  "kind": "text",
                  "text": "The host resource builder."
                }
              ],
              "otlpPrefix": [
                {
                  "kind": "text",
                  "text": "The URL path prefix for OTLP proxy routes. Defaults to "
                },
                {
                  "kind": "code",
                  "text": "\"_otlp\""
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ]
            }
          },
          "sourceFile": "src/Aspire.Hosting.Blazor/BlazorHostedExtensions.cs",
          "sourceLines": "62-68"
        }
      ]

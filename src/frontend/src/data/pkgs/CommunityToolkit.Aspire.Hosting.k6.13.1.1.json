          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Runs a k6 JS script when starting the Grafana k6 container resource. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Add a Grafana k6 container to the application model and reference it in a .NET project. Additionally, in this example a script runs when the container starts. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var api = builder.AddProject<Projects.Api>(\"api\");\n             var k6 = builder.AddK6(\"k6\")\n                 .WithBindMount(\"scripts\", \"/scripts\", true)\n                 .WithScript(\"/scripts/main.js\")\n                 .WithReference(api)\n                 .WaitFor(api);\n              \n             builder.Build().Run(); \n             ",
                "language": "csharp"
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "The "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],

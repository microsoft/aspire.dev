          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Configures an Azure SQL Database (server) resource to run locally in a container. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " The following example creates an Azure SQL Database (server) resource that runs locally in a SQL Server container and referencing that resource in a .NET project. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var data = builder.AddAzureSqlServer(\"data\")\n                 .RunAsContainer();\n            \n             builder.AddProject<Projects.ProductService>()\n                 .WithReference(data);\n            \n             builder.Build().Run();\n             ",
                "language": "csharp"
              }

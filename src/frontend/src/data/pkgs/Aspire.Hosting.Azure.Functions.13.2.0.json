          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",
              "type": "Aspire.Hosting.IDistributedApplicationBuilder",
              "modifier": "this"
            },
            {
              "name": "name",
              "type": "string"
            }
          ],
          "genericParameters": [
            {
              "name": "TProject",
              "constraints": [
                "new()",
                "Aspire.Hosting.IProjectMetadata"
              ]
            }
          ],
          "attributes": [
            {
              "name": "Aspire.Hosting.AspireExportIgnoreAttribute"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds an Azure Functions project to the distributed application. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " This overload is not available in polyglot app hosts. Use "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.AzureFunctionsProjectResourceExtensions.AddAzureFunctionsProject(Aspire.Hosting.IDistributedApplicationBuilder,System.String,System.String)"
                  },
                  {
                    "kind": "text",
                    "text": " with a project path instead. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " When Functions projects are deployed to Azure Container Apps, they are provisioned with the container app "
                  },
                  {
                    "kind": "code",
                    "text": "kind"
                  },
                  {
                    "kind": "text",
                    "text": " property set to "
                  },
                  {
                    "kind": "code",
                    "text": "functionapp"
                  },
                  {
                    "kind": "text",
                    "text": ". This enables KEDA auto-scaler rules to be automatically configured based on the Azure Functions triggers defined in the project. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " By default, an implicit Azure Storage account is provisioned to be used as host storage for the Functions runtime. This storage account is required by the Azure Functions runtime for operations such as managing triggers, logging function executions, and coordinating instances. The implicit storage account is assigned the following roles: "
                  },
                  {
                    "kind": "list",
                    "style": "bullet",
                    "items": [
                      {
                        "description": [
                          {
                            "kind": "cref",
                            "value": "P:Azure.Provisioning.Storage.StorageBuiltInRole.StorageBlobDataContributor"
                          }
                        ]
                      },
                      {
                        "description": [
                          {
                            "kind": "cref",
                            "value": "P:Azure.Provisioning.Storage.StorageBuiltInRole.StorageTableDataContributor"
                          }
                        ]
                      },
                      {
                        "description": [
                          {
                            "kind": "cref",
                            "value": "P:Azure.Provisioning.Storage.StorageBuiltInRole.StorageQueueDataContributor"
                          }
                        ]
                      },
                      {
                        "description": [
                          {
                            "kind": "cref",
                            "value": "P:Azure.Provisioning.Storage.StorageBuiltInRole.StorageAccountContributor"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "kind": "text",
                    "text": " For more information, see "
                  },
                  {
                    "kind": "href",
                    "text": "Azure Functions host storage",
                    "value": "https://learn.microsoft.com/azure/azure-functions/dotnet-aspire-integration#azure-functions-host-storage"
                  },
                  {
                    "kind": "text",
                    "text": ". "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " Use "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.AzureFunctionsProjectResourceExtensions.WithHostStorage(Aspire.Hosting.ApplicationModel.IResourceBuilder{Aspire.Hosting.Azure.AzureFunctionsProjectResource},Aspire.Hosting.ApplicationModel.IResourceBuilder{Aspire.Hosting.Azure.AzureStorageResource})"
                  },
                  {
                    "kind": "text",
                    "text": " to specify a custom Azure Storage resource as the host storage instead of the implicit default storage account. "
                  }
                ]
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "An "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " for the added Azure Functions project resource."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The "
                },
                {
                  "kind": "cref",
                  "value": "T:Aspire.Hosting.IDistributedApplicationBuilder"
                },
                {
                  "kind": "text",
                  "text": " to which the Azure Functions project will be added."
                }
              ],
              "name": [
                {
                  "kind": "text",
                  "text": "The name to be associated with the Azure Functions project. This name will be used for service discovery when referenced in a dependency."
                }
              ]
            },
            "typeParameters": {
              "TProject": [
                {
                  "kind": "text",
                  "text": "The type of the project metadata, which must implement "
                },
                {
                  "kind": "cref",
                  "value": "T:Aspire.Hosting.IProjectMetadata"
                },
                {
                  "kind": "text",
                  "text": " and have a parameterless constructor."
                }
              ]
            }
          },

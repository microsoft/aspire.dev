          ],
          "attributes": [
            {
              "name": "System.Diagnostics.CodeAnalysis.ExperimentalAttribute",
              "constructorArguments": [
                "CTASPIRE001"
              ],
              "arguments": {
                "UrlFormat": "https://github.com/CommunityToolkit/Aspire/issues/{0}"
              }
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a Streamlit application to the application model. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " This method uses the Aspire.Hosting.Python integration to run Streamlit applications. By default, it uses the "
                  },
                  {
                    "kind": "code",
                    "text": ".venv"
                  },
                  {
                    "kind": "text",
                    "text": " virtual environment in the app directory. Use standard Python extension methods like "
                  },
                  {
                    "kind": "code",
                    "text": "WithVirtualEnvironment"
                  },
                  {
                    "kind": "text",
                    "text": ", "
                  },
                  {
                    "kind": "code",
                    "text": "WithPip"
                  },
                  {
                    "kind": "text",
                    "text": ", or "
                  },
                  {
                    "kind": "code",
                    "text": "WithUv"
                  },
                  {
                    "kind": "text",
                    "text": " to customize the environment. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " **⚠️ EXPERIMENTAL:** This integration is experimental and subject to change. The underlying implementation will be updated to use public APIs when they become available in Aspire.Hosting.Python (expected in Aspire 13.1). "
                  }
                ]
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "An "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " for the Streamlit application resource."
              }
            ],
            "parameters": {
              "appDirectory": [
                {
                  "kind": "text",
                  "text": "The path to the directory containing the Streamlit application."
                }
              ],
              "builder": [
                {
                  "kind": "text",
                  "text": "The "
                },
                {
                  "kind": "cref",
                  "value": "T:Aspire.Hosting.IDistributedApplicationBuilder"
                },
                {
                  "kind": "text",
                  "text": " to add the resource to."
                }
              ],
              "name": [
                {
                  "kind": "text",
                  "text": "The name of the Streamlit application."
                }
              ],
              "scriptPath": [
                {
                  "kind": "text",
                  "text": "The path to the Python script to be run by Streamlit (relative to appDirectory)."
                }
              ]
            },
            "examples": [
              {
                "code": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             builder.AddStreamlitApp(\"dashboard\", \"../streamlit-app\", \"app.py\")\n                    .WithHttpEndpoint(env: \"PORT\");\n            \n             builder.Build().Run();\n             ",
                "language": "csharp",
                "description": [
                  {
                    "kind": "text",
                    "text": "Add a Streamlit application to the application model:"
                  }
                ]
              }
            ]
          },
          "sourceFile": "src/CommunityToolkit.Aspire.Hosting.Python.Extensions/StreamlitAppHostingExtension.cs",
          "sourceLines": "50-102"
        }
      ]

          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.StreamlitAppResource>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",

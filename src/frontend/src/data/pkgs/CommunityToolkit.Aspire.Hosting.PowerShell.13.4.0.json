          "accessibility": "public",
          "signature": "public Task PowerShellScriptResource.StartAsync(ILogger scriptLogger, ResourceNotificationService notificationService, CancellationToken cancellationToken = default(CancellationToken))",
          "returnType": "System.Threading.Tasks.Task",
          "parameters": [
            {
              "name": "scriptLogger",

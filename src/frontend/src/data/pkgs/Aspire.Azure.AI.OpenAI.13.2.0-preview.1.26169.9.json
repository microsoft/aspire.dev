          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Gets or sets a boolean value indicating whether potentially sensitive information should be included in telemetry. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " By default, telemetry includes metadata, such as token counts, but not raw inputs and outputs, such as message content, function call arguments, and function call results. The default value can be overridden by setting the "
              },
              {
                "kind": "code",
                "text": "OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT"
              },
              {
                "kind": "text",
                "text": " environment variable to \"true\". Explicitly setting this property will override the environment variable. "
              }
            ],
            "value": [
              {
                "kind": "langword",
                "value": "true"
              },
              {
                "kind": "text",
                "text": " if potentially sensitive information should be included in telemetry; "
              },
              {
                "kind": "langword",
                "value": "false"
              },
              {
                "kind": "text",
                "text": " if telemetry shouldn't include raw inputs and outputs. The default value is "
              },
              {
                "kind": "langword",
                "value": "false"
              },
              {
                "kind": "text",
                "text": ", unless the "
              },
              {
                "kind": "code",
                "text": "OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT"
              },
              {
                "kind": "text",
                "text": " environment variable is set to \"true\" (case-insensitive). "
              }
            ]
          },
          "sourceFile": "src/Components/Aspire.Azure.AI.OpenAI/AzureOpenAISettings.cs"
        },

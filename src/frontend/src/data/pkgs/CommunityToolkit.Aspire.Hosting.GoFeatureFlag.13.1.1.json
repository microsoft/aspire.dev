            "summary": [
              {
                "kind": "text",
                "text": " Adds a named volume for the data folder to a GO Feature flag container resource. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Add a GO Feature flag container to the application model and reference it in a .NET project. Additionally, in this example a data volume is added to the container to allow data to be persisted across container restarts. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var goff = builder.AddGoFeatureFlag(\"goff\")\n             .WithDataVolume();\n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithReference(goff);\n              \n             builder.Build().Run(); \n             ",
                "language": "csharp"
              }

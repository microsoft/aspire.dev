            "summary": [
              {
                "kind": "text",
                "text": " Adds a bind mount for the goff configuration folder to a GO Feature flag container resource. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Add a GO Feature flag container to the application model and reference it in a .NET project. Additionally, in this example a bind mount is added to the container to allow reading goff configuration. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var goff = builder.AddGoFeatureFlag(\"goff\")\n             .WithGoffBindMount(\"./goff\");\n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithReference(goff);\n              \n             builder.Build().Run(); \n             ",
                "language": "csharp"
              }

          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds Keycloak JWT Bearer authentication to the application. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " The "
              },
              {
                "kind": "paramref",
                "value": "serviceName"
              },
              {
                "kind": "text",
                "text": " is used to resolve the Keycloak server URL and is combined with the realm to form the authority URL. For example, if "
              },
              {
                "kind": "paramref",
                "value": "serviceName"
              },
              {
                "kind": "text",
                "text": " is \"keycloak\" and "
              },
              {
                "kind": "paramref",
                "value": "realm"
              },
              {
                "kind": "text",
                "text": " is \"myrealm\", the authority URL will be \"https+http://keycloak/realms/myrealm\". "
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The "
                },
                {
                  "kind": "cref",
                  "value": "T:Microsoft.AspNetCore.Authentication.AuthenticationBuilder"
                },
                {
                  "kind": "text",
                  "text": " to add services to."
                }
              ],
              "realm": [
                {
                  "kind": "text",
                  "text": "The realm of the Keycloak server to connect to."
                }
              ],
              "serviceName": [
                {
                  "kind": "text",
                  "text": "The name of the service used to resolve the Keycloak server URL."
                }
              ]
            }
          },

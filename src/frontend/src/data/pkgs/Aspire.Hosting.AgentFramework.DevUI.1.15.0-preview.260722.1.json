    {
      "name": "AgentServiceAnnotation",
      "fullName": "Aspire.Hosting.ApplicationModel.AgentServiceAnnotation",
      "namespace": "Aspire.Hosting.ApplicationModel",
      "kind": "class",
      "accessibility": "public",
      "interfaces": [
        "Aspire.Hosting.ApplicationModel.IResourceAnnotation"
      ],
      "docs": {
        "summary": [
          {
            "kind": "text",
            "text": " An annotation that tracks an agent service backend referenced by a DevUI resource. "
          }
        ],
        "remarks": [
          {
            "kind": "text",
            "text": " This annotation is used to configure DevUI to aggregate entities from multiple agent service backends. Each annotation represents one backend that DevUI should connect to for entity discovery and request routing. "
          }
        ]
      },
      "members": [
        {
          "name": ".ctor",
          "kind": "constructor",
          "accessibility": "public",
          "signature": "public AgentServiceAnnotation.AgentServiceAnnotation(IResource agentService, string? entityIdPrefix = null, IReadOnlyList<AgentEntityInfo>? agents = null)",
          "returnType": "void",
          "parameters": [
            {
              "name": "agentService",
              "type": "Aspire.Hosting.ApplicationModel.IResource"
            },
            {
              "name": "entityIdPrefix",
              "type": "string?",
              "isNullable": true,
              "isOptional": true
            },
            {
              "name": "agents",
              "type": "System.Collections.Generic.IReadOnlyList<Aspire.Hosting.AgentFramework.AgentEntityInfo>?",
              "isNullable": true,
              "isOptional": true
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Initializes a new instance of the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.AgentServiceAnnotation"
              },
              {
                "kind": "text",
                "text": " class. "
              }
            ],
            "parameters": {
              "agents": [
                {
                  "kind": "text",
                  "text": " Optional list of agents declared by this backend. When provided, the aggregator builds the entity listing directly from these declarations instead of querying the backend's "
                },
                {
                  "kind": "code",
                  "text": "/v1/entities"
                },
                {
                  "kind": "text",
                  "text": " endpoint. "
                }

  },
  "types": [
    {
      "name": "AgentFrameworkBuilderExtensions",
      "fullName": "Aspire.Hosting.AgentFrameworkBuilderExtensions",
      "namespace": "Aspire.Hosting",
      "kind": "class",
      "accessibility": "public",
      "isStatic": true,
      "docs": {
        "summary": [
          {
            "kind": "text",
            "text": " Provides extension methods for adding Agent Framework DevUI resources to the application model. "
          }
        ]
      },
      "members": [
        {
          "name": "AddDevUI",
          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<DevUIResource> AgentFrameworkBuilderExtensions.AddDevUI(this IDistributedApplicationBuilder builder, string name, int? port = null)",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.DevUIResource>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",
              "type": "Aspire.Hosting.IDistributedApplicationBuilder",
              "modifier": "this"
            },
            {
              "name": "name",
              "type": "string"
            },
            {
              "name": "port",
              "type": "int?",
              "isNullable": true,
              "isOptional": true
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a DevUI resource for testing AI agents in a distributed application. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " DevUI is a web-based interface for testing and debugging AI agents using the OpenAI Responses protocol. When configured with "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.AgentFrameworkBuilderExtensions.WithAgentService``1(Aspire.Hosting.ApplicationModel.IResourceBuilder{Aspire.Hosting.ApplicationModel.DevUIResource},Aspire.Hosting.ApplicationModel.IResourceBuilder{``0},System.Collections.Generic.IReadOnlyList{Aspire.Hosting.AgentFramework.AgentEntityInfo},System.String)"
                  },
                  {
                    "kind": "text",
                    "text": ", it aggregates agents from multiple backend services and provides a unified testing interface. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " The aggregator runs as an in-process reverse proxy within the AppHost, requiring no external container image. It serves the DevUI frontend from embedded resources in Microsoft.Agents.AI.DevUI when available, and falls back to proxying from the first configured backend. It aggregates entity listings from all backends. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " This resource is excluded from the deployment manifest as it is intended for development use only. "
                  }
                ]
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " for chaining."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The "
                },
                {
                  "kind": "cref",
                  "value": "T:Aspire.Hosting.IDistributedApplicationBuilder"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": [
                {
                  "kind": "text",
                  "text": "The name to give the resource."
                }
              ],
              "port": [
                {
                  "kind": "text",
                  "text": "The host port for the DevUI web interface. If not specified, a random port will be assigned."
                }
              ]
            },
            "examples": [
              {
                "code": "\n            var devui = builder.AddDevUI(\"devui\")\n                .WithAgentService(dotnetAgent)\n                .WithAgentService(pythonAgent);\n            ",
                "language": "csharp"
              }
            ]
          }
        },
        {
          "name": "WithAgentService",
          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<DevUIResource> AgentFrameworkBuilderExtensions.WithAgentService<TSource>(this IResourceBuilder<DevUIResource> builder, IResourceBuilder<TSource> agentService, IReadOnlyList<AgentEntityInfo>? agents = null, string? entityIdPrefix = null)",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.DevUIResource>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",
              "type": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.DevUIResource>",
              "modifier": "this"
            },
            {
              "name": "agentService",
              "type": "Aspire.Hosting.ApplicationModel.IResourceBuilder<TSource>"
            },
            {
              "name": "agents",
              "type": "System.Collections.Generic.IReadOnlyList<Aspire.Hosting.AgentFramework.AgentEntityInfo>?",
              "isNullable": true,
              "isOptional": true
            },
            {
              "name": "entityIdPrefix",
              "type": "string?",
              "isNullable": true,
              "isOptional": true
            }
          ],
          "genericParameters": [
            {
              "name": "TSource",
              "constraints": [
                "Aspire.Hosting.ApplicationModel.IResourceWithEndpoints"
              ]
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Configures DevUI to connect to an agent service backend. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " Each agent service should expose the OpenAI Responses and Conversations API endpoints (via "
                  },
                  {
                    "kind": "code",
                    "text": "MapOpenAIResponses"
                  },
                  {
                    "kind": "text",
                    "text": " and "
                  },
                  {
                    "kind": "code",
                    "text": "MapOpenAIConversations"
                  },
                  {
                    "kind": "text",
                    "text": "). "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " When "
                  },
                  {
                    "kind": "paramref",
                    "value": "agents"
                  },
                  {
                    "kind": "text",
                    "text": " is provided, the aggregator builds the entity listing from these declarations without querying the backend. When not provided, a single agent named after the service resource is assumed. Agent services don't need a "
                  },
                  {
                    "kind": "code",
                    "text": "/v1/entities"
                  },
                  {
                    "kind": "text",
                    "text": " endpoint. "
                  }
                ]
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " for chaining."
              }
            ],
            "parameters": {
              "agents": [
                {
                  "kind": "text",
                  "text": " Optional list of agents declared by this backend. When provided, the aggregator uses these declarations directly. When not provided, defaults to a single agent named after the "
                },
                {
                  "kind": "paramref",
                  "value": "agentService"
                },
                {
                  "kind": "text",
                  "text": " resource. The backend doesn't need to expose a "
                },
                {
                  "kind": "code",
                  "text": "/v1/entities"
                },
                {
                  "kind": "text",
                  "text": " endpoint in either case. "
                }
              ],
              "agentService": [
                {
                  "kind": "text",
                  "text": "The agent service resource to connect to."
                }
              ],
              "builder": [
                {
                  "kind": "text",
                  "text": "The DevUI resource builder."
                }
              ],
              "entityIdPrefix": [
                {
                  "kind": "text",
                  "text": " An optional prefix to add to entity IDs from this backend. If not specified, the resource name will be used as the prefix. "
                }
              ]
            },
            "typeParameters": {
              "TSource": [
                {
                  "kind": "text",
                  "text": "The type of the agent service resource."
                }
              ]
            },
            "examples": [
              {
                "code": "\n             var writerAgent = builder.AddProject<Projects.WriterAgent>(\"writer-agent\");\n             var editorAgent = builder.AddProject<Projects.EditorAgent>(\"editor-agent\");\n            \n             builder.AddDevUI(\"devui\")\n                 .WithAgentService(writerAgent, agents: [new(\"writer\", \"Writes short stories\")])\n                 .WithAgentService(editorAgent, agents: [new(\"editor\", \"Edits and formats stories\")])\n                 .WaitFor(writerAgent)\n                 .WaitFor(editorAgent);\n             ",
                "language": "csharp"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "AgentEntityInfo",
      "fullName": "Aspire.Hosting.AgentFramework.AgentEntityInfo",
      "namespace": "Aspire.Hosting.AgentFramework",
      "kind": "record",
      "accessibility": "public",
      "interfaces": [
        "System.IEquatable<Aspire.Hosting.AgentFramework.AgentEntityInfo>"
      ],
      "docs": {
        "summary": [
          {
            "kind": "text",
            "text": " Describes an AI agent exposed by an agent service backend, used for entity discovery in DevUI. "
          }
        ],
        "remarks": [
          {
            "kind": "para",
            "children": [
              {
                "kind": "text",
                "text": " When added via "
              },
              {
                "kind": "cref",
                "value": "M:Aspire.Hosting.AgentFrameworkBuilderExtensions.WithAgentService``1(Aspire.Hosting.ApplicationModel.IResourceBuilder{Aspire.Hosting.ApplicationModel.DevUIResource},Aspire.Hosting.ApplicationModel.IResourceBuilder{``0},System.Collections.Generic.IReadOnlyList{Aspire.Hosting.AgentFramework.AgentEntityInfo},System.String)"
              },
              {
                "kind": "text",
                "text": ", agent metadata is declared at the AppHost level so that the DevUI aggregator can build the entity listing without querying each backend's "
              },
              {
                "kind": "code",
                "text": "/v1/entities"
              },
              {
                "kind": "text",
                "text": " endpoint. "
              }
            ]
          },
          {
            "kind": "para",
            "children": [
              {
                "kind": "text",
                "text": " Agent services only need to expose the standard OpenAI Responses and Conversations API endpoints ("
              },
              {
                "kind": "code",
                "text": "MapOpenAIResponses"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "MapOpenAIConversations"
              },
              {
                "kind": "text",
                "text": "), not a custom discovery endpoint. "
              }
            ]
          }
        ],
        "parameters": {
          "Description": [
            {
              "kind": "text",
              "text": "A short description of the agent's capabilities."
            }
          ],
          "Id": [
            {
              "kind": "text",
              "text": "The unique identifier for the agent, typically matching the name passed to "
            },
            {
              "kind": "code",
              "text": "AddAIAgent"
            },
            {
              "kind": "text",
              "text": "."
            }
          ]
        }
      },

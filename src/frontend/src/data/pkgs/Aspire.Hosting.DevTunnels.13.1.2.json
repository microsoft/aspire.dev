            {
              "name": "TResource",
              "constraints": [
                "Aspire.Hosting.ApplicationModel.IResourceWithEnvironment"
              ]
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Injects service discovery and endpoint information as environment variables from the dev tunnel resource into the destination resource, using the tunneled resource's name as the service name. Each endpoint defined on the target resource will be injected using the format defined by the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.ReferenceEnvironmentInjectionAnnotation"
              },
              {
                "kind": "text",
                "text": " on the destination resource, i.e. either \"services__{sourceResourceName}__{endpointName}__{endpointIndex}={uriString}\" for .NET service discovery, or \"{RESOURCE_ENDPOINT}={uri}\" for endpoint injection. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Referencing a dev tunnel will delay the start of the resource until the referenced dev tunnel's endpoint is allocated. "
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "The builder."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The builder."
                }
              ],
              "targetResource": [
                {
                  "kind": "text",
                  "text": "The resource to inject service discovery information for."
                }
              ],
              "tunnelResource": [
                {
                  "kind": "text",
                  "text": "The dev tunnel resource to resolve the tunnel address from."
                }
              ]
            }
          },

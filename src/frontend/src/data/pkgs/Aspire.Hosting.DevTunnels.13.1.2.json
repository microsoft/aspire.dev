          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a dev tunnel resource to the application model. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Dev tunnels can be used to expose local endpoints to the public internet via a secure tunnel. By default, the tunnel requires authentication, but anonymous access can be enabled via "
              },
              {
                "kind": "cref",
                "value": "M:Aspire.Hosting.DevTunnelsResourceBuilderExtensions.WithAnonymousAccess(Aspire.Hosting.ApplicationModel.IResourceBuilder{Aspire.Hosting.DevTunnels.DevTunnelResource})"
              },
              {
                "kind": "text",
                "text": ". "
              }
            ],
            "examples": [
              {
                "code": "\n            var builder = DistributedApplication.CreateBuilder(args);\n            var web = builder.AddProject<Projects.WebApp>(\"web\");\n            var tunnel = builder.AddDevTunnel(\"mytunnel\")\n                .WithReference(web)\n                .WithAnonymousAccess();\n            builder.Build().Run();\n            ",
                "language": "csharp",
                "description": [
                  {
                    "kind": "text",
                    "text": "The following example shows how to create a dev tunnel resource that exposes all endpoints on a web application project and enable anonymous access:"
                  }
                ]
              }
            ]
          },
          "sourceFile": "src/Aspire.Hosting.DevTunnels/DevTunnelResourceBuilderExtensions.cs",
          "sourceLines": "49-214"

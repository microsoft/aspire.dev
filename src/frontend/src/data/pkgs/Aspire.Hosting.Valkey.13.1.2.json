              "type": "string"
            },
            {
              "name": "isReadOnly",
              "type": "bool",
              "isOptional": true,
              "defaultValue": "False"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a bind mount for the data folder to a Valkey container resource and enables Valkey persistence. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Use "
              },
              {
                "kind": "cref",
                "value": "M:Aspire.Hosting.ValkeyBuilderExtensions.WithPersistence(Aspire.Hosting.ApplicationModel.IResourceBuilder{Aspire.Hosting.ApplicationModel.ValkeyResource},System.Nullable{System.TimeSpan},System.Int64)"
              },
              {
                "kind": "text",
                "text": " to adjust Valkey persistence configuration, e.g.: "
              },
              {
                "kind": "codeblock",
                "text": "\n            var valkey = builder.AddValkey(\"valkey\")\n                               .WithDataBindMount(\"mydata\")\n                               .WithPersistence(TimeSpan.FromSeconds(10), 5);\n            ",
                "language": "csharp"
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "The "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The resource builder."
                }
              ],
              "isReadOnly": [
                {
                  "kind": "text",
                  "text": " A flag that indicates if this is a read-only mount. Setting this to "
                },
                {
                  "kind": "code",
                  "text": "true"
                },
                {
                  "kind": "text",
                  "text": " will disable Valkey persistence."
                },
                {
                  "kind": "text",
                  "text": " Defaults to "
                },
                {
                  "kind": "code",
                  "text": "false"
                },
                {
                  "kind": "text",
                  "text": ". "
                }
              ],
              "source": [
                {
                  "kind": "text",
                  "text": "The source directory on the host to mount into the container."
                }
              ]
            }
          },
          "sourceFile": "src/Aspire.Hosting.Valkey/ValkeyBuilderExtensions.cs",
          "sourceLines": "244-253"

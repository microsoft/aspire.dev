          "accessibility": "public",
          "signature": "public static IResourceBuilder<ValkeyResource> ValkeyBuilderExtensions.WithDataBindMount(this IResourceBuilder<ValkeyResource> builder, string source, bool isReadOnly = false)",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.ApplicationModel.ValkeyResource>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [

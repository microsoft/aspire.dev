              "name": "T",
              "constraints": [
                "Aspire.Hosting.ApplicationModel.IResource"
              ]
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Assigns the specified roles to the given resource, granting it the necessary permissions on the target Azure Web PubSub resource. This replaces the default role assignments for the resource. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Assigns the WebPubSubServiceReader role to the 'Projects.Api' project. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var webPubSub = builder.AddAzureWebPubSub(\"webPubSub\");\n            \n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithRoleAssignments(webPubSub, WebPubSubBuiltInRole.WebPubSubServiceReader)\n               .WithReference(webPubSub);\n             ",
                "language": "csharp"
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "The updated "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " with the applied role assignments."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The resource to which the specified roles will be assigned."
                }
              ],
              "roles": [
                {
                  "kind": "text",
                  "text": "The built-in Web PubSub roles to be assigned."
                }
              ],
              "target": [
                {
                  "kind": "text",
                  "text": "The target Azure Web PubSub resource."
                }
              ]
            }
          },

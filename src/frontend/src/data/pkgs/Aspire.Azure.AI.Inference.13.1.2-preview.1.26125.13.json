              }
            ],
            "value": [
              {
                "kind": "langword",
                "value": "true"
              },
              {
                "kind": "text",
                "text": " if potentially sensitive information should be included in telemetry; "
              },
              {
                "kind": "langword",
                "value": "false"
              },
              {
                "kind": "text",
                "text": " if telemetry shouldn't include raw inputs and outputs. The default value is "
              },
              {
                "kind": "langword",
                "value": "false"
              },
              {
                "kind": "text",
                "text": ", unless the "
              },
              {
                "kind": "code",
                "text": "OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT"
              },
              {
                "kind": "text",
                "text": " environment variable is set to \"true\" (case-insensitive). "
              }
            ]

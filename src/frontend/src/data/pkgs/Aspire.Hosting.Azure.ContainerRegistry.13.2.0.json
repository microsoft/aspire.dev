                  {
                    "kind": "paramref",
                    "value": "taskName"
                  },
                  {
                    "kind": "text",
                    "text": " conflicts with an existing task."
                  }
                ]
              },
              {
                "type": "T:System.ArgumentOutOfRangeException",
                "description": [
                  {
                    "kind": "text",
                    "text": "Thrown when "
                  },
                  {
                    "kind": "paramref",
                    "value": "keep"
                  },
                  {
                    "kind": "text",
                    "text": " is less than 1, or "
                  },
                  {
                    "kind": "paramref",
                    "value": "ago"
                  },
                  {
                    "kind": "text",
                    "text": " is negative or less than 1 minute (when non-zero)."
                  }
                ]
              }
            ],
            "examples": [
              {
                "code": "\n            var acr = builder.AddAzureContainerRegistry(\"myregistry\")\n                .WithPurgeTask(\"0 1 * * *\", ago: TimeSpan.FromDays(7), keep: 5);\n            ",
                "language": "csharp",
                "description": [
                  {
                    "kind": "text",
                    "text": "This example configures a daily purge task that removes images older than 7 days, keeping the 5 most recent:"

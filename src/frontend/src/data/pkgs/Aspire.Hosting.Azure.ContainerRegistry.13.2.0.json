                    "kind": "langword",
                    "value": "null"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ]
              },
              {
                "type": "T:System.ArgumentException",
                "description": [
                  {
                    "kind": "text",
                    "text": "Thrown when "
                  },
                  {
                    "kind": "paramref",
                    "value": "schedule"
                  },
                  {
                    "kind": "text",
                    "text": " is "
                  },
                  {
                    "kind": "langword",
                    "value": "null"
                  },
                  {
                    "kind": "text",
                    "text": ", empty, or whitespace, or when "

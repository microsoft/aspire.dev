          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a scheduled ACR purge task to remove old or unused container images from the registry. "
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " for chaining."
              }
            ],
            "parameters": {
              "ago": [
                {
                  "kind": "text",
                  "text": "The age threshold for "
                },
                {
                  "kind": "code",
                  "text": "acr purge --ago"
                },
                {
                  "kind": "text",
                  "text": ". Images older than this duration will be considered for removal. Uses Go-style duration format (e.g., "
                },
                {
                  "kind": "code",
                  "text": "2d3h6m"
                },
                {
                  "kind": "text",
                  "text": "). Defaults to "
                },
                {
                  "kind": "code",
                  "text": "0d"
                },
                {
                  "kind": "text",
                  "text": " when "
                },
                {
                  "kind": "langword",
                  "value": "null"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "builder": [
                {
                  "kind": "text",
                  "text": "The resource builder for the "
                },
                {
                  "kind": "cref",
                  "value": "T:Aspire.Hosting.Azure.AzureContainerRegistryResource"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "filter": [
                {
                  "kind": "text",
                  "text": "An optional filter for the "
                },
                {
                  "kind": "code",
                  "text": "acr purge --filter"
                },
                {
                  "kind": "text",
                  "text": " parameter. Only repositories matching this filter will be purged. Defaults to "
                },
                {
                  "kind": "code",
                  "text": "\".*:.*\""
                },
                {
                  "kind": "text",
                  "text": " (all repositories and tags) when "
                },
                {
                  "kind": "langword",
                  "value": "null"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "keep": [
                {
                  "kind": "text",
                  "text": "The number of most recent images to keep per repository, regardless of age. Must be greater than zero. Defaults to 3."
                }
              ],
              "schedule": [
                {
                  "kind": "text",
                  "text": "The cron schedule for the purge task timer trigger. Must be a five-part cron expression ("
                },
                {
                  "kind": "code",
                  "text": "minute hour day-of-month month day-of-week"
                },
                {
                  "kind": "text",
                  "text": "); seconds are not supported."
                }
              ],
              "taskName": [
                {
                  "kind": "text",
                  "text": "An optional name for the ACR task resource. If not provided, a name is auto-generated based on existing purge tasks to avoid conflicts. If a task with the specified name already exists, an "
                },
                {
                  "kind": "cref",
                  "value": "T:System.ArgumentException"
                },
                {
                  "kind": "text",
                  "text": " is thrown."
                }
              ]
            },
            "exceptions": [
              {
                "type": "T:System.ArgumentNullException",
                "description": [
                  {
                    "kind": "text",
                    "text": "Thrown when "
                  },
                  {
                    "kind": "paramref",

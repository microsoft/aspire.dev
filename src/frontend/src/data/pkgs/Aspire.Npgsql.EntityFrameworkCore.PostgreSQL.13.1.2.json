          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Registers the given "
              },
              {
                "kind": "cref",
                "value": "T:Microsoft.EntityFrameworkCore.DbContext"
              },
              {
                "kind": "text",
                "text": " as a service in the services provided by the "
              },
              {
                "kind": "paramref",
                "value": "builder"
              },
              {
                "kind": "text",
                "text": ". Enables db context pooling, retries, corresponding health check, logging and telemetry. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " Reads the configuration from \"Aspire:Npgsql:EntityFrameworkCore:PostgreSQL:{typeof(TContext).Name}\" config section, or \"Aspire:Npgsql:EntityFrameworkCore:PostgreSQL\" if former does not exist. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " The "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Microsoft.EntityFrameworkCore.DbContext.OnConfiguring(Microsoft.EntityFrameworkCore.DbContextOptionsBuilder)"
                  },
                  {
                    "kind": "text",
                    "text": " method can then be overridden to configure "
                  },
                  {
                    "kind": "cref",
                    "value": "T:Microsoft.EntityFrameworkCore.DbContext"
                  },
                  {
                    "kind": "text",
                    "text": " options. "
                  }
                ]
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The "
                },
                {
                  "kind": "cref",
                  "value": "T:Microsoft.Extensions.Hosting.IHostApplicationBuilder"
                },
                {
                  "kind": "text",
                  "text": " to read config from and add services to."
                }
              ],
              "configureDbContextOptions": [
                {
                  "kind": "text",
                  "text": "An optional delegate to configure the "
                },
                {
                  "kind": "cref",
                  "value": "T:Microsoft.EntityFrameworkCore.DbContextOptions"
                },
                {
                  "kind": "text",
                  "text": " for the context."
                }
              ],
              "configureSettings": [
                {
                  "kind": "text",
                  "text": "An optional delegate that can be used for customizing options. It's invoked after the settings are read from the configuration."
                }
              ],
              "connectionName": [
                {
                  "kind": "text",
                  "text": "A name used to retrieve the connection string from the ConnectionStrings configuration section."
                }
              ]
            },
            "typeParameters": {
              "TContext": [
                {
                  "kind": "text",
                  "text": "The "
                },
                {
                  "kind": "cref",
                  "value": "T:Microsoft.EntityFrameworkCore.DbContext"
                },
                {
                  "kind": "text",
                  "text": " that needs to be registered."
                }
              ]
            },
            "exceptions": [
              {
                "type": "T:System.ArgumentNullException",
                "description": [
                  {
                    "kind": "text",
                    "text": "Thrown if mandatory "
                  },
                  {
                    "kind": "paramref",
                    "value": "builder"
                  },
                  {
                    "kind": "text",
                    "text": " is null."
                  }
                ]
              },

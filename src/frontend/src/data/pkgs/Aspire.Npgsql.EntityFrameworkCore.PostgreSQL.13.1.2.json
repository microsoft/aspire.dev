              "modifier": "this"
            },
            {
              "name": "connectionName",
              "type": "string"
            },
            {
              "name": "configureSettings",
              "type": "System.Action<Aspire.Npgsql.EntityFrameworkCore.PostgreSQL.NpgsqlEntityFrameworkCorePostgreSQLSettings>?",
              "isNullable": true,
              "isOptional": true
            },
            {

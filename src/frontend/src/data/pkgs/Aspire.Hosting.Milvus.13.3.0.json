          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a Milvus database to the application model. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": "This method does not actually create the database in Milvus, rather helps complete a connection string that is used by the client component. "
              },
              {
                "kind": "text",
                "text": " Use in application host "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var booksdb = builder.AddMilvus(\"milvus\");\n               .AddDatabase(\"booksdb\");\n            \n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithReference(booksdb);\n            \n             builder.Build().Run();\n             ",
                "language": "csharp"
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The Milvus server resource builder."
                }
              ],
              "databaseName": [
                {
                  "kind": "text",
                  "text": "The name of the database. If not provided, this defaults to the same value as "
                },
                {
                  "kind": "paramref",
                  "value": "name"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": [
                {
                  "kind": "text",
                  "text": "The name of the resource. This name will be used as the connection string name when referenced in a dependency."
                }
              ]
            }
          },

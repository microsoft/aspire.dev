            }
          ],
          "attributes": [
            {
              "name": "Aspire.Hosting.AspireExportAttribute"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds an Azure Key Vault resource to the application model. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " By default references to the Azure Key Vault resource will be assigned the following roles: "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " - "
                  },
                  {
                    "kind": "cref",
                    "value": "P:Azure.Provisioning.KeyVault.KeyVaultBuiltInRole.KeyVaultAdministrator"
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " These can be replaced by calling "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.AzureKeyVaultResourceExtensions.WithRoleAssignments``1(Aspire.Hosting.ApplicationModel.IResourceBuilder{``0},Aspire.Hosting.ApplicationModel.IResourceBuilder{Aspire.Hosting.Azure.AzureKeyVaultResource},Azure.Provisioning.KeyVault.KeyVaultBuiltInRole[])"
                  },
                  {
                    "kind": "text",
                    "text": ". "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": "Managing Secrets:"
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " Use the "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.AzureKeyVaultResourceExtensions.AddSecret(Aspire.Hosting.ApplicationModel.IResourceBuilder{Aspire.Hosting.Azure.AzureKeyVaultResource},System.String,Aspire.Hosting.ApplicationModel.ParameterResource)"
                  },
                  {
                    "kind": "text",
                    "text": " methods to add secrets to the Key Vault: "
                  }
                ]
              },
              {
                "kind": "codeblock",
                "text": "\n            var builder = DistributedApplication.CreateBuilder(args);\n            \n            var vault = builder.AddAzureKeyVault(\"vault\");\n            \n            // Add a secret from a parameter\n            var secret = builder.AddParameter(\"secretParam\", secret: true);\n            vault.AddSecret(\"my-secret\", secret);\n            \n            // Add a secret from a reference expression\n            var connectionString = ReferenceExpression.Create($\"Server={server};Database={db}\");\n            vault.AddSecret(\"connection-string\", connectionString);\n            \n            // Get a reference to an existing secret\n            var existingSecret = vault.GetSecret(\"existing-secret\");\n            ",
                "language": "csharp"
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The "
                },
                {
                  "kind": "cref",
                  "value": "T:Aspire.Hosting.IDistributedApplicationBuilder"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": [
                {
                  "kind": "text",
                  "text": "The name of the resource. This name will be used as the connection string name when referenced in a dependency."
                }
              ]
            }
          },

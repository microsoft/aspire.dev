          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<AzureKeyVaultResource> AzureKeyVaultResourceExtensions.AddAzureKeyVault(this IDistributedApplicationBuilder builder, string name)",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.Azure.AzureKeyVaultResource>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",

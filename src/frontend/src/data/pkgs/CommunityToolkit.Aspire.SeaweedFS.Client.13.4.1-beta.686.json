        "summary": [
          {
            "kind": "text",
            "text": " A strongly-typed HTTP client for interacting with the SeaweedFS Native Filer API. "
          }
        ],
        "remarks": [
          {
            "kind": "text",
            "text": " The "
          },
          {
            "kind": "cref",
            "value": "T:CommunityToolkit.Aspire.SeaweedFS.Client.SeaweedFSFilerClient"
          },
          {
            "kind": "text",
            "text": " provides a direct interface to the SeaweedFS Filer node, allowing for file system operations such as listing, creating, and managing files/directories. "
          },
          {
            "kind": "para",
            "children": [
              {
                "kind": "text",
                "text": "Usage example:"
              },
              {
                "kind": "codeblock",
                "text": "\n            public class MyService(SeaweedFSFilerClient filerClient)\n            {\n                public async Task ListFilesAsync()\n                {\n                    var response = await filerClient.HttpClient.GetAsync(\"/\");\n                    // ...\n                }\n            }\n            ",
                "language": "csharp"
              }
            ]
          }
        ],

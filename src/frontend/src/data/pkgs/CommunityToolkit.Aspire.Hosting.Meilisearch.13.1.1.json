          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a bind mount for the data folder to a Meilisearch container resource. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Add an Meilisearch container to the application model and reference it in a .NET project. Additionally, in this example a bind mount is added to the container to allow data to be persisted across container restarts. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var meilisearch = builder.AddMeilisearch(\"meilisearch\")\n             .WithDataBindMount(\"./data/meilisearch/data\");\n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithReference(meilisearch);\n              \n             builder.Build().Run(); \n             ",
                "language": "csharp"
              }
            ],

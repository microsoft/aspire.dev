            "summary": [
              {
                "kind": "text",
                "text": " Configures the RabbitMQ container resource to enable the RabbitMQ management plugin. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " This method only supports custom tags matching the default RabbitMQ ones for the corresponding management tag to be inferred automatically, e.g. "
              },
              {
                "kind": "code",
                "text": "4"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "kind": "code",
                "text": "4.0-alpine"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "kind": "code",
                "text": "4.0.2-management-alpine"
              },
              {
                "kind": "text",
                "text": ", etc."
              },
              {
                "kind": "text",
                "text": " Calling this method on a resource configured with an unrecognized image registry, name, or tag will result in a "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.DistributedApplicationException"
              },
              {
                "kind": "text",
                "text": " being thrown. This version of the package defaults to the "
              },
              {
                "kind": "text",
                "text": " tag of the "
              },
              {
                "kind": "text",
                "text": " container image. "
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "The "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The resource builder."
                }
              ]
            },
            "exceptions": [
              {
                "type": "T:Aspire.Hosting.DistributedApplicationException",
                "description": [
                  {
                    "kind": "text",
                    "text": "Thrown when the current container image and tag do not match the defaults for "
                  },
                  {

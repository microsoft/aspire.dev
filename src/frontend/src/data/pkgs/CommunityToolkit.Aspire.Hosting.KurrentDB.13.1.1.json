              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var kurrentdb = builder.AddKurrentDB(\"kurrentdb\")\n               .WithDataVolume();\n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithReference(kurrentdb);\n              \n             builder.Build().Run(); \n             ",

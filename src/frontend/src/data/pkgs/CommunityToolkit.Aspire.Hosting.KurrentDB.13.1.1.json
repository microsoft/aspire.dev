          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a bind mount for the data folder to a KurrentDB container resource. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Add a KurrentDB container to the application model and reference it in a .NET project. Additionally, in this example a bind mount is added to the container to allow data to be persisted across container restarts. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var kurrentdb = builder.AddKurrentDB(\"kurrentdb\")\n               .WithDataBindMount(\"./data/kurrentdb/data\");\n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithReference(kurrentdb);\n              \n             builder.Build().Run(); \n             ",
                "language": "csharp"
              }
            ],

              "modifier": "params"
            }
          ],
          "genericParameters": [
            {
              "name": "T",
              "constraints": [
                "Aspire.Hosting.ApplicationModel.IResource"
              ]
            }
          ],
          "attributes": [
            {
              "name": "Aspire.Hosting.AspireExportIgnoreAttribute"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Assigns the specified roles to the given resource, granting it the necessary permissions on the target Azure OpenAI resource. This replaces the default role assignments for the resource. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " This overload is not available in polyglot app hosts. Use the enum-based overload instead. "
              },
              {
                "kind": "text",
                "text": " Assigns the CognitiveServicesOpenAIUser role to the 'Projects.Api' project. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var openai = builder.AddAzureOpenAI(\"openai\");\n             \n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithRoleAssignments(openai, CognitiveServicesBuiltInRole.CognitiveServicesOpenAIUser)\n               .WithReference(openai);\n             ",
                "language": "csharp"
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "The updated "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " with the applied role assignments."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The resource to which the specified roles will be assigned."
                }
              ],
              "roles": [
                {
                  "kind": "text",
                  "text": "The built-in Cognitive Services roles to be assigned."
                }
              ],
              "target": [
                {
                  "kind": "text",
                  "text": "The target Azure OpenAI resource."
                }
              ]
            }
          },

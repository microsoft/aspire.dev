          "signature": "public static IResourceBuilder<T> AzureOpenAIExtensions.WithRoleAssignments<T>(this IResourceBuilder<T> builder, IResourceBuilder<AzureOpenAIResource> target, params CognitiveServicesBuiltInRole[] roles)",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<T>",

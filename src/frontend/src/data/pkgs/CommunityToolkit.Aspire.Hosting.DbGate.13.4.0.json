              "name": "resourceName",
              "type": "string"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Sanitizes a resource name to be used as a connection ID in DbGate environment variables. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " This method performs basic sanitization by replacing hyphens with underscores, as hyphens are not valid in Linux environment variable names. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " Note: Linux environment variable names have additional constraints (must contain only letters, numbers, and underscores, and cannot start with a number). This method does not validate or enforce these additional constraints. Resource names should follow standard naming conventions to ensure compatibility. "
                  }
                ]
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A sanitized connection ID safe for use in environment variable names."
              }
            ],
            "parameters": {
              "resourceName": [
                {
                  "kind": "text",
                  "text": "The resource name to sanitize."
                }
              ]
            }

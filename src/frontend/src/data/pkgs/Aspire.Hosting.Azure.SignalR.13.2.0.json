          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Assigns the specified roles to the given resource, granting it the necessary permissions on the target Azure SignalR resource. This replaces the default role assignments for the resource. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Assigns the SignalRContributor role to the 'Projects.Api' project. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var signalr = builder.AddAzureSignalR(\"signalr\");\n             \n             var api = builder.AddProject<Projects.Api>(\"api\")\n               .WithRoleAssignments(signalr, SignalRBuiltInRole.SignalRContributor)\n               .WithReference(signalr);\n             ",
                "language": "csharp"
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "The updated "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " with the applied role assignments."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The resource to which the specified roles will be assigned."
                }
              ],
              "roles": [
                {
                  "kind": "text",
                  "text": "The built-in SignalR roles to be assigned."
                }
              ],
              "target": [
                {
                  "kind": "text",
                  "text": "The target Azure SignalR resource."
                }
              ]
            }

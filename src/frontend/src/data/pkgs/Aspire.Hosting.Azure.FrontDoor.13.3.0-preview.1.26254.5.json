            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Gets the endpoint URL output reference for a specific origin by its resource name. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " The output name follows the pattern "
              },
              {
                "kind": "code",
                "text": "{normalizedOriginName}_endpointUrl"
              },
              {
                "kind": "text",
                "text": ". For example, if the origin resource is named \"api\", the output is "
              },
              {
                "kind": "code",
                "text": "api_endpointUrl"
              },
              {
                "kind": "text",
                "text": ". "
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.Azure.BicepOutputReference"
              },
              {
                "kind": "text",
                "text": " for the Front Door endpoint URL serving that origin."
              }
            ],

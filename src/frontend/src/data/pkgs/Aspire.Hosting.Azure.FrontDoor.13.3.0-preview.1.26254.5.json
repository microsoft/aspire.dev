            }
          ],
          "genericParameters": [
            {
              "name": "T",
              "constraints": [
                "Aspire.Hosting.ApplicationModel.IComputeResource",
                "Aspire.Hosting.ApplicationModel.IResourceWithEndpoints"
              ]
            }
          ],
          "attributes": [
            {
              "name": "Aspire.Hosting.AspireExportAttribute"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds an origin (backend) to the Azure Front Door resource. Each origin gets its own Front Door endpoint with a distinct "
              },
              {
                "kind": "code",
                "text": "*.azurefd.net"
              },
              {
                "kind": "text",
                "text": " hostname, its own origin group, and a default route. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Add multiple origins (each gets its own Front Door endpoint): "
              },
              {
                "kind": "codeblock",
                "text": "\n            var frontDoor = builder.AddAzureFrontDoor(\"frontdoor\")\n                .WithOrigin(api)\n                .WithOrigin(web);\n            ",
                "language": "csharp"
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " for chaining."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The Azure Front Door resource builder."
                }
              ],
              "resource": [
                {
                  "kind": "text",
                  "text": "The resource to add as an origin (e.g., a project, container, or other compute resource with endpoints)."
                }
              ]
            },
            "typeParameters": {
              "T": [
                {
                  "kind": "text",
                  "text": "The type of the resource with endpoints."
                }
              ]
            }
          },
          "sourceFile": "src/Aspire.Hosting.Azure.FrontDoor/AzureFrontDoorExtensions.cs",

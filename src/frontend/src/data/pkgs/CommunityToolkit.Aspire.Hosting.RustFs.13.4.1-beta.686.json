          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a bind mount for the data folder to a RustFs container resource. "
              }
            ],
            "remarks": [
              {
                "kind": "text",
                "text": " Add a RustFs container to the application model and reference it in a .NET project. Additionally, in this example a bind mount is added to the container to allow data to be persisted across container restarts. "
              },
              {
                "kind": "codeblock",
                "text": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             var rustfs = builder.AddRustFs(\"rustfs\")\n                 .WithDataBindMount(\"./data/rustfs/data\");\n             var api = builder.AddProject<Projects.Api>(\"api\")\n                 .WithReference(rustfs);\n            \n             builder.Build().Run();\n             ",
                "language": "csharp"
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "The "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],

      "members": [
        {
          "name": "AddGoApp",
          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<GoAppResource> GoHostingExtensions.AddGoApp(this IDistributedApplicationBuilder builder, string name, string appDirectory, string packagePath = \".\", string[]? buildTags = null, string? ldFlags = null, string? gcFlags = null, bool raceDetector = false)",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<Aspire.Hosting.Go.GoAppResource>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",
              "type": "Aspire.Hosting.IDistributedApplicationBuilder",
              "modifier": "this"
            },
            {
              "name": "name",
              "type": "string"
            },
            {
              "name": "appDirectory",
              "type": "string"
            },
            {
              "name": "packagePath",
              "type": "string",
              "isOptional": true,
              "defaultValue": "."
            },
            {
              "name": "buildTags",
              "type": "string[]?",
              "isNullable": true,
              "isOptional": true
            },
            {
              "name": "ldFlags",
              "type": "string?",
              "isNullable": true,
              "isOptional": true
            },
            {
              "name": "gcFlags",
              "type": "string?",
              "isNullable": true,
              "isOptional": true
            },
            {
              "name": "raceDetector",
              "type": "bool",
              "isOptional": true,
              "defaultValue": "False"
            }
          ],
          "attributes": [
            {
              "name": "Aspire.Hosting.AspireExportAttribute"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a Go application to the application model. The Go toolchain must be available on the PATH. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " This method executes the Go application using "
                  },
                  {
                    "kind": "code",
                    "text": "go run ."
                  },
                  {
                    "kind": "text",
                    "text": ". The Go toolchain resolves the entry point from the package in "
                  },
                  {
                    "kind": "paramref",
                    "value": "appDirectory"
                  },
                  {
                    "kind": "text",
                    "text": ". "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " Go applications automatically have VS Code debugging support enabled via Delve. Use "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.GoHostingExtensions.WithModTidy``1(Aspire.Hosting.ApplicationModel.IResourceBuilder{``0})"
                  },
                  {
                    "kind": "text",
                    "text": ", "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.GoHostingExtensions.WithModVendor``1(Aspire.Hosting.ApplicationModel.IResourceBuilder{``0})"
                  },
                  {
                    "kind": "text",
                    "text": ", or "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.GoHostingExtensions.WithModDownload``1(Aspire.Hosting.ApplicationModel.IResourceBuilder{``0})"
                  },
                  {
                    "kind": "text",
                    "text": " to manage module dependencies before startup, and "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.GoHostingExtensions.WithVetTool``1(Aspire.Hosting.ApplicationModel.IResourceBuilder{``0})"
                  },
                  {
                    "kind": "text",
                    "text": " to run static analysis. Use "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.GoHostingExtensions.WithAppArgs``1(Aspire.Hosting.ApplicationModel.IResourceBuilder{``0},System.Object[])"
                  },
                  {
                    "kind": "text",
                    "text": " to pass runtime program arguments, and "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.GoHostingExtensions.WithDelveServer``1(Aspire.Hosting.ApplicationModel.IResourceBuilder{``0},System.Int32)"
                  },
                  {
                    "kind": "text",
                    "text": " to enable remote debugging via a headless Delve server. "
                  }
                ]
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "parameters": {
              "appDirectory": [
                {
                  "kind": "text",
                  "text": " The path to the directory that acts as both the Go module root (where "
                },
                {
                  "kind": "code",
                  "text": "go.mod"
                },
                {
                  "kind": "text",
                  "text": " lives) and the Docker build context for "
                },
                {
                  "kind": "code",
                  "text": "aspire publish"
                },
                {
                  "kind": "text",
                  "text": ". "
                }
              ],
              "builder": [
                {
                  "kind": "text",
                  "text": "The "
                },
                {
                  "kind": "cref",
                  "value": "T:Aspire.Hosting.IDistributedApplicationBuilder"
                },
                {
                  "kind": "text",
                  "text": " to add the resource to."
                }
              ],
              "buildTags": [
                {
                  "kind": "text",
                  "text": "Optional build tags passed to the compiler via "
                },
                {
                  "kind": "code",
                  "text": "-tags"
                },
                {
                  "kind": "text",
                  "text": " (e.g. "
                },
                {
                  "kind": "code",
                  "text": "\"netgo\""
                },
                {
                  "kind": "text",
                  "text": ", "
                },
                {
                  "kind": "code",
                  "text": "\"integration\""
                },
                {
                  "kind": "text",
                  "text": ")."
                }
              ],
              "gcFlags": [
                {
                  "kind": "text",
                  "text": "Optional compiler flags passed via "
                },
                {
                  "kind": "code",
                  "text": "-gcflags"
                },
                {
                  "kind": "text",
                  "text": " (e.g. "
                },
                {
                  "kind": "code",
                  "text": "\"all=-N -l\""
                },
                {
                  "kind": "text",
                  "text": " to disable optimisations for Delve)."
                }
              ],
              "ldFlags": [
                {
                  "kind": "text",
                  "text": "Optional linker flags passed via "
                },
                {
                  "kind": "code",
                  "text": "-ldflags"
                },
                {
                  "kind": "text",
                  "text": " (e.g. "
                },
                {
                  "kind": "code",
                  "text": "\"-X main.version=1.0.0\""
                },
                {
                  "kind": "text",
                  "text": ")."
                }
              ],
              "name": [
                {
                  "kind": "text",
                  "text": "The name of the resource."
                }
              ],
              "packagePath": [
                {
                  "kind": "text",
                  "text": " The Go package to run or build, relative to "
                },
                {
                  "kind": "paramref",
                  "value": "appDirectory"
                },
                {
                  "kind": "text",
                  "text": ". Defaults to "
                },
                {
                  "kind": "code",
                  "text": "\".\""
                },
                {
                  "kind": "text",
                  "text": " (the module root itself). Use a sub-path such as "
                },
                {
                  "kind": "code",
                  "text": "\"./cmd/server\""
                },
                {
                  "kind": "text",
                  "text": " when the main package is not at the module root (e.g. "
                },
                {
                  "kind": "code",
                  "text": "api/cmd/server/main.go"
                },
                {
                  "kind": "text",
                  "text": " with "
                },
                {
                  "kind": "code",
                  "text": "api/go.mod"
                },
                {
                  "kind": "text",
                  "text": "). This value is passed to "
                },
                {
                  "kind": "code",
                  "text": "go run"
                },
                {
                  "kind": "text",
                  "text": ", "
                },
                {
                  "kind": "code",
                  "text": "dlv debug"
                },
                {
                  "kind": "text",
                  "text": ", and "
                },
                {
                  "kind": "code",
                  "text": "go build"
                },
                {
                  "kind": "text",
                  "text": " consistently. "
                }
              ],
              "raceDetector": [
                {
                  "kind": "text",
                  "text": "When "
                },
                {
                  "kind": "langword",
                  "value": "true"
                },
                {
                  "kind": "text",
                  "text": ", enables the Go race detector by passing "
                },
                {
                  "kind": "code",
                  "text": "-race"
                },
                {
                  "kind": "text",
                  "text": " to "
                },
                {
                  "kind": "code",
                  "text": "go run"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ]
            },
            "examples": [
              {
                "code": "\n             var builder = DistributedApplication.CreateBuilder(args);\n            \n             builder.AddGoApp(\"api\", \"../go-api\",\n                        buildTags: [\"netgo\"],\n                        ldFlags: \"-X main.version=1.0.0\")\n                    .WithHttpEndpoint(port: 8080)\n                    .WithExternalHttpEndpoints();\n            \n             builder.Build().Run();\n             ",
                "language": "csharp",
                "description": [
                  {
                    "kind": "text",
                    "text": "Add a Go API to the application model with build tags and linker flags:"
                  }
                ]
              }
            ]
          },
          "sourceFile": "src/Aspire.Hosting.Go/GoHostingExtensions.cs",
          "sourceLines": "82-327"
        },

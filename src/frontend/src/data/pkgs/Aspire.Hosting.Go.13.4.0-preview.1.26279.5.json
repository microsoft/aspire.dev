        {
          "name": "WithDelveServer",
          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<T> GoHostingExtensions.WithDelveServer<T>(this IResourceBuilder<T> builder, int port = 2345)",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<T>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",
              "type": "Aspire.Hosting.ApplicationModel.IResourceBuilder<T>",
              "modifier": "this"
            },
            {
              "name": "port",
              "type": "int",
              "isOptional": true,
              "defaultValue": "2345"
            }
          ],
          "genericParameters": [
            {
              "name": "T",
              "constraints": [
                "Aspire.Hosting.Go.GoAppResource"
              ]
            }
          ],
          "attributes": [
            {
              "name": "Aspire.Hosting.AspireExportAttribute"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Starts a headless Delve debug server so that any DAP-compatible client can attach remotely. The application is launched as "
              },
              {
                "kind": "code",
                "text": "dlv --headless=true --listen=127.0.0.1:<port> --api-version=2 debug ."
              },
              {
                "kind": "text",
                "text": " instead of "
              },
              {
                "kind": "code",
                "text": "go run ."
              },
              {
                "kind": "text",
                "text": ". Delve must be available on the PATH. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " Delve is the only Go debugger; both GoLand and VS Code use it under the hood, just in different modes: "
                  }
                ]
              },
              {
                "kind": "list",
                "style": "bullet",
                "items": [
                  {
                    "term": [
                      {
                        "kind": "text",
                        "text": "GoLand"
                      }
                    ],
                    "description": [
                      {
                        "kind": "text",
                        "text": "Create a "
                      },
                      {
                        "kind": "text",
                        "text": "Go Remote"
                      },
                      {
                        "kind": "text",
                        "text": " run configuration pointing at "
                      },
                      {
                        "kind": "code",
                        "text": "localhost:<port>"
                      },
                      {
                        "kind": "text",
                        "text": " and start it after the resource has started."
                      }
                    ]
                  },
                  {
                    "term": [
                      {
                        "kind": "text",
                        "text": "VS Code (attach mode)"
                      }
                    ],
                    "description": [
                      {
                        "kind": "text",
                        "text": "Add a "
                      },
                      {
                        "kind": "code",
                        "text": "\"request\": \"attach\""
                      },
                      {
                        "kind": "text",
                        "text": " entry to "
                      },
                      {
                        "kind": "code",
                        "text": "launch.json"
                      },
                      {
                        "kind": "text",
                        "text": " with "
                      },
                      {
                        "kind": "code",
                        "text": "\"mode\": \"remote\""
                      },
                      {
                        "kind": "text",
                        "text": ", "
                      },
                      {
                        "kind": "code",
                        "text": "\"host\": \"localhost\""
                      },
                      {
                        "kind": "text",
                        "text": ", and "
                      },
                      {
                        "kind": "code",
                        "text": "\"port\": <port>"
                      },
                      {
                        "kind": "text",
                        "text": ", then start it after the resource has started."
                      }
                    ]
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " VS Code users who do not need GoLand compatibility can rely on the automatic VS Code debugging support that "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.GoHostingExtensions.AddGoApp(Aspire.Hosting.IDistributedApplicationBuilder,System.String,System.String,System.String,System.String[],System.String,System.String,System.Boolean)"
                  },
                  {
                    "kind": "text",
                    "text": " enables by default — no change to the application command is required in that case. "
                  }
                ]
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " for chaining."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The resource builder for the Go application."
                }
              ],
              "port": [
                {
                  "kind": "text",
                  "text": "The TCP port Delve listens on. Defaults to "
                },
                {
                  "kind": "code",
                  "text": "2345"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ]
            },
            "typeParameters": {
              "T": [
                {
                  "kind": "text",
                  "text": "The type of the Go application resource."
                }
              ]
            },
            "examples": [
              {
                "code": "\n            builder.AddGoApp(\"api\", \"../go-api\")\n                   .WithDelveServer(port: 2345);\n            ",
                "language": "csharp"
              }
            ]
          },
          "sourceFile": "src/Aspire.Hosting.Go/GoHostingExtensions.cs",
          "sourceLines": "644-662"
        },
        {
          "name": "WithGoPrivate",
          "kind": "method",
          "accessibility": "public",
          "signature": "public static IResourceBuilder<T> GoHostingExtensions.WithGoPrivate<T>(this IResourceBuilder<T> builder, string[] privatePatterns, string authHost, string usernameArgName = \"GIT_USER\", string tokenSecretId = \"gittoken\")",
          "returnType": "Aspire.Hosting.ApplicationModel.IResourceBuilder<T>",
          "isStatic": true,
          "isExtension": true,
          "parameters": [
            {
              "name": "builder",
              "type": "Aspire.Hosting.ApplicationModel.IResourceBuilder<T>",
              "modifier": "this"
            },
            {
              "name": "privatePatterns",
              "type": "string[]"
            },
            {
              "name": "authHost",
              "type": "string"
            },
            {
              "name": "usernameArgName",
              "type": "string",
              "isOptional": true,
              "defaultValue": "GIT_USER"
            },
            {
              "name": "tokenSecretId",
              "type": "string",
              "isOptional": true,
              "defaultValue": "gittoken"
            }
          ],
          "genericParameters": [
            {
              "name": "T",
              "constraints": [
                "Aspire.Hosting.Go.GoAppResource"
              ]
            }
          ],
          "attributes": [
            {
              "name": "Aspire.Hosting.AspireExportAttribute"
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Configures private Go module authentication for publish-time Dockerfile generation. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " Only affects the generated Dockerfile — has no effect in run mode, where the local Go toolchain picks up credentials from the developer's own "
                  },
                  {
                    "kind": "code",
                    "text": "~/.netrc"
                  },
                  {
                    "kind": "text",
                    "text": " or git credential helper. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " The generated build stage writes a temporary "
                  },
                  {
                    "kind": "code",
                    "text": ".netrc"
                  },
                  {
                    "kind": "text",
                    "text": " file from the username build-arg and the token secret, runs "
                  },
                  {
                    "kind": "code",
                    "text": "go mod download"
                  },
                  {
                    "kind": "text",
                    "text": ", then removes the file — all in a single layer so credentials never persist in the image. "
                  }
                ]
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": " for chaining."
              }
            ],
            "parameters": {
              "authHost": [
                {
                  "kind": "text",
                  "text": "The Git host that requires authentication, e.g. "
                },
                {
                  "kind": "code",
                  "text": "\"github.com\""
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "builder": [
                {
                  "kind": "text",
                  "text": "The resource builder for the Go application."
                }
              ],
              "privatePatterns": [
                {
                  "kind": "text",
                  "text": " One or more module path patterns that should bypass the public proxy and checksum database, e.g. "
                },
                {
                  "kind": "code",
                  "text": "\"*.mycompany.com\""
                },
                {
                  "kind": "text",
                  "text": " or "
                },
                {
                  "kind": "code",
                  "text": "\"github.com/myorg\""
                },
                {
                  "kind": "text",
                  "text": ". Passed verbatim to "
                },
                {
                  "kind": "code",
                  "text": "GOPRIVATE"
                },
                {
                  "kind": "text",
                  "text": ", which implicitly covers "
                },
                {
                  "kind": "code",
                  "text": "GONOSUMCHECK"
                },
                {
                  "kind": "text",
                  "text": " and "
                },
                {
                  "kind": "code",
                  "text": "GONOPROXY"
                },
                {
                  "kind": "text",
                  "text": ". "
                }
              ],
              "tokenSecretId": [
                {
                  "kind": "text",
                  "text": " The BuildKit secret ID for the Git access token. Defaults to "
                },
                {
                  "kind": "code",
                  "text": "\"gittoken\""
                },
                {
                  "kind": "text",
                  "text": ". Pass it at build time with "
                },
                {
                  "kind": "code",
                  "text": "--secret id=gittoken,src=/path/to/token"
                },
                {
                  "kind": "text",
                  "text": ". "
                }
              ],
              "usernameArgName": [
                {
                  "kind": "text",

              "isNullable": true,
              "isOptional": true
            }
          ],
          "docs": {
            "summary": [
              {
                "kind": "text",
                "text": " Adds a MySQL database to the application model. "
              }
            ],
            "remarks": [
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " When adding a "
                  },
                  {
                    "kind": "cref",
                    "value": "T:Aspire.Hosting.ApplicationModel.MySqlDatabaseResource"
                  },
                  {
                    "kind": "text",
                    "text": " to your application model the resource can then be referenced by other resources using the resource name. When the dependent resource is using the extension method "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.ResourceBuilderExtensions.WaitFor``1(Aspire.Hosting.ApplicationModel.IResourceBuilder{``0},Aspire.Hosting.ApplicationModel.IResourceBuilder{Aspire.Hosting.ApplicationModel.IResource})"
                  },
                  {
                    "kind": "text",
                    "text": " then the dependent resource will wait until the MySQL database is available. "
                  }
                ]
              },
              {
                "kind": "para",
                "children": [
                  {
                    "kind": "text",
                    "text": " Note that calling "
                  },
                  {
                    "kind": "cref",
                    "value": "M:Aspire.Hosting.MySqlBuilderExtensions.AddDatabase(Aspire.Hosting.ApplicationModel.IResourceBuilder{Aspire.Hosting.ApplicationModel.MySqlServerResource},System.String,System.String)"
                  },
                  {
                    "kind": "text",
                    "text": " will result in the database being created on the MySQL server when the server becomes ready. The database creation happens automatically as part of the resource lifecycle. "
                  }
                ]
              }
            ],
            "returns": [
              {
                "kind": "text",
                "text": "A reference to the "
              },
              {
                "kind": "cref",
                "value": "T:Aspire.Hosting.ApplicationModel.IResourceBuilder`1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "parameters": {
              "builder": [
                {
                  "kind": "text",
                  "text": "The MySQL server resource builder."
                }
              ],
              "databaseName": [
                {
                  "kind": "text",
                  "text": "The name of the database. If not provided, this defaults to the same value as "
                },
                {
                  "kind": "paramref",
                  "value": "name"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": [
                {
                  "kind": "text",
                  "text": "The name of the resource. This name will be used as the connection string name when referenced in a dependency."
                }
              ]
            }
          },
          "sourceFile": "src/Aspire.Hosting.MySql/MySqlBuilderExtensions.cs",
          "sourceLines": "113-140"

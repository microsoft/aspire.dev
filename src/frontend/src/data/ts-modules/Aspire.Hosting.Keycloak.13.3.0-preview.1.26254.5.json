      "name": "addKeycloak",
      "capabilityId": "Aspire.Hosting.Keycloak/addKeycloak",
      "qualifiedName": "addKeycloak",
      "description": "Adds a Keycloak container to the application model.",
      "remarks": "The container exposes port 8080 by default.\nThis version of the package defaults to the tag of the / container image.\nUse in application host\n```\nvar keycloak = builder.AddKeycloak(\"keycloak\");\nvar myService = builder.AddProject<Projects.MyService<()\n.WithReference(keycloak);\n```",
      "returns": "A reference to the `IResourceBuilder`1`.",
      "kind": "Method",
      "signature": "addKeycloak(name: string, port?: number, adminUsername?: ParameterResource, adminPassword?: ParameterResource): KeycloakResource",
      "parameters": [
        {
          "name": "name",
          "type": "string",
          "description": "The name of the resource."
        },
        {
          "name": "port",
          "type": "number",
          "isOptional": true,
          "isNullable": true,
          "description": "The host port that the underlying container is bound to when running locally."
        },
        {
          "name": "adminUsername",
          "type": "ParameterResource",
          "isOptional": true,
          "description": "The parameter used as the admin for the Keycloak resource. If `null` a default value will be used."
        },
        {
          "name": "adminPassword",
          "type": "ParameterResource",
          "isOptional": true,
          "description": "The parameter used as the admin password for the Keycloak resource. If `null` a default password will be used."
        }
      ],
      "returnType": "KeycloakResource",
      "returnsBuilder": true,
      "targetTypeId": "Aspire.Hosting/Aspire.Hosting.IDistributedApplicationBuilder",

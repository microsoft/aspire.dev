      "kind": "Method",
      "signature": "withRoleAssignments(target: AzureSearchResource, roles: AzureSearchRole[]): IResource",
      "parameters": [
        {
          "name": "target",
          "type": "AzureSearchResource",
          "description": "The target Azure AI Search service resource."
        },
        {
          "name": "roles",
          "type": "AzureSearchRole[]",
          "description": "The Azure AI Search roles to be assigned."

          "type": "callback",
          "isOptional": true,
          "isCallback": true,
          "callbackSignature": "(obj: AzureStorageExplorerResource) => Promise<void>",
          "description": "Configuration callback for Azure Storage Explorer container resource."
        },
        {
          "name": "name",
          "type": "string",
          "isOptional": true,
          "description": "The name of the resource."
        }
      ],

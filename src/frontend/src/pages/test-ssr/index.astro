---
export const prerender = false;

const now = new Date().toISOString();
const headers = Object.fromEntries(Astro.request.headers);
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>SSR Test - aspire.dev</title>
  <style>
    body { font-family: system-ui; max-width: 720px; margin: 2rem auto; padding: 0 1rem; color-scheme: light dark; }
    code { background: rgba(128,128,128,.15); padding: .1em .3em; border-radius: 3px; }
    pre { background: rgba(128,128,128,.1); padding: 1rem; border-radius: 6px; overflow-x: auto; }
    .badge { display: inline-block; background: #22c55e; color: #fff; padding: .2em .6em; border-radius: 4px; font-weight: 600; }
  </style>
</head>
<body>
  <h1>🚀 Astro SSR Test Page</h1>
  <p><span class="badge">Server-rendered</span> This page is rendered on-demand by the Astro SSR adapter — not prerendered at build time.</p>
  <h2>Server time</h2>
  <p>Rendered at: <code>{now}</code></p>
  <p>Refresh to see the timestamp change (proves it's SSR, not static).</p>
  <h2>Request headers</h2>
  <pre>{JSON.stringify(headers, null, 2)}</pre>
</body>
</html>

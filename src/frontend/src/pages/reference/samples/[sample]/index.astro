---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getImage } from 'astro:assets';

import Breadcrumb from '@components/Breadcrumb.astro';
import SampleDetail from '@components/SampleDetail.astro';
import samplesJson from '@data/samples.json';
import {
  isResolvedThemeAwareSampleImage,
  isThemeAwareSampleImage,
  sampleDescriptionText,
  sampleSlug,
  stripSampleImageUrlSuffix,
  type ResolvedSampleThumbnail,
  type Sample,
  type SampleThumbnail,
} from '@utils/samples';

export function getStaticPaths() {
  return (samplesJson as Sample[]).map((sample) => ({
    params: { sample: sampleSlug(sample.name) },
    props: { sample },
  }));
}

const { sample } = Astro.props as { sample: Sample };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const samplesHref = `${base}/reference/samples/`;
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/samples/**/*.{png,jpg,jpeg,gif,svg,webp}',
  { eager: true }
);

function resolveImagePath(imagePath: string | null): ImageMetadata | null {
  if (!imagePath) return null;
  const importPath = stripSampleImageUrlSuffix(imagePath).replace('~/assets/', '/src/assets/');
  const entry = allImages[importPath];
  return entry?.default ?? null;
}

function resolveThumbnail(thumbnail: SampleThumbnail): ResolvedSampleThumbnail {
  if (isThemeAwareSampleImage(thumbnail)) {
    const light = resolveImagePath(thumbnail.light);
    const dark = resolveImagePath(thumbnail.dark);

    if (light && dark) {
      return { light, dark };
    }

    return light ?? dark ?? null;
  }

  return resolveImagePath(thumbnail);
}

const resolvedThumbnail = resolveThumbnail(sample.thumbnail);
const resolvedOgThumbnail = isResolvedThemeAwareSampleImage(resolvedThumbnail)
  ? resolvedThumbnail.light
  : resolvedThumbnail;
const sampleOgImage = resolvedOgThumbnail
  ? (await getImage({ src: resolvedOgThumbnail, width: 1200 })).src
  : undefined;
const description =
  sampleDescriptionText(sample.description)
    ?.split('\n')
    .find((line) => line.trim().length > 0)
    ?.trim() ?? `Explore the ${sample.title} Aspire sample.`;
---

<StarlightPage
  frontmatter={{
    title: sample.title,
    description,
    ...(sampleOgImage ? { ogImage: sampleOgImage } : {}),
    topic: 'reference',
    category: 'sample',
    prev: false,
    next: false,
    tableOfContents: false,
    lastUpdated: false,
    editUrl: false,
    giscus: false,
    pageActions: true,
  }}
>
  <Breadcrumb
    crumbs={[
      { label: 'Docs', href: `${base}/docs/`, icon: 'docs' },
      { label: 'Reference', href: `${base}/reference/overview/` },
      { label: 'Samples', href: samplesHref },
      { label: sample.title },
    ]}
  />

  <SampleDetail sample={sample} samplesHref={samplesHref} />
</StarlightPage>

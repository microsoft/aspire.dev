---
import SampleCard from '@components/SampleCard.astro';
import { tagLabel } from '@utils/sample-tags';
import {
  isThemeAwareSampleImage,
  sampleDetailHref,
  stripSampleImageUrlSuffix,
  type ResolvedSampleThumbnail,
  type Sample,
  type SampleThumbnail,
} from '@utils/samples';

interface Props {
  samples: Sample[];
}

const { samples } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Eagerly import all sample images at build time
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/samples/**/*.{png,jpg,jpeg,gif,svg,webp}',
  { eager: true }
);

// Build a lookup from the ~/assets/... path to the resolved image
function resolveImagePath(imagePath: string | null): ImageMetadata | null {
  if (!imagePath) return null;
  // Convert ~/assets/samples/... to /src/assets/samples/...
  const importPath = stripSampleImageUrlSuffix(imagePath).replace('~/assets/', '/src/assets/');
  const entry = allImages[importPath];
  return entry?.default ?? null;
}

function resolveThumbnail(thumbnail: SampleThumbnail): ResolvedSampleThumbnail {
  if (isThemeAwareSampleImage(thumbnail)) {
    const light = resolveImagePath(thumbnail.light);
    const dark = resolveImagePath(thumbnail.dark);

    if (light && dark) {
      return { light, dark };
    }

    return light ?? dark ?? null;
  }

  return resolveImagePath(thumbnail);
}

const resolvedSamples = samples.map((s) => ({
  ...s,
  detailHref: sampleDetailHref(base, s.name),
  resolvedThumbnail: resolveThumbnail(s.thumbnail),
}));

// Collect all unique tags, sorted alphabetically
const allTags = [...new Set(samples.flatMap((s) => s.tags))].sort();
const tagCounts = new Map(
  allTags.map((tag) => [tag, samples.filter((s) => s.tags.includes(tag)).length])
);
---

<div class="samples-browser not-content" data-samples-browser>
  <!-- Search bar with embedded clear icon -->
  <div class="search-container">
    <svg
      class="search-icon"
      aria-hidden="true"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <label class="sr-only" for="samples-search-input">Search samples</label>
    <input
      autocomplete="off"
      spellcheck="false"
      type="search"
      id="samples-search-input"
      class="search-box"
      placeholder="Search samples..."
      data-search-input
    />
    <button type="button" class="search-clear" aria-label="Clear search" data-clear-btn hidden>
      <svg
        aria-hidden="true"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Filter chips: transparent by default so the wall feels lighter; active
       chips fill with the accent color so they read as the only "loud" item
       in the row. On mobile the row collapses to a two-row max-height with a
       "Show all" expander to avoid the overwhelming 28-tag wall. -->
  <div class="tag-filters" data-tag-filters data-collapsed="true">
    {
      allTags.map((tag) => (
        <button
          class="tag-chip"
          data-tag={tag}
          data-tag-label={tagLabel(tag)}
          type="button"
          aria-pressed="false"
        >
          <span class="tag-label">{tagLabel(tag)}</span>
          <span
            class="tag-count"
            aria-label={`${tagCounts.get(tag)} ${tagCounts.get(tag) === 1 ? 'sample' : 'samples'}`}
          >
            {tagCounts.get(tag)}
          </span>
        </button>
      ))
    }
  </div>
  <button class="tag-toggle" type="button" data-tag-toggle hidden>
    <span data-tag-toggle-label>Show all {allTags.length} tags</span>
    <svg
      class="tag-toggle-caret"
      aria-hidden="true"
      width="12"
      height="12"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  <!-- Results header: count + subtle clear-all text link (only when filters
       are active). The active state of the chips themselves is the source of
       truth for "what's filtered" — no separate "Filtered by" bar. -->
  <div class="results-bar">
    <span class="results-count" data-results-count>
      {samples.length}
      {samples.length === 1 ? 'sample' : 'samples'}
    </span>
    <button class="clear-all" type="button" data-clear-all hidden>Clear all</button>
  </div>

  <!-- Card grid -->
  <div class="card-grid" data-card-grid>
    {
      resolvedSamples.map((sample) => (
        <div class="card-item" data-sample-item>
          <SampleCard sample={sample} />
        </div>
      ))
    }
  </div>

  <!-- Empty state -->
  <div class="empty-state" data-empty-state style="display: none;">
    <svg
      width="48"
      height="48"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      <line x1="8" y1="11" x2="14" y2="11"></line>
    </svg>
    <p>No samples match your filters.</p>
    <p class="empty-state-detail">Try removing a filter or adjusting your search.</p>
    <button class="reset-btn" data-reset-btn type="button">Reset all filters</button>
  </div>
</div>

<!-- is:inline is required so the filter/search logic runs synchronously in the
     page rather than being bundled and deferred by Astro's script processing.
     This ensures the grid is interactive immediately on page load. -->
<script is:inline>
  (function () {
    const browser = document.querySelector('[data-samples-browser]');
    if (!browser) return;

    const searchInput = browser.querySelector('[data-search-input]');
    const clearBtn = browser.querySelector('[data-clear-btn]');
    const tagChips = browser.querySelectorAll('[data-tag]');
    const tagFilters = browser.querySelector('[data-tag-filters]');
    const tagToggle = browser.querySelector('[data-tag-toggle]');
    const tagToggleLabel = browser.querySelector('[data-tag-toggle-label]');
    const cardGrid = browser.querySelector('[data-card-grid]');
    const cardItems = browser.querySelectorAll('[data-sample-item]');
    const resultsCount = browser.querySelector('[data-results-count]');
    const clearAllBtn = browser.querySelector('[data-clear-all]');
    const emptyState = browser.querySelector('[data-empty-state]');
    const resetBtn = browser.querySelector('[data-reset-btn]');

    let activeTags = new Set();
    let searchQuery = '';
    const validTagSlugs = new Set([...tagChips].map((chip) => chip.dataset.tag).filter(Boolean));
    const SEARCH_PARAM = 'q';
    const TAGS_PARAM = 'tags';
    const TAG_COLLAPSE_THRESHOLD = 8;

    // Hydrate `searchQuery` and `activeTags` from the current URL so a shared
    // link like `?q=redis&tags=databases,redis` lands on a pre-filtered view.
    // Unknown tag slugs are silently dropped; whitespace-only `q` is ignored.
    function readFiltersFromUrl() {
      let params;
      try {
        params = new URLSearchParams(window.location.search);
      } catch (_err) {
        return;
      }

      const initialQuery = (params.get(SEARCH_PARAM) || '').trim();
      if (initialQuery) {
        searchQuery = initialQuery;
        searchInput.value = initialQuery;
      }

      const rawTags = params.get(TAGS_PARAM) || '';
      rawTags
        .split(',')
        .map((tag) => tag.trim())
        .filter((tag) => tag && validTagSlugs.has(tag))
        .forEach((tag) => activeTags.add(tag));

      tagChips.forEach((chip) => {
        const isActive = activeTags.has(chip.dataset.tag);
        chip.classList.toggle('active', isActive);
        chip.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });
    }

    // Mirror current filter state into `location.search` via
    // `history.replaceState` (not `pushState`) so the back/forward stack
    // is unaffected and the URL stays shareable.
    function syncUrl() {
      let nextSearch = '';
      try {
        const params = new URLSearchParams();
        const query = searchQuery.trim();
        if (query) params.set(SEARCH_PARAM, query);
        if (activeTags.size > 0) {
          params.set(TAGS_PARAM, [...activeTags].sort().join(','));
        }
        const serialized = params.toString();
        nextSearch = serialized ? `?${serialized}` : '';
      } catch (_err) {
        return;
      }

      if (window.location.search === nextSearch) return;
      const nextUrl = `${window.location.pathname}${nextSearch}${window.location.hash}`;
      try {
        window.history.replaceState(window.history.state, '', nextUrl);
      } catch (_err) {
        /* ignore — e.g. sandboxed iframes block history APIs */
      }
    }

    function applyFilters() {
      let visible = 0;
      const query = searchQuery.toLowerCase().trim();

      cardItems.forEach((item) => {
        const card = item.querySelector('.sample-card');
        if (!card) return;

        const title = card.dataset.title || '';
        const name = card.dataset.name || '';
        const desc = card.dataset.description || '';
        const tags = (card.dataset.tags || '').split(',').filter(Boolean);

        // Text search
        let matchesSearch = true;
        if (query) {
          matchesSearch =
            title.includes(query) ||
            name.includes(query) ||
            desc.includes(query) ||
            tags.some((t) => t.includes(query));
        }

        // Tag filter (AND logic)
        let matchesTags = true;
        if (activeTags.size > 0) {
          matchesTags = [...activeTags].every((tag) => tags.includes(tag));
        }

        if (matchesSearch && matchesTags) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });

      const total = cardItems.length;
      const hasFilters = query || activeTags.size > 0;
      resultsCount.textContent = hasFilters
        ? `${visible} of ${total} ${total === 1 ? 'sample' : 'samples'}`
        : `${visible} ${visible === 1 ? 'sample' : 'samples'}`;

      cardGrid.style.display = visible === 0 ? 'none' : '';
      emptyState.style.display = visible === 0 ? '' : 'none';
      clearBtn.hidden = !query;
      clearAllBtn.hidden = !hasFilters;

      syncUrl();
    }

    // Search
    searchInput.addEventListener('input', (e) => {
      searchQuery = e.target.value;
      applyFilters();
    });

    clearBtn.addEventListener('click', () => {
      searchInput.value = '';
      searchQuery = '';
      applyFilters();
      searchInput.focus();
    });

    // Tag chips
    tagChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const tag = chip.dataset.tag;
        if (activeTags.has(tag)) {
          activeTags.delete(tag);
          chip.classList.remove('active');
          chip.setAttribute('aria-pressed', 'false');
        } else {
          activeTags.add(tag);
          chip.classList.add('active');
          chip.setAttribute('aria-pressed', 'true');
        }
        applyFilters();
      });
    });

    // Clear all
    function resetAll() {
      searchInput.value = '';
      searchQuery = '';
      activeTags.clear();
      tagChips.forEach((chip) => {
        chip.classList.remove('active');
        chip.setAttribute('aria-pressed', 'false');
      });
      applyFilters();
    }

    if (clearAllBtn) clearAllBtn.addEventListener('click', resetAll);
    if (resetBtn) resetBtn.addEventListener('click', resetAll);

    // Mobile "Show all N tags" expander — only meaningful when there are
    // enough tags that the wall would feel overwhelming. The toggle button
    // is hidden on viewports wide enough to show every chip without
    // overflow (see the @media rule in <style>); we still show/hide it via
    // the `hidden` attribute so the count doesn't render when unnecessary.
    if (tagToggle && tagFilters && tagChips.length > TAG_COLLAPSE_THRESHOLD) {
      tagToggle.hidden = false;

      // If a hidden chip is active on hydrate, expand the row by default so
      // the user sees what's filtering their view.
      const visibleHiddenActive = [...tagChips]
        .slice(TAG_COLLAPSE_THRESHOLD)
        .some((chip) => chip.classList.contains('active'));
      if (visibleHiddenActive) {
        tagFilters.setAttribute('data-collapsed', 'false');
        if (tagToggleLabel) tagToggleLabel.textContent = 'Show fewer tags';
      }

      tagToggle.addEventListener('click', () => {
        const collapsed = tagFilters.getAttribute('data-collapsed') === 'true';
        tagFilters.setAttribute('data-collapsed', collapsed ? 'false' : 'true');
        if (tagToggleLabel) {
          tagToggleLabel.textContent = collapsed
            ? 'Show fewer tags'
            : `Show all ${tagChips.length} tags`;
        }
        tagToggle.setAttribute('aria-expanded', collapsed ? 'true' : 'false');
      });
    }

    // Initialize
    readFiltersFromUrl();
    applyFilters();
  })();
</script>

<style>
  .samples-browser {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ---- Visually-hidden label (mirrors Starlight pattern) ---- */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---- Search ---- */
  .search-container {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .search-icon {
    position: absolute;
    left: 0.75rem;
    color: var(--sl-color-gray-3);
    pointer-events: none;
  }

  .search-box {
    width: 100%;
    padding: 0.625rem 2.5rem 0.625rem 2.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    font-size: 0.95rem;
    outline: none;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .search-box::placeholder {
    color: var(--sl-color-gray-3);
  }

  .search-box:focus {
    border-color: var(--sl-color-text-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--sl-color-text-accent) 18%, transparent);
  }

  /* Hide the UA-provided "x" inside `type="search"` — we render our own. */
  .search-box::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
  }

  .search-clear {
    position: absolute;
    right: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }

  .search-clear:hover,
  .search-clear:focus-visible {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-white);
    outline: none;
  }

  /* ---- Tag chips: quiet by default, accent-filled when active ---- */
  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    transition: max-height 0.25s ease;
  }

  .tag-chip {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    padding: 0.25rem 0.65rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 2rem;
    background: transparent;
    color: var(--sl-color-gray-2);
    font-size: 0.78rem;
    cursor: pointer;
    transition:
      border-color 0.15s ease,
      background 0.15s ease,
      color 0.15s ease;
    white-space: nowrap;
    user-select: none;
  }

  .tag-chip:hover {
    border-color: var(--sl-color-gray-3);
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
  }

  .tag-chip:focus-visible {
    outline: 2px solid var(--sl-color-text-accent);
    outline-offset: 2px;
  }

  .tag-count {
    color: var(--sl-color-gray-3);
    font-size: 0.72rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .tag-chip.active {
    border-color: var(--sl-color-text-accent);
    background: color-mix(in srgb, var(--sl-color-text-accent) 14%, transparent);
    color: var(--sl-color-white);
    font-weight: 600;
  }

  .tag-chip.active .tag-count {
    color: color-mix(in srgb, var(--sl-color-white) 75%, transparent);
  }

  /* ---- Mobile-only "Show all N tags" expander ---- */
  .tag-toggle {
    display: none;
    align-items: center;
    gap: 0.3rem;
    align-self: flex-start;
    margin-top: 0.1rem;
    padding: 0.2rem 0.1rem;
    border: none;
    background: transparent;
    color: var(--sl-color-text-accent);
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
  }

  .tag-toggle:hover {
    color: var(--sl-color-white);
  }

  .tag-toggle-caret {
    transition: transform 0.2s ease;
  }

  .tag-filters[data-collapsed='false'] ~ .tag-toggle .tag-toggle-caret {
    transform: rotate(180deg);
  }

  @media (max-width: 768px) {
    .tag-toggle:not([hidden]) {
      display: inline-flex;
    }

    /* Cap the chip wall to ~2 rows on narrow viewports. The mask gives a
       subtle fade so the cut-off feels intentional rather than clipped. */
    .tag-filters[data-collapsed='true'] {
      max-height: 4.5rem;
      overflow: hidden;
      mask-image: linear-gradient(to bottom, #000 60%, transparent);
      -webkit-mask-image: linear-gradient(to bottom, #000 60%, transparent);
    }
  }

  /* ---- Results header ---- */
  .results-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 0.25rem;
    border-top: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
  }

  .results-count {
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    font-weight: 500;
  }

  .clear-all {
    border: none;
    background: none;
    padding: 0;
    color: var(--sl-color-text-accent);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: underline;
    white-space: nowrap;
  }

  .clear-all:hover,
  .clear-all:focus-visible {
    color: var(--sl-color-white);
    outline: none;
  }

  /* ---- Card grid (CSS columns for masonry) ---- */
  .card-grid {
    column-count: 1;
    column-gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .card-grid {
      column-count: 2;
    }
  }

  .card-item {
    break-inside: avoid;
    margin-bottom: 1.25rem;
  }

  /* ---- Empty state ---- */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 3rem 1rem;
    border: 1px dashed var(--sl-color-gray-4);
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--sl-color-gray-6) 88%, var(--sl-color-accent));
    color: var(--sl-color-gray-3);
    text-align: center;
  }

  .empty-state p {
    margin: 0;
    font-size: 1.1rem;
  }

  .empty-state-detail {
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
  }

  .reset-btn {
    background: var(--sl-color-accent-high);
    border: 1px solid var(--sl-color-accent-high);
    border-radius: 0.5rem;
    color: var(--sl-color-black);
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition:
      filter 0.2s,
      transform 0.2s;
  }

  .reset-btn:hover {
    filter: brightness(1.05);
    transform: translateY(-1px);
  }

  /* ---- Even tighter chips on very narrow screens ---- */
  @media (max-width: 480px) {
    .tag-chip {
      font-size: 0.72rem;
      padding: 0.2rem 0.55rem;
    }
    .tag-count {
      font-size: 0.68rem;
    }
  }
</style>

---
import { Aside, Steps } from '@astrojs/starlight/components';
import { Code } from 'astro-expressive-code/components';
import type { Element as HastElement } from 'hast';
import { toHtml } from 'hast-util-to-html';
import type {
  Blockquote,
  Code as CodeNode,
  Heading,
  Link,
  List,
  PhrasingContent,
  RootContent,
} from 'mdast';
import { toHast, type State } from 'mdast-util-to-hast';

import {
  headingPlainText,
  normalizeHeadingNodes,
  slugifyHeading,
  toSentenceCase,
} from '@utils/sample-readme-headings';
import { isStandaloneSampleImageBlock } from '@utils/sample-readme-images';

interface Props {
  blocks: RootContent[];
  sampleHref: string;
  headingCounts?: Map<string, number>;
  /**
   * Set to true when the component is recursing into a list item, blockquote,
   * or other nested block container. While nested, ordered lists render as
   * plain `<ol>` instead of being wrapped in `<Steps>` — Starlight's `<Steps>`
   * is intended for top-level numbered procedures, not for sub-steps inside a
   * step. Wrapping nested ordered lists in `<Steps>` produces double indents,
   * double numbering chrome, and breaks the visual rhythm of the parent.
   */
  nested?: boolean;
}

const {
  blocks,
  sampleHref,
  headingCounts = new Map<string, number>(),
  nested = false,
} = Astro.props;

function escapeAttribute(value: string): string {
  return value
    .replace(/&/g, '&amp;')
    .replace(/"/g, '&quot;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function escapeHtml(value: string): string {
  return escapeAttribute(value).replace(/'/g, '&#39;');
}

function resolveReadmeHref(href: string): string {
  if (/^(?:https?:|mailto:|tel:|#|\/)/i.test(href)) {
    return href;
  }

  const relativeHref = href.replace(/^\.\//, '');
  return `${sampleHref}/${relativeHref}`;
}

/**
 * Custom `mdast-util-to-hast` handler for links. Mirrors the previous marked
 * `renderer.link`: links with no destination are dropped entirely (rather than
 * being rewritten to a broken sample-relative URL), README links are resolved
 * against the sample's source path (so `./relative` paths point at the right
 * file on GitHub) and external links open in a new tab with a safe `rel`.
 */
function linkHandler(state: State, node: Link): HastElement | undefined {
  if (!node.url || node.url.trim() === '') {
    return undefined;
  }

  const resolvedHref = resolveReadmeHref(node.url);
  const isExternal = /^(?:https?:)?\/\//i.test(resolvedHref);
  const properties: Record<string, string> = { href: resolvedHref };

  if (node.title) {
    properties.title = node.title;
  }

  if (isExternal) {
    properties.target = '_blank';
    properties.rel = 'noopener noreferrer';
  }

  const result: HastElement = {
    type: 'element',
    tagName: 'a',
    properties,
    children: state.all(node) as HastElement['children'],
  };

  state.patch(node, result);
  return state.applyData(node, result) as HastElement;
}

const toHastOptions = {
  allowDangerousHtml: true,
  handlers: { link: linkHandler },
} as const;

/** Serialize a single block-level MDAST node to an HTML string. */
function renderNodeHtml(node: RootContent): string {
  const hast = toHast(node, toHastOptions);
  return hast ? toHtml(hast, { allowDangerousHtml: true }) : '';
}

/**
 * Serialize inline (phrasing) MDAST nodes to an HTML string without wrapping
 * them in a `<p>`. Used for heading inner content, where the surrounding
 * `<h*>`/anchor markup is emitted separately.
 */
function renderInlineHtml(nodes: readonly PhrasingContent[]): string {
  return nodes
    .map((node) => {
      const hast = toHast(node, toHastOptions);
      return hast ? toHtml(hast, { allowDangerousHtml: true }) : '';
    })
    .join('');
}

function headingHtml(node: Heading): string {
  const rawText = headingPlainText(node.children);
  const normalizedText = toSentenceCase(rawText);
  const innerHtml = renderInlineHtml(normalizeHeadingNodes(node.children));
  const baseSlug = slugifyHeading(rawText);
  const seen = headingCounts.get(baseSlug) ?? 0;
  headingCounts.set(baseSlug, seen + 1);
  const slug = seen === 0 ? baseSlug : `${baseSlug}-${seen}`;
  const depth = node.depth;

  return `<div class="sl-heading-wrapper level-h${depth}"><h${depth} id="${slug}">${innerHtml}</h${depth}><a class="sl-anchor-link" href="#${slug}"><span aria-hidden="true" class="sl-anchor-icon"><svg width="16" height="16" viewBox="0 0 24 24"><path fill="currentcolor" d="m12.11 15.39-3.88 3.88a2.52 2.52 0 0 1-3.5 0 2.47 2.47 0 0 1 0-3.5l3.88-3.88a1 1 0 0 0-1.42-1.42l-3.88 3.89a4.48 4.48 0 0 0 6.33 6.33l3.89-3.88a1 1 0 1 0-1.42-1.42Zm8.58-12.08a4.49 4.49 0 0 0-6.33 0l-3.89 3.88a1 1 0 0 0 1.42 1.42l3.88-3.88a2.52 2.52 0 0 1 3.5 0a2.47 2.47 0 0 1 0 3.5l-3.88 3.88a1 1 0 1 0 1.42 1.42l3.88-3.89a4.48 4.48 0 0 0 0-6.33Zm-6.36 5a1 1 0 0 0-1.41 0l-4.6 4.6a1 1 0 0 0 1.41 1.41l4.6-4.6a1 1 0 0 0 0-1.4Z"/></svg></span><span class="sr-only">Section titled ${escapeHtml(normalizedText)}</span></a></div>`;
}

function getCodeProps(node: CodeNode): { code: string; lang: string; meta: string } {
  const rawLang = (node.lang ?? 'text').trim() || 'text';
  const lang = rawLang.toLowerCase() === 'shell' ? 'bash' : rawLang;

  return {
    code: node.value,
    lang,
    meta: node.meta ?? '',
  };
}

/**
 * GitHub-flavoured alert syntax inside a blockquote. The first paragraph of
 * the quote opens with one of `[!NOTE]`, `[!TIP]`, `[!IMPORTANT]`, `[!WARNING]`,
 * or `[!CAUTION]` on its own line — see
 * https://docs.github.com/en/get-started/writing-on-github/working-with-advanced-formatting/organizing-information-with-collapsed-sections#alerts.
 * We strip that marker and render the remaining quoted content as a Starlight
 * `<Aside>` so it picks up the site's themed callout styling instead of
 * leaking through as a generic blockquote.
 */
type GitHubAlertKind = 'NOTE' | 'TIP' | 'IMPORTANT' | 'WARNING' | 'CAUTION';

type AsideVariant = 'note' | 'tip' | 'caution' | 'danger';

const GITHUB_ALERT_PATTERN = /^\s*\[!(NOTE|TIP|IMPORTANT|WARNING|CAUTION)\]\s*\r?\n?/i;

const GITHUB_ALERT_TO_ASIDE: Record<GitHubAlertKind, { type: AsideVariant; title?: string }> = {
  NOTE: { type: 'note' },
  TIP: { type: 'tip' },
  IMPORTANT: { type: 'note', title: 'Important' },
  WARNING: { type: 'caution' },
  CAUTION: { type: 'danger', title: 'Caution' },
};

type GitHubAlert = {
  type: AsideVariant;
  title?: string;
  nodes: RootContent[];
};

function matchGitHubAlert(block: Blockquote): GitHubAlert | null {
  const children = block.children;
  const firstBlock = children[0];

  if (!firstBlock || firstBlock.type !== 'paragraph') return null;

  const firstInline = firstBlock.children[0];
  if (!firstInline || firstInline.type !== 'text') return null;

  const match = GITHUB_ALERT_PATTERN.exec(firstInline.value);
  if (!match) return null;

  const kind = match[1].toUpperCase() as GitHubAlertKind;
  const mapping = GITHUB_ALERT_TO_ASIDE[kind];
  if (!mapping) return null;

  // Strip the `[!KIND]` marker from the opening text node. The remaining
  // phrasing children (links, code spans, emphasis) are already-parsed MDAST
  // nodes and carry over unchanged.
  const strippedValue = firstInline.value.replace(GITHUB_ALERT_PATTERN, '').replace(/^\s+/, '');
  const restInline = firstBlock.children.slice(1);
  const newParagraphChildren: PhrasingContent[] =
    strippedValue.length > 0
      ? [{ ...firstInline, value: strippedValue }, ...restInline]
      : restInline;

  const restBlocks = children.slice(1);
  const nodes: RootContent[] =
    newParagraphChildren.length > 0
      ? [{ ...firstBlock, children: newParagraphChildren }, ...restBlocks]
      : restBlocks;

  return {
    type: mapping.type,
    title: mapping.title,
    nodes,
  };
}
---

{
  blocks.map((block) => {
    if (block.type === 'code') {
      const code = getCodeProps(block);
      if (code.lang.toLowerCase() === 'mermaid') {
        return <pre class="mermaid">{code.code}</pre>;
      }

      return <Code code={code.code} lang={code.lang} meta={code.meta} />;
    }

    if (isStandaloneSampleImageBlock(block)) {
      return null;
    }

    if (block.type === 'heading') {
      return <Fragment set:html={headingHtml(block)} />;
    }

    if (block.type === 'list') {
      const list = block as List;
      if (list.ordered) {
        const orderedList = (
          <ol start={list.start || undefined}>
            {list.children.map((item) => (
              <li>
                <Astro.self
                  blocks={item.children}
                  sampleHref={sampleHref}
                  headingCounts={headingCounts}
                  nested={true}
                />
              </li>
            ))}
          </ol>
        );

        return nested ? orderedList : <Steps>{orderedList}</Steps>;
      }

      return (
        <ul>
          {list.children.map((item) => (
            <li>
              <Astro.self
                blocks={item.children}
                sampleHref={sampleHref}
                headingCounts={headingCounts}
                nested={true}
              />
            </li>
          ))}
        </ul>
      );
    }

    if (block.type === 'blockquote') {
      const alert = matchGitHubAlert(block);
      if (alert) {
        return (
          <Aside type={alert.type} title={alert.title}>
            <Astro.self
              blocks={alert.nodes}
              sampleHref={sampleHref}
              headingCounts={headingCounts}
              nested={nested}
            />
          </Aside>
        );
      }

      return (
        <blockquote>
          <Astro.self
            blocks={block.children}
            sampleHref={sampleHref}
            headingCounts={headingCounts}
            nested={nested}
          />
        </blockquote>
      );
    }

    return <Fragment set:html={renderNodeHtml(block)} />;
  })
}

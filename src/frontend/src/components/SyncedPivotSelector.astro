---
import PivotSelector from '@components/PivotSelector.astro';

interface Option {
  id: string;
  title: string;
  disabled?: boolean;
}

interface Props {
  key: string;
  syncKey: string;
  options: Option[];
  title?: string;
  marginTop?: number | null;
}

const { key, syncKey, options, title, marginTop } = Astro.props;
const optionLabels = Object.fromEntries(options.map(({ id, title }) => [id, title]));
---

<PivotSelector key={key} title={title} options={options} marginTop={marginTop} />

<script is:inline define:vars={{ key, syncKey, optionLabels }}>
  function initSyncedPivotSelector() {
    const selector = document.getElementById(`pivot-selector-${key}`);
    if (!selector || selector.dataset.syncedTabsBound === 'true') {
      return;
    }

    selector.dataset.syncedTabsBound = 'true';

    const storageKey = `starlight-synced-tabs__${syncKey}`;

    const getIdForLabel = (label) => Object.entries(optionLabels)
      .find(([, value]) => value === label)?.[0];

    const setPivotState = (id) => {
      if (!id) {
        return;
      }

      localStorage.setItem(key, id);

      const url = new URL(window.location);
      url.searchParams.set(key, id);
      window.history.replaceState({}, '', url);

      [...selector.querySelectorAll('button')].forEach((button) =>
        button.classList.toggle('active', button.dataset.pivotOption === id)
      );
    };

    const syncTabs = (id) => {
      const label = optionLabels[id];
      if (!label) {
        return;
      }

      localStorage.setItem(storageKey, label);

      const tab = [...document.querySelectorAll('main [role="tab"]')]
        .find((button) => button.textContent?.trim() === label);

      if (tab && tab.getAttribute('aria-selected') !== 'true') {
        tab.click();
      }
    };

    const bindTabs = () => {
      [...document.querySelectorAll('main [role="tab"]')].forEach((button) => {
        const label = button.textContent?.trim();
        const id = getIdForLabel(label);

        if (!id || button.dataset.syncedPivotBound === 'true') {
          return;
        }

        button.dataset.syncedPivotBound = 'true';
        button.addEventListener('click', () => {
          requestAnimationFrame(() => setPivotState(id));
        });
      });
    };

    const applyCurrentSelection = () => {
      const active = selector.querySelector('button.active');
      const id = active?.dataset.pivotOption;
      if (id) {
        syncTabs(id);
      }
    };

    selector.addEventListener('click', (event) => {
      const button = event.target.closest('button[data-pivot-option]');
      if (button?.dataset.pivotOption) {
        requestAnimationFrame(() => syncTabs(button.dataset.pivotOption));
      }
    });

    bindTabs();
    requestAnimationFrame(applyCurrentSelection);
  }

  document.addEventListener('astro:page-load', initSyncedPivotSelector);
  initSyncedPivotSelector();
</script>

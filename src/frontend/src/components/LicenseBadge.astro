---
interface Props {
  title: string;
}

const { title } = Astro.props;
const href = title.match(/:\s+(https?:\/\/.+)$/)?.[1];
---

{href ? (
  <a
    class="thanks-license-badge"
    href={href}
    title={title}
    data-tooltip-placement="top"
    aria-label={`License: ${title}`}
    target="_blank"
    rel="noreferrer"
  >
    <svg class="thanks-license-icon" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M4.5 13.5h7M8.01 1v12.06M1.5 3.5h3l1.5-1h4l1.5 1h3M.5 10L3 4.48L5.5 10C4 11 2 11 .5 10m10 0L13 4.48L15.5 10c-1.5 1-3.5 1-5 0" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
) : (
  <span
    class="thanks-license-badge"
    title={title}
    data-tooltip-placement="top"
    aria-label={`License: ${title}`}
  >
    <svg class="thanks-license-icon" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M4.5 13.5h7M8.01 1v12.06M1.5 3.5h3l1.5-1h4l1.5 1h3M.5 10L3 4.48L5.5 10C4 11 2 11 .5 10m10 0L13 4.48L15.5 10c-1.5 1-3.5 1-5 0" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
)}

<style>
  .thanks-license-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--sl-color-text) 18%, transparent);
    background: color-mix(in srgb, var(--sl-color-bg) 92%, transparent);
    color: var(--sl-color-text);
    opacity: 0.76;
    cursor: help;
    text-decoration: none;
    transition: opacity 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .thanks-license-badge:hover,
  .thanks-license-badge:focus-visible {
    opacity: 1;
    border-color: color-mix(in srgb, var(--sl-color-text) 34%, transparent);
    background: color-mix(in srgb, var(--sl-color-bg) 96%, transparent);
    outline: none;
  }

  .thanks-license-badge :global(.thanks-license-icon) {
    display: block;
    width: 16px;
    height: 16px;
    color: var(--sl-color-text);
  }
  
  @media (prefers-reduced-motion: reduce) {
    .thanks-license-badge {
      transition: none;
    }
  }
</style>

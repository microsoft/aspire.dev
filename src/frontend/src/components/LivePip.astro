---
import { Icon } from '@astrojs/starlight/components';

/**
 * Site-global native Document Picture-in-Picture controller.
 *
 * The header live icon remains a normal link when we're offline. When we're
 * live and the browser supports Document PiP, clicking the icon opens a
 * resizable native PiP window with the active embed instead of navigating.
 * Closing the native PiP window never redirects.
 */
---

<div id="aspire-live-source-menu" class="live-source-menu not-content" role="menu" aria-label="Choose live stream" hidden>
  <div class="live-source-menu__header">
    <p class="live-source-menu__label">Watch live on</p>
  </div>
  <div class="live-source-menu__body">
    <button type="button" class="live-source-menu__item" role="menuitem" data-live-source-choice="youtube">
      <Icon name="youtube" />
      <span class="live-source-menu__name">YouTube</span>
    </button>
    <button type="button" class="live-source-menu__item" role="menuitem" data-live-source-choice="twitch">
      <Icon name="twitch" />
      <span class="live-source-menu__name">Twitch</span>
    </button>
  </div>
</div>

<script>
  import { getCurrent, subscribe, type LiveSnapshot } from '@components/live-status.ts';

  type DocumentPictureInPictureApi = {
    requestWindow(options?: { width?: number; height?: number }): Promise<Window>;
    window?: Window | null;
  };

  type LivePipState = {
    pipWindow: Window | null;
    activeEmbedKey: string;
    open: boolean;
    selectedSource: LiveSource | null;
  };

  type LiveSource = 'twitch' | 'youtube';

  declare global {
    interface Window {
      documentPictureInPicture?: DocumentPictureInPictureApi;
      __aspireLivePipState?: LivePipState;
    }
    interface DocumentEventMap {
      'aspire:live-pip-change': CustomEvent<{ open: boolean }>;
    }
  }

  const DEFAULT_TWITCH_CHANNEL = 'aspiredotdev';
  const DEFAULT_YOUTUBE_CHANNEL_ID = 'UC8Hyt2P1u3KKnBgRf-Iv6_Q';
  const SOURCE_PICKER_ID = 'aspire-live-source-menu';
  const VIDEOS_PATH = '/community/videos/';

  let current = getCurrent();

  function getState(): LivePipState {
    return (window.__aspireLivePipState ??= {
      pipWindow: null,
      activeEmbedKey: '',
      open: false,
      selectedSource: null,
    });
  }

  function getPipWindow(): Window | null {
    const state = getState();
    const nativeWindow = window.documentPictureInPicture?.window;
    if (nativeWindow && !nativeWindow.closed && state.pipWindow !== nativeWindow) {
      state.pipWindow = nativeWindow;
    }
    if (state.pipWindow?.closed) {
      state.pipWindow = null;
      state.activeEmbedKey = '';
      state.open = false;
      state.selectedSource = null;
    }
    return state.pipWindow;
  }

  function publishPipState(open: boolean): void {
    const state = getState();
    if (state.open === open) return;
    state.open = open;
    document.dispatchEvent(new CustomEvent('aspire:live-pip-change', { detail: { open } }));
  }

  function clearPipState(): void {
    const state = getState();
    state.pipWindow = null;
    state.activeEmbedKey = '';
    state.selectedSource = null;
    publishPipState(false);
  }

  function isModifiedClick(evt: MouseEvent): boolean {
    return evt.defaultPrevented || evt.button !== 0 || evt.altKey || evt.ctrlKey || evt.metaKey || evt.shiftKey;
  }

  function parentHost(): string {
    return window.location.hostname || 'localhost';
  }

  function nativePipAvailable(): boolean {
    return typeof window.documentPictureInPicture?.requestWindow === 'function';
  }

  function getLiveSources(snapshot: LiveSnapshot): LiveSource[] {
    const sources: LiveSource[] = [];
    if (snapshot.youtube.live) sources.push('youtube');
    if (snapshot.twitch.live) sources.push('twitch');
    return sources;
  }

  function sourceIsLive(snapshot: LiveSnapshot, source: LiveSource | null): source is LiveSource {
    return source === 'youtube' ? snapshot.youtube.live : source === 'twitch' ? snapshot.twitch.live : false;
  }

  function chooseSource(snapshot: LiveSnapshot, requestedSource = getState().selectedSource): LiveSource | null {
    if (sourceIsLive(snapshot, requestedSource)) {
      return requestedSource;
    }

    const liveSources = getLiveSources(snapshot);
    if (liveSources.length === 1) {
      return liveSources[0];
    }

    if (sourceIsLive(snapshot, snapshot.primarySource)) {
      return snapshot.primarySource;
    }

    return liveSources[0] ?? null;
  }

  function buildEmbed(
    doc: Document,
    snapshot: LiveSnapshot,
    source: LiveSource | null,
  ): { key: string; iframe: HTMLIFrameElement | null; source: LiveSource | null } {
    if (source === 'twitch' && snapshot.twitch.live) {
      const channel = snapshot.twitch.channel ?? DEFAULT_TWITCH_CHANNEL;
      const iframe = doc.createElement('iframe');
      iframe.src = `https://player.twitch.tv/?channel=${encodeURIComponent(channel)}&parent=${encodeURIComponent(parentHost())}&autoplay=true&muted=true`;
      iframe.allow = 'autoplay; fullscreen';
      iframe.setAttribute('aria-label', `Twitch live stream from ${channel}`);
      return { key: `twitch:${channel}`, iframe, source };
    }

    if (source === 'youtube' && snapshot.youtube.live) {
      const id = snapshot.youtube.videoId;
      const iframe = doc.createElement('iframe');
      iframe.src = id
        ? `https://www.youtube-nocookie.com/embed/${encodeURIComponent(id)}?autoplay=1&mute=1`
        : `https://www.youtube-nocookie.com/embed/live_stream?channel=${encodeURIComponent(DEFAULT_YOUTUBE_CHANNEL_ID)}&autoplay=1&mute=1`;
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
      iframe.setAttribute('aria-label', 'YouTube live stream');
      return { key: id ? `youtube:${id}` : `youtube-channel:${DEFAULT_YOUTUBE_CHANNEL_ID}`, iframe, source };
    }

    return { key: '', iframe: null, source: null };
  }

  function renderPip(snapshot: LiveSnapshot): void {
    const pipWindow = getPipWindow();
    if (!pipWindow) {
      publishPipState(false);
      return;
    }

    if (!snapshot.isLive) {
      pipWindow.close();
      clearPipState();
      return;
    }

    const doc = pipWindow.document;
    const { key, iframe, source } = buildEmbed(doc, snapshot, chooseSource(snapshot));
    if (!iframe || !key) return;
    const state = getState();
    if (state.activeEmbedKey === key) {
      state.selectedSource = source;
      publishPipState(true);
      return;
    }

    doc.title = 'Aspire live stream';
    doc.head.replaceChildren();

    const style = doc.createElement('style');
    style.textContent = `
      html, body {
        margin: 0;
        width: 100%;
        height: 100%;
        background: #000;
        overflow: hidden;
      }
      iframe {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
      }
    `;
    doc.head.append(style);
    doc.body.replaceChildren(iframe);
    state.activeEmbedKey = key;
    state.selectedSource = source;
    publishPipState(true);
  }

  async function openNativePip(source?: LiveSource): Promise<boolean> {
    if (!current.isLive || !nativePipAvailable()) return false;

    const selectedSource = chooseSource(current, source ?? null);
    if (!selectedSource) return false;
    const state = getState();
    state.selectedSource = selectedSource;

    const existingPipWindow = getPipWindow();
    if (existingPipWindow) {
      existingPipWindow.focus();
      renderPip(current);
      publishPipState(true);
      return true;
    }

    const pipWindow = await window.documentPictureInPicture!.requestWindow({
      width: 480,
      height: 270,
    });
    state.pipWindow = pipWindow;
    state.activeEmbedKey = '';
    pipWindow.addEventListener(
      'pagehide',
      () => {
        clearPipState();
      },
      { once: true },
    );
    renderPip(current);
    return true;
  }

  function getSourcePicker(): HTMLElement | null {
    return document.getElementById(SOURCE_PICKER_ID);
  }

  function closeSourcePicker(): void {
    const picker = getSourcePicker();
    if (picker) {
      picker.hidden = true;
    }
    document.querySelectorAll<HTMLElement>('.live-btn').forEach((btn) => {
      btn.setAttribute('aria-expanded', 'false');
    });
  }

  function syncSourcePickerControls(): void {
    const picker = getSourcePicker();
    if (!picker) return;
    picker.querySelectorAll<HTMLButtonElement>('[data-live-source-choice]').forEach((button) => {
      const source = button.dataset.liveSourceChoice as LiveSource | undefined;
      const live = sourceIsLive(current, source ?? null);
      button.hidden = !live;
      button.disabled = !live;
    });
    if (getLiveSources(current).length < 2) {
      closeSourcePicker();
    }
  }

  function positionSourcePicker(anchor: HTMLElement, picker: HTMLElement): void {
    const rect = anchor.getBoundingClientRect();
    const margin = 8;
    const width = picker.offsetWidth || 180;
    const left = Math.min(Math.max(margin, rect.left + rect.width / 2 - width / 2), window.innerWidth - width - margin);
    picker.style.top = `${rect.bottom + margin}px`;
    picker.style.left = `${left}px`;
  }

  function openSourcePicker(anchor: HTMLElement): void {
    const picker = getSourcePicker();
    if (!picker) return;
    syncSourcePickerControls();
    picker.hidden = false;
    positionSourcePicker(anchor, picker);
    document.querySelectorAll<HTMLElement>('.live-btn').forEach((btn) => {
      btn.setAttribute('aria-expanded', String(btn === anchor));
    });
    picker.querySelector<HTMLButtonElement>('[data-live-source-choice]:not([hidden]):not(:disabled)')?.focus();
  }

  function bindSourcePicker(): void {
    const picker = getSourcePicker();
    if (!picker || picker.dataset.bound === 'true') return;
    picker.dataset.bound = 'true';
    picker.querySelectorAll<HTMLButtonElement>('[data-live-source-choice]').forEach((button) => {
      button.addEventListener('click', () => {
        const source = button.dataset.liveSourceChoice as LiveSource | undefined;
        if (!source) return;
        closeSourcePicker();
        void openNativePip(source).catch((err) => {
          console.warn('[live-status] native Picture-in-Picture failed, navigating to videos page', err);
          window.location.assign(VIDEOS_PATH);
        });
      });
    });
    document.addEventListener('click', (evt) => {
      const target = evt.target;
      if (!(target instanceof Node)) return;
      if (picker.contains(target) || (target instanceof Element && target.closest('.live-btn'))) return;
      closeSourcePicker();
    });
    document.addEventListener('keydown', (evt) => {
      if (evt.key === 'Escape') {
        closeSourcePicker();
      }
    });
  }

  function syncHeaderMenuState(): void {
    const hasChoices = current.isLive && nativePipAvailable() && getLiveSources(current).length > 1;
    document.querySelectorAll<HTMLElement>('.live-btn').forEach((btn) => {
      if (hasChoices) {
        btn.setAttribute('aria-haspopup', 'menu');
        btn.setAttribute('aria-controls', SOURCE_PICKER_ID);
        btn.setAttribute('aria-expanded', String(!getSourcePicker()?.hidden && btn.getAttribute('aria-expanded') === 'true'));
      } else {
        btn.removeAttribute('aria-haspopup');
        btn.removeAttribute('aria-controls');
        btn.removeAttribute('aria-expanded');
      }
    });
    syncSourcePickerControls();
  }

  function bindHeaderButtons(): void {
    document.querySelectorAll<HTMLAnchorElement>('.live-btn').forEach((btn) => {
      if (btn.dataset.nativePipBound === 'true') return;
      btn.dataset.nativePipBound = 'true';
      btn.addEventListener('click', (evt) => {
        if (isModifiedClick(evt) || !current.isLive || !nativePipAvailable()) {
          return;
        }

        evt.preventDefault();
        const liveSources = getLiveSources(current);
        if (liveSources.length > 1) {
          openSourcePicker(btn);
          return;
        }

        void openNativePip(liveSources[0]).catch((err) => {
          console.warn('[live-status] native Picture-in-Picture failed, navigating to videos page', err);
          window.location.assign(btn.href);
        });
      });
    });
  }

  function init(): void {
    bindSourcePicker();
    bindHeaderButtons();
    syncHeaderMenuState();
    publishPipState(Boolean(getPipWindow()));
  }

  subscribe((snapshot) => {
    current = snapshot;
    syncHeaderMenuState();
    renderPip(snapshot);
  });

  if (typeof window !== 'undefined') {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
    document.addEventListener('astro:after-swap', init);
  }
</script>

<style>
  .live-source-menu {
    position: fixed;
    z-index: 1000;
    min-width: 13rem;
    padding: 0;
    color: var(--sl-color-text);
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: var(--sl-shadow-lg);
    overflow: hidden;
  }

  .live-source-menu[hidden] {
    display: none;
  }

  .live-source-menu__header {
    padding: 0.85rem 1rem;
    background: var(--sl-color-bg);
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .live-source-menu__label {
    margin: 0;
    color: var(--sl-color-text);
    font-size: var(--sl-text-sm);
    font-weight: 600;
  }

  .live-source-menu__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem;
  }

  .live-source-menu__item {
    display: flex;
    width: 100%;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.75rem;
    color: inherit;
    text-align: start;
    background: transparent;
    border: 0;
    border-radius: 0.5rem;
    cursor: pointer;
  }

  .live-source-menu__item:hover,
  .live-source-menu__item:focus-visible {
    background: var(--sl-color-gray-5);
    outline: none;
  }

  .live-source-menu__name {
    font-weight: 700;
  }

  .live-source-menu__item :global(svg) {
    flex: 0 0 auto;
    width: 1.15rem;
    height: 1.15rem;
  }
</style>

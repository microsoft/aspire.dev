---
/**
 * ApiSearchBar — unified search bar with kind filters, version dropdown,
 * stats line, no-results state, and search results container.
 *
 * Composes InpageSearch and VersionFilter into a single coordinated UI.
 * On tablet/desktop the version dropdown sits to the right of the search input.
 * On mobile they stack. The "Clear filters" button resets both kind and version filters.
 *
 * Usage:
 * ```astro
 * <ApiSearchBar
 *   id="api"
 *   placeholder="Search types, methods…"
 *   kinds={allKinds}
 *   versions={allVersions}
 *   defaultStatsText="151 packages"
 *   size="lg"
 * />
 * ```
 */
import VersionFilter from './VersionFilter.astro';

interface Props {
  /** Unique prefix for element IDs (e.g. "api" or "ts-api") */
  id: string;
  /** Placeholder text for the search input */
  placeholder: string;
  /** Unique kind strings to render as filter chips */
  kinds: string[];
  /** Version strings for the version dropdown (empty array to hide) */
  versions?: string[];
  /** Text shown beneath the search bar before any query */
  defaultStatsText: string;
  /** Size variant: "lg" (index page) or "sm" (package page) */
  size?: 'lg' | 'sm';
}

const { id, placeholder, kinds, versions = [], defaultStatsText, size = 'lg' } = Astro.props;
const hasVersions = versions.length > 0;
const searchInputId = id + '-search-input';
const searchStatusId = id + '-search-status';
const searchClearId = id + '-search-clear';
const kindFiltersId = id + '-kind-filters';
const searchCountId = id + '-search-count';
const clearFiltersId = id + '-clear-filters';
const searchResultsId = id + '-search-results';
const getKindClassName = (kind: string) => 'api-filter-dot kind-' + kind.replace(/\s+/g, '-');
---

<div class="api-search-bar-unified inpage-search" data-size={size}>
  <!-- Top row: search input + version dropdown -->
  <div class="asb-top-row">
    <div class="asb-input-wrap">
      <svg class="asb-search-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <label class="sr-only" for={searchInputId}>{placeholder}</label>
      <input
        type="search"
        id={searchInputId}
        class="asb-search-input"
        placeholder={placeholder}
        autocomplete="off"
        aria-describedby={searchStatusId}
      />
      <button
        type="button"
        class="asb-search-clear"
        id={searchClearId}
        aria-label="Clear search"
        style="display: none;"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    {hasVersions && (
      <div class="asb-version-slot">
        <VersionFilter id={id} versions={versions} />
      </div>
    )}
  </div>

  <!-- Kind filter chips -->
  <div class="inpage-kind-filters" id={kindFiltersId}>
    {kinds.map(kind => (
      <button
        class="api-filter-chip"
        data-kind={kind}
        type="button"
        aria-pressed="false"
      >
        <span class={getKindClassName(kind)}></span>
        {kind}
      </button>
    ))}
  </div>

  <div id={searchStatusId} class="sr-only" aria-live="polite"></div>

  <!-- Stats line + clear filters -->
  <div class="inpage-search-stats">
    <span id={searchCountId}>{defaultStatsText}</span>
    <button class="inpage-clear-filters" id={clearFiltersId} type="button" style="display: none;">Clear filters</button>
  </div>

  <!-- Search results (populated by the page's controller script) -->
  <div id={searchResultsId} class="api-list" style="display: none;"></div>
</div>

<style>
  /* ── Accessibility ──────────────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Top row: search + version ─────────────────────────────── */
  .asb-top-row {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
    margin-bottom: 0.25rem;
  }

  .asb-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 0;
  }

  .asb-search-icon {
    position: absolute;
    left: 0.75rem;
    width: 1.25rem;
    height: 1.25rem;
    color: var(--sl-color-gray-1);
    pointer-events: none;
    z-index: 1;
  }

  .asb-search-input {
    width: 100%;
    padding: 0.5rem 2.5rem 0.5rem 2.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.625rem;
    background: var(--sl-color-bg-nav);
    color: var(--sl-color-text);
    font-size: var(--sl-text-sm);
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
    box-sizing: border-box;
  }

  .asb-search-input::placeholder {
    color: var(--sl-color-gray-1);
  }

  .asb-search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
  }

  .asb-search-input:focus {
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 1px var(--sl-color-accent);
  }

  [data-size="sm"] .asb-search-input {
    padding: 0.4375rem 2.25rem 0.4375rem 2.25rem;
    font-size: var(--sl-text-sm);
    border-radius: 0.5rem;
  }

  [data-size="sm"] .asb-search-icon {
    width: 1rem;
    height: 1rem;
    left: 0.625rem;
  }

  .asb-search-clear {
    position: absolute;
    right: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border: none;
    background: none;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    border-radius: 50%;
    padding: 0;
  }

  .asb-search-clear svg {
    width: 1rem;
    height: 1rem;
  }

  .asb-search-clear:hover {
    color: var(--sl-color-text);
    background: var(--sl-color-gray-6);
  }

  /* Version slot aligns with the search bar */
  .asb-version-slot {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  /* ── Mobile: stack search + version ──────────────────────────── */
  @media (max-width: 50rem) {
    .asb-top-row {
      flex-direction: column;
    }

    .asb-version-slot {
      width: 100%;
    }
  }
</style>

<!-- Global styles for kind filters, stats, clear button, and dynamic results -->
<style is:global>
  /* ── Kind filter chips ──────────────────────────────────────── */
  .api-search-bar-unified .inpage-kind-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }

  .api-search-bar-unified .api-filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 2rem;
    background: transparent;
    color: var(--sl-color-gray-2);
    font-size: 0.78rem;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
    text-transform: capitalize;
    user-select: none;
  }

  .api-search-bar-unified .api-filter-chip:hover {
    border-color: var(--sl-color-gray-3);
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
  }

  .api-search-bar-unified .api-filter-chip.active {
    border-color: currentColor;
    background: color-mix(in srgb, currentColor 12%, transparent);
    font-weight: 600;
  }

  .api-search-bar-unified .api-filter-chip.active[data-kind='class']         { color: var(--api-kind-class); }
  .api-search-bar-unified .api-filter-chip.active[data-kind='interface']     { color: var(--api-kind-interface); }
  .api-search-bar-unified .api-filter-chip.active[data-kind='enum']          { color: var(--api-kind-enum); }
  .api-search-bar-unified .api-filter-chip.active[data-kind='struct']        { color: var(--api-kind-struct); }
  .api-search-bar-unified .api-filter-chip.active[data-kind='record']        { color: var(--api-kind-record); }
  .api-search-bar-unified .api-filter-chip.active[data-kind='delegate']      { color: var(--api-kind-delegate); }
  .api-search-bar-unified .api-filter-chip.active[data-kind='record struct'] { color: var(--api-kind-record-struct); }
  .api-search-bar-unified .api-filter-chip.active[data-kind='function']      { color: #3b82f6; }
  .api-search-bar-unified .api-filter-chip.active[data-kind='method']        { color: #3b82f6; }
  .api-search-bar-unified .api-filter-chip.active[data-kind='property']      { color: #10b981; }
  .api-search-bar-unified .api-filter-chip.active[data-kind='constructor']   { color: #8b5cf6; }
  .api-search-bar-unified .api-filter-chip.active[data-kind='field']         { color: #f59e0b; }
  .api-search-bar-unified .api-filter-chip.active[data-kind='event']         { color: #ef4444; }
  .api-search-bar-unified .api-filter-chip.active[data-kind='indexer']       { color: #06b6d4; }
  .api-search-bar-unified .api-filter-chip.active[data-kind='enum member']   { color: #d97706; }
  .api-search-bar-unified .api-filter-chip.active[data-kind='handle']        { color: var(--api-kind-class); }
  .api-search-bar-unified .api-filter-chip.active[data-kind='type']          { color: var(--api-kind-struct); }

  .api-search-bar-unified .api-filter-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--api-kind-class, var(--sl-color-accent));
  }

  .api-search-bar-unified .api-filter-dot.kind-interface    { background: var(--api-kind-interface); }
  .api-search-bar-unified .api-filter-dot.kind-enum         { background: var(--api-kind-enum); }
  .api-search-bar-unified .api-filter-dot.kind-struct       { background: var(--api-kind-struct); }
  .api-search-bar-unified .api-filter-dot.kind-record       { background: var(--api-kind-record); }
  .api-search-bar-unified .api-filter-dot.kind-delegate     { background: var(--api-kind-delegate); }
  .api-search-bar-unified .api-filter-dot.kind-record-struct { background: var(--api-kind-record-struct); }
  .api-search-bar-unified .api-filter-dot.kind-function     { background: #2563a8; }
  .api-search-bar-unified .api-filter-dot.kind-method       { background: #2563a8; }
  .api-search-bar-unified .api-filter-dot.kind-property     { background: #0a7d56; }
  .api-search-bar-unified .api-filter-dot.kind-constructor  { background: #6d3dc8; }
  .api-search-bar-unified .api-filter-dot.kind-field        { background: #9a6400; }
  .api-search-bar-unified .api-filter-dot.kind-event        { background: #c42b2b; }
  .api-search-bar-unified .api-filter-dot.kind-indexer      { background: #047e94; }
  .api-search-bar-unified .api-filter-dot.kind-enum-member  { background: #d97706; }
  .api-search-bar-unified .api-filter-dot.kind-handle       { background: var(--api-kind-class); }
  .api-search-bar-unified .api-filter-dot.kind-type         { background: var(--api-kind-struct); }

  /* ── Stats line ─────────────────────────────────────────────── */
  .api-search-bar-unified .inpage-search-stats {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.4rem 0 0.15rem;
    font-size: var(--api-text-sm, 0.875rem);
    color: var(--sl-color-gray-3);
  }

  .api-search-bar-unified .inpage-clear-filters {
    background: none;
    border: none;
    color: var(--sl-color-text-accent);
    font-size: 0.82rem;
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
    white-space: nowrap;
  }

  .api-search-bar-unified .inpage-clear-filters:hover {
    color: var(--sl-color-white);
  }

  /* ── Search result items (dynamically injected by controllers) ── */
  .api-search-bar-unified .api-result-name-wrap {
    display: flex;
    align-items: baseline;
    gap: 0;
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
  }

  .api-search-bar-unified .api-result-parent {
    color: var(--sl-color-gray-3);
    font-size: 0.85em;
    font-weight: 400;
    flex-shrink: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .api-search-bar-unified .api-result-dot {
    color: var(--sl-color-gray-4);
    font-size: 0.85em;
    flex-shrink: 0;
  }

  .api-search-bar-unified .api-search-result-name {
    font-weight: 600;
    font-size: var(--api-text-md, 1.05rem);
  }

  .api-search-bar-unified .api-kind-micro {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #fff;
    background: var(--api-kind-class, var(--sl-color-accent));
    flex-shrink: 0;
    line-height: 1.4;
    vertical-align: middle;
  }

  .api-search-bar-unified .api-kind-micro.kind-interface    { background: var(--api-kind-interface); }
  .api-search-bar-unified .api-kind-micro.kind-enum         { background: var(--api-kind-enum); }
  .api-search-bar-unified .api-kind-micro.kind-struct       { background: var(--api-kind-struct); }
  .api-search-bar-unified .api-kind-micro.kind-record       { background: var(--api-kind-record); }
  .api-search-bar-unified .api-kind-micro.kind-delegate     { background: var(--api-kind-delegate); }
  .api-search-bar-unified .api-kind-micro.kind-record-struct { background: var(--api-kind-record-struct); }
  .api-search-bar-unified .api-kind-micro.kind-function     { background: #2563a8; }
  .api-search-bar-unified .api-kind-micro.kind-method       { background: #2563a8; }
  .api-search-bar-unified .api-kind-micro.kind-property     { background: #0a7d56; }
  .api-search-bar-unified .api-kind-micro.kind-constructor  { background: #6d3dc8; }
  .api-search-bar-unified .api-kind-micro.kind-field        { background: #9a6400; }
  .api-search-bar-unified .api-kind-micro.kind-event        { background: #c42b2b; }
  .api-search-bar-unified .api-kind-micro.kind-indexer      { background: #047e94; }
  .api-search-bar-unified .api-kind-micro.kind-enum-member  { background: #d97706; }

  [data-theme='light'] .api-search-bar-unified .api-kind-micro {
    color: var(--api-kind-class);
    background: color-mix(in srgb, var(--api-kind-class) 10%, #f5f5f5);
    border: 1px solid color-mix(in srgb, var(--api-kind-class) 25%, transparent);
  }
  [data-theme='light'] .api-search-bar-unified .api-kind-micro.kind-interface {
    color: var(--api-kind-interface);
    background: color-mix(in srgb, var(--api-kind-interface) 10%, #f5f5f5);
    border-color: color-mix(in srgb, var(--api-kind-interface) 25%, transparent);
  }
  [data-theme='light'] .api-search-bar-unified .api-kind-micro.kind-enum {
    color: var(--api-kind-enum);
    background: color-mix(in srgb, var(--api-kind-enum) 10%, #f5f5f5);
    border-color: color-mix(in srgb, var(--api-kind-enum) 25%, transparent);
  }
  [data-theme='light'] .api-search-bar-unified .api-kind-micro.kind-struct {
    color: var(--api-kind-struct);
    background: color-mix(in srgb, var(--api-kind-struct) 10%, #f5f5f5);
    border-color: color-mix(in srgb, var(--api-kind-struct) 25%, transparent);
  }
  [data-theme='light'] .api-search-bar-unified .api-kind-micro.kind-function {
    color: #2563a8;
    background: color-mix(in srgb, #2563a8 10%, #f5f5f5);
    border: 1px solid color-mix(in srgb, #2563a8 25%, transparent);
  }
  [data-theme='light'] .api-search-bar-unified .api-kind-micro.kind-method {
    color: #2563a8;
    background: color-mix(in srgb, #2563a8 10%, #f5f5f5);
    border: 1px solid color-mix(in srgb, #2563a8 25%, transparent);
  }
  [data-theme='light'] .api-search-bar-unified .api-kind-micro.kind-property {
    color: #0a7d56;
    background: color-mix(in srgb, #0a7d56 10%, #f5f5f5);
    border: 1px solid color-mix(in srgb, #0a7d56 25%, transparent);
  }

  .api-search-bar-unified mark {
    background-color: transparent;
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--sl-color-text-accent);
    text-underline-offset: 2px;
    text-decoration-thickness: 2px;
  }

  .api-search-bar-unified .api-search-empty {
    padding: 2.5rem 1.5rem;
    text-align: center;
    background: var(--api-surface, var(--sl-color-gray-6));
    border-radius: var(--api-radius-lg, 0.75rem);
    color: var(--sl-color-gray-2);
  }

  .api-search-bar-unified .api-search-empty-hint {
    margin-top: 0.5rem;
    font-size: var(--api-text-sm, 0.875rem);
    color: var(--sl-color-gray-3);
  }

  .api-search-bar-unified .api-load-more {
    display: block;
    width: 100%;
    padding: 0.65rem 1rem;
    margin-top: 0.75rem;
    background: var(--sl-color-accent-low);
    border: 1px solid var(--sl-color-accent);
    border-radius: var(--api-radius-md, 0.5rem);
    color: var(--sl-color-accent-high);
    font-size: var(--api-text-sm, 0.875rem);
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    text-align: center;
  }

  .api-search-bar-unified .api-load-more:hover {
    background: var(--sl-color-accent);
    color: #fff;
    border-color: var(--sl-color-accent);
  }

  @media (max-width: 48rem) {
    .api-search-bar-unified .api-search-result .api-list-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
      gap: 0.35rem 0.5rem;
    }

    .api-search-bar-unified .api-search-result .api-result-name-wrap {
      display: flex;
      width: 100%;
      max-width: 100%;
      min-width: 0;
    }

    .api-search-bar-unified .api-search-result .trailing {
      grid-column: 1 / -1;
      width: 100%;
      min-width: 0;
      margin-left: 0;
    }
  }

  @media (max-width: 480px) {
    .api-search-bar-unified .api-filter-chip {
      font-size: 0.72rem;
      padding: 0.2rem 0.5rem;
    }
  }
</style>

---
import YourChoiceSvg from '@assets/icons/your-choices.svg';

const t = Astro.locals.t as unknown as (key: string) => string;
---

<nav class="footer-column" aria-labelledby="footer-legal-heading">
  <p id="footer-legal-heading" class="footer-heading">
    {t('footer.legal') || 'Legal'}
  </p>
  <ul class="footer-links">
    <li>
      <a
        href="https://aka.ms/yourcaliforniaprivacychoices"
        target="_blank"
        rel="noopener noreferrer"
        class="privacy-choice"
      >
        <YourChoiceSvg />
        {t('footer.privacyChoices')}
      </a>
    </li>
    <li>
      <a
        href="https://go.microsoft.com/fwlink/?LinkId=521839"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t('footer.privacyAndCookies')}
      </a>
    </li>
    <li>
      <a
        href="https://go.microsoft.com/fwlink/?LinkID=206977"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t('footer.terms')}
      </a>
    </li>
    <li>
      <a
        href="https://go.microsoft.com/fwlink/?linkid=2196228"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t('footer.trademarks')}
      </a>
    </li>
    <li>
      <a href="/support/" rel="noopener noreferrer">
        {t('footer.support')}
      </a>
    </li>
  </ul>
</nav>

<style>
  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-heading {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--sl-color-white);
    margin: 0 0 0.25rem 0;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    font-size: var(--sl-text-sm);
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: var(--sl-color-white);
  }

  .privacy-choice {
    gap: 0.5rem;
  }
</style>

---
import { Badge, Icon } from '@astrojs/starlight/components';
import { Image } from 'astro:assets';
import ThemeAwareImage from '@components/ThemeImage.astro';
import { tagLabel } from '@utils/sample-tags';
import {
  appHostIconName,
  appHostShortLabel,
  isResolvedThemeAwareSampleImage,
  sampleDescriptionText,
  type ResolvedSample,
} from '@utils/samples';

interface Props {
  sample: ResolvedSample;
}

const { sample } = Astro.props;

/**
 * Split a plain text description into a preview (first paragraph or intro before
 * a list) and the remaining content. Short descriptions are not split.
 */
function splitDescription(text: string): { preview: string; rest: string | null } {
  // Short descriptions don't need truncation — 200 chars fits comfortably in a card
  if (text.length <= 200) return { preview: text, rest: null };

  // Try splitting at the first markdown list item or paragraph break
  const listIdx = text.indexOf('\n- ');
  const paraIdx = text.indexOf('\n\n');

  let splitPoint = -1;
  // Require the split point to be at least 40 chars in to avoid tiny previews
  if (paraIdx > 40) splitPoint = paraIdx;
  if (listIdx > 40 && (splitPoint === -1 || listIdx < splitPoint)) splitPoint = listIdx;

  if (splitPoint > 0) {
    return {
      preview: text.substring(0, splitPoint).trim(),
      rest: text.substring(splitPoint).trim(),
    };
  }

  // Fallback: split after the first two sentences.
  // The regex is intentionally simple — it may match abbreviations like "e.g. "
  // but that's acceptable for a best-effort preview split.
  const sentenceEnd = /[.!?]\s/g;
  let count = 0;
  let match: RegExpExecArray | null;
  while ((match = sentenceEnd.exec(text)) !== null) {
    count++;
    // Require at least 80 chars so the preview isn't too short
    if (count >= 2 && match.index + 1 > 80) {
      return {
        preview: text.substring(0, match.index + 1).trim(),
        rest: text.substring(match.index + 1).trim() || null,
      };
    }
  }

  // No natural break — don't split
  return { preview: text, rest: null };
}

let previewText: string | null = null;
let restText: string | null = null;
const descriptionText = sampleDescriptionText(sample.description);

if (descriptionText) {
  // Cards without a thumbnail show full text (no truncation)
  if (!sample.resolvedThumbnail) {
    previewText = descriptionText;
    restText = null;
  } else {
    const { preview, rest } = splitDescription(descriptionText);
    previewText = preview;
    restText = rest;
  }
}

const visibleTags = sample.tags.slice(0, 5);
const remaining = Math.max(sample.tags.length - 5, 0);
const overflowTags = sample.tags.slice(5);

const appHostIcon = appHostIconName(sample.appHost);
---

<article
  class="sample-card"
  class:list={[sample.resolvedThumbnail && 'has-thumbnail']}
  data-sample-detail-href={sample.detailHref}
  data-tags={sample.tags.join(',')}
  data-title={sample.title.toLowerCase()}
  data-name={sample.name}
  data-description={(sample.description || '').toLowerCase()}
>
  {
    sample.resolvedThumbnail && (
      <div class="thumbnail">
        {isResolvedThemeAwareSampleImage(sample.resolvedThumbnail) ? (
          <ThemeAwareImage
            light={sample.resolvedThumbnail.light}
            dark={sample.resolvedThumbnail.dark}
            alt={`Screenshot of the ${sample.title} sample`}
            width={sample.resolvedThumbnail.light.width}
            height={sample.resolvedThumbnail.light.height}
            zoomable={false}
          />
        ) : (
          <Image
            src={sample.resolvedThumbnail}
            alt={`Screenshot of the ${sample.title} sample`}
            loading="lazy"
            widths={[400, 800]}
            sizes="(min-width: 768px) 50vw, 100vw"
          />
        )}
      </div>
    )
  }
  <div class="card-body">
    <h3 class="title">
      <a href={sample.detailHref}>
        {sample.title}
      </a>
    </h3>
    {
      previewText && (
        <div class="desc" data-desc>
          <p>{previewText}</p>
          {restText && (
            <div class="desc-rest" data-desc-rest hidden>
              <p>{restText}</p>
            </div>
          )}
          {restText && (
            <button class="read-more-btn" data-read-more type="button">
              Read more&hellip;
            </button>
          )}
        </div>
      )
    }
    {
      sample.tags.length > 0 && (
        <div class="badges">
          {visibleTags.map((tag) => (
            <span data-tag-key={tag}>
              <Badge text={tagLabel(tag)} size="small" />
            </span>
          ))}
          {remaining > 0 && (
            <Badge
              text={`+${remaining}`}
              size="small"
              variant="tip"
              title={overflowTags.map(tagLabel).join(', ')}
            />
          )}
        </div>
      )
    }
    <div class="footer">
      {
        sample.appHost && (
          <div class="apphost-pill" data-apphost={sample.appHost}>
            {appHostIcon ? (
              <Icon name={appHostIcon} size="0.85rem" />
            ) : (
              <svg
                class="apphost-glyph"
                aria-hidden="true"
                viewBox="0 0 16 16"
                width="12"
                height="12"
              >
                <path
                  d="M5.6 4.2 2.2 7.6c-.22.22-.22.58 0 .8L5.6 11.8c.22.22.58.22.8 0a.566.566 0 0 0 0-.8L3.42 8l3-3a.566.566 0 0 0 0-.8.566.566 0 0 0-.82 0Zm4.8 0a.566.566 0 0 0-.8.8l3 3-3 3a.566.566 0 0 0 0 .8c.22.22.58.22.8 0l3.4-3.4a.566.566 0 0 0 0-.8l-3.4-3.4Z"
                  fill="currentColor"
                />
              </svg>
            )}
            <span>{appHostShortLabel(sample.appHost)} AppHost</span>
          </div>
        )
      }
      <a href={sample.href} target="_blank" rel="noopener noreferrer" class="link">
        <Icon name="github" size="1rem" />
        View on GitHub
      </a>
    </div>
  </div>
</article>

<script>
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    // Read-more toggle with smooth animation
    const btn = target.closest('[data-read-more]') as HTMLButtonElement | null;
    if (btn) {
      const desc = btn.closest('[data-desc]');
      if (!desc) return;
      const rest = desc.querySelector('[data-desc-rest]') as HTMLElement | null;
      if (!rest) return;

      const isExpanded = !rest.hidden;
      rest.hidden = isExpanded;
      btn.textContent = isExpanded ? 'Read more\u2026' : 'Show less';
      return;
    }

    // Clickable tag badges — activate the matching filter chip in the grid.
    // Each badge is wrapped in a <span data-tag-key="..."> so we can match by
    // tag key rather than display text, avoiding locale/whitespace mismatches.
    const badgeWrap = target.closest('[data-tag-key]') as HTMLElement | null;
    if (badgeWrap) {
      const tagKey = badgeWrap.dataset.tagKey;
      if (!tagKey) return;
      const browser = document.querySelector('[data-samples-browser]');
      if (!browser) return;
      const chip = browser.querySelector(`[data-tag="${tagKey}"]`) as HTMLElement | null;
      if (chip) {
        chip.click();
        chip.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
      }
      return;
    }

    const card = target.closest('[data-sample-detail-href]') as HTMLElement | null;
    if (card && !target.closest('a, button')) {
      const href = card.dataset.sampleDetailHref;
      if (href) {
        window.location.href = href;
      }
    }
  });
</script>

<style>
  .sample-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--sl-color-gray-5);
    border-top: 3px solid transparent;
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: var(--sl-shadow-sm);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--sl-color-gray-6) 100%, transparent) 0%,
      color-mix(in srgb, var(--sl-color-gray-6) 85%, var(--sl-color-black)) 100%
    );
    transition:
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
    break-inside: avoid;
    cursor: pointer;
  }

  .sample-card:hover,
  .sample-card:focus-within {
    box-shadow: var(--sl-shadow-md);
    border-color: var(--sl-color-gray-4);
    border-top-color: var(--sl-color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .sample-card.has-thumbnail:hover,
    .sample-card.has-thumbnail:focus-within {
      transform: translateY(-2px);
    }

    .sample-card.has-thumbnail .thumbnail :global(img) {
      transition:
        transform 0.35s ease,
        filter 0.35s ease;
    }

    .sample-card.has-thumbnail:hover .thumbnail :global(img),
    .sample-card.has-thumbnail:focus-within .thumbnail :global(img) {
      transform: scale(1.025);
      filter: saturate(1.05) contrast(1.03);
    }
  }

  .thumbnail {
    width: 100%;
    overflow: hidden;
    background: var(--sl-color-gray-5);
    flex-shrink: 0;
    border-bottom: 1px solid var(--sl-color-gray-5);
    box-shadow: inset 0 -4px 8px -4px rgba(0, 0, 0, 0.15);
  }

  .thumbnail :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1rem;
  }

  .title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
    color: var(--sl-color-white);
  }

  .title a {
    text-decoration: none;
    color: inherit;
  }

  .title a:hover {
    text-decoration: underline;
    color: var(--sl-color-accent-high);
  }

  .apphost-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    border: 1px solid
      color-mix(in srgb, var(--apphost-color, var(--sl-color-accent)) 50%, transparent);
    background: color-mix(
      in srgb,
      var(--apphost-color, var(--sl-color-accent)) 14%,
      var(--sl-color-bg)
    );
    color: color-mix(
      in srgb,
      var(--apphost-color, var(--sl-color-accent)) 35%,
      var(--sl-color-white)
    );
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .apphost-pill :global(svg),
  .apphost-pill .apphost-glyph {
    color: color-mix(
      in srgb,
      var(--apphost-color, var(--sl-color-accent-high)) 80%,
      var(--sl-color-white)
    );
  }

  .apphost-glyph {
    display: inline-block;
    flex-shrink: 0;
  }

  .apphost-pill[data-apphost='typescript'] {
    --apphost-color: #3178c6;
  }

  .apphost-pill[data-apphost='csproj'],
  .apphost-pill[data-apphost='file-based'] {
    --apphost-color: #512bd4;
  }

  :global([data-theme='light']) .apphost-pill {
    color: color-mix(
      in srgb,
      var(--apphost-color, var(--sl-color-accent)) 80%,
      var(--sl-color-black)
    );
    background: color-mix(in srgb, var(--apphost-color, var(--sl-color-accent)) 12%, white);
    border-color: color-mix(in srgb, var(--apphost-color, var(--sl-color-accent)) 55%, transparent);
  }

  :global([data-theme='light']) .apphost-pill :global(svg),
  :global([data-theme='light']) .apphost-pill .apphost-glyph {
    color: var(--apphost-color, var(--sl-color-accent-high));
  }

  /* ---- Description (rendered markdown) ---- */
  .desc {
    color: var(--sl-color-gray-2);
    line-height: 1.55;
    margin: 0;
    font-size: 0.875rem;
  }

  .desc :global(p) {
    margin: 0 0 0.5em;
  }

  .desc p {
    margin: 0 0 0.5em;
    white-space: pre-line;
  }

  .desc :global(p:last-child) {
    margin-bottom: 0;
  }

  .desc p:last-child {
    margin-bottom: 0;
  }

  .desc :global(ul),
  .desc :global(ol) {
    margin: 0.25em 0 0.5em;
    padding-left: 1.25em;
  }

  .desc :global(li) {
    margin-bottom: 0.25em;
  }

  .desc :global(strong) {
    color: var(--sl-color-white);
    font-weight: 600;
  }

  .desc :global(code) {
    background: var(--sl-color-gray-5);
    padding: 0.1em 0.35em;
    border-radius: 0.25em;
    font-size: 0.85em;
  }

  .desc :global(a) {
    color: var(--sl-color-accent-high);
    text-decoration: underline;
  }

  .read-more-btn {
    background: none;
    border: none;
    color: var(--sl-color-accent-high);
    font-size: 0.825rem;
    cursor: pointer;
    padding: 0;
    margin-top: 0.25em;
    font-weight: 500;
  }

  .read-more-btn:hover {
    text-decoration: underline;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3em;
    margin: 0;
    padding: 0;
  }

  .badges :global(.sl-badge) {
    cursor: pointer;
    transition: opacity 0.15s ease;
  }

  .badges :global(.sl-badge:hover) {
    opacity: 0.8;
  }

  .footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.625rem;
    border-top: 1px solid var(--sl-color-gray-5);
  }

  .link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    color: var(--sl-color-accent-high);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
  }

  .link:hover {
    text-decoration: underline;
  }
</style>

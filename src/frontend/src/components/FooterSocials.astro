---
import { Icon } from '@astrojs/starlight/components';
import { socialConfig, type SocialLink } from '../../config/socials.config';
import CookiesSvg from '@assets/icons/cookies.svg';
---

<div class="footer-socials">
  <div class="footer-mobile-tools" aria-label="Site tools">
    <button
      type="button"
      class="footer-mobile-tool-btn cookie-consent-btn"
      data-cc="show-preferencesModal"
      data-tour-target="cookie-preferences"
      data-tour-step="cookie-preferences"
      title="Cookie preferences"
      data-placement="top"
      aria-label="Open cookie preferences dialog"
    >
      <CookiesSvg />
      <span class="footer-mobile-tool-label">Cookies</span>
    </button>
    <button
      type="button"
      class="footer-mobile-tool-btn install-cli-btn"
      data-open-install-modal
      data-tour-target="install-cli"
      data-tour-step="install-cli"
      title="Install Aspire CLI"
      data-placement="top"
      aria-label="Open install Aspire CLI dialog"
    >
      <Icon name="download" />
      <span class="footer-mobile-tool-label">CLI</span>
    </button>
  </div>
  <div class="footer-section-title">
    Connect with us
  </div>
  <div class="social-icons-row">
    <a
      href="/rss.xml"
      rel="noopener noreferrer"
      class="social-link"
      target="_blank"
      title="RSS feed"
      data-tooltip-placement="top"
      aria-label="RSS feed (opens in new tab)"
    >
      <Icon name="rss" />
    </a>

    {
      socialConfig.map((social: SocialLink) => (
        <a
          href={social.href}
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          title={social.label}
          data-tooltip-placement="top"
          aria-label={`${social.label} (opens in new tab)`}
        >
          <Icon name={social.icon} />
        </a>
      ))
    }
  </div>
</div>

<style>
  .footer-socials {
    width: 100%;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--sl-color-gray-5);
    margin-bottom: 1.5rem;
  }

  .footer-mobile-tools {
    display: none;
  }

  .footer-mobile-tool-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.5rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 88%, transparent);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--sl-color-bg-nav) 96%, transparent);
    color: var(--sl-color-text-accent);
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .footer-mobile-tool-btn:hover {
    background: color-mix(in srgb, var(--sl-color-gray-6) 82%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-gray-4) 92%, transparent);
  }

  .footer-mobile-tool-btn :global(svg) {
    --sl-icon-size: 1.05rem !important;
    flex-shrink: 0;
  }

  .footer-mobile-tool-label {
    font-size: var(--sl-text-2xs);
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .footer-section-title {
    text-align: center;
    font-weight: bold;
    margin-bottom: 1rem;
    font-size: var(--sl-text-lg);
  }

  .social-icons-row {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sl-color-text);
    transition:
      color 0.2s ease,
      transform 0.2s ease;
    padding: 0.5rem;
  }

  .social-link:hover {
    color: var(--aspire-color-primary, #7455dd);
    transform: scale(1.1);
  }

  .social-link :global(svg) {
    --sl-icon-size: 1.5em !important;
  }

  /* Responsive: slightly smaller on mobile, larger gaps on desktop */
  @media (max-width: 49.999rem) {
    .footer-mobile-tools {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
    }

    .social-icons-row {
      gap: 0.75rem;
    }

    .social-link :global(svg) {
     --sl-icon-size: 1em !important;
    }
  }

  @media (max-width: 23rem) {
    .footer-mobile-tool-label {
      display: none;
    }
  }

  @media (min-width: 768px) {
    .social-icons-row {
      gap: 1.5rem;
    }

    .social-link :global(svg) {
      --sl-icon-size: 1.375em !important;
    }
  }
</style>

---
import { Badge, Icon } from '@astrojs/starlight/components';
import { Image } from 'astro:assets';
import { Code } from 'astro-expressive-code/components';
import { marked } from 'marked';
import StarlightImageZoom from 'starlight-image-zoom/components/ImageZoom.astro';

import { tagLabel } from '@utils/sample-tags';
import type { Sample } from '@utils/samples';

interface Props {
  sample: Sample;
  resolvedThumbnail: ImageMetadata | null;
  samplesHref: string;
}

const { sample, resolvedThumbnail, samplesHref } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/samples/**/*.{png,jpg,jpeg,gif,svg,webp}',
  { eager: true }
);

function escapeAttribute(value: string): string {
  return value
    .replace(/&/g, '&amp;')
    .replace(/"/g, '&quot;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function stripReadmeTitle(readme: string): string {
  return readme.replace(/^#\s+.+\r?\n+/, '');
}

function resolveReadmeHref(href: string): string {
  if (/^(?:https?:|mailto:|tel:|#|\/)/i.test(href)) {
    return href;
  }

  const relativeHref = href.replace(/^\.\//, '');
  return `${sample.href}/${relativeHref}`;
}

function createRenderer(): marked.Renderer {
  const renderer = new marked.Renderer();
  renderer.link = function ({ href, title, tokens }) {
    if (!href) {
      return '';
    }

    const resolvedHref = resolveReadmeHref(href);
    const isExternal = /^(?:https?:)?\/\//i.test(resolvedHref);
    const text = tokens?.map((token: any) => token.raw || token.text || '').join('') || href;
    const titleAttr = title ? ` title="${escapeAttribute(title)}"` : '';
    const targetAttrs = isExternal ? ' target="_blank" rel="noopener noreferrer"' : '';

    return `<a href="${escapeAttribute(resolvedHref)}"${titleAttr}${targetAttrs}>${text}</a>`;
  };

  return renderer;
}

const markdownRenderer = createRenderer();

function renderBlockHtml(token: marked.Token): string {
  return marked.parser([token], { renderer: markdownRenderer });
}

function getStandaloneImage(token: marked.Token): { src: ImageMetadata; alt: string } | null {
  if (token.type !== 'paragraph') {
    return null;
  }

  const paragraph = token as marked.Tokens.Paragraph;
  const tokens = paragraph.tokens ?? [];
  if (tokens.length !== 1 || tokens[0]?.type !== 'image') {
    return null;
  }

  const imageToken = tokens[0] as marked.Tokens.Image;
  const importPath = imageToken.href.replace('~/assets/', '/src/assets/');
  const entry = imageToken.href.startsWith('~/assets/') ? allImages[importPath] : undefined;
  if (!entry) {
    return null;
  }

  return {
    src: entry.default,
    alt: imageToken.text || `Screenshot of the ${sample.title} sample`,
  };
}

function getCodeProps(token: marked.Token): { code: string; lang: string; meta: string } {
  const codeToken = token as marked.Tokens.Code;
  const [lang = 'text', ...meta] = (codeToken.lang || 'text').trim().split(/\s+/);

  return {
    code: codeToken.text,
    lang,
    meta: meta.join(' '),
  };
}

const readmeBlocks = marked.lexer(stripReadmeTitle(sample.readme), { gfm: true });
const visibleTags = sample.tags;
const sampleSummary = sample.description
  ?.split('\n')
  .find((line) => line.trim().length > 0)
  ?.trim();
---

<StarlightImageZoom />
<article class="sample-detail">
  <div class="sample-hero not-content">
    <div class="sample-hero-copy">
      <div class="sample-kicker">Aspire sample</div>
      <h2 class="sample-hero-title">Explore {sample.title}</h2>
      {sampleSummary && <p class="sample-summary">{sampleSummary}</p>}
      {
        visibleTags.length > 0 && (
          <div class="sample-tags" aria-label="Sample tags">
            {visibleTags.map((tag) => (
              <Badge text={tagLabel(tag)} size="small" />
            ))}
          </div>
        )
      }
      <div class="sample-actions">
        <a
          class="sample-action primary"
          href={sample.href}
          target="_blank"
          rel="noopener noreferrer"
        >
          View on GitHub
          <Icon name="external" size="1rem" />
        </a>
        <a class="sample-action secondary" href={samplesHref}>Browse all samples</a>
      </div>
      <dl class="sample-meta" aria-label="Sample metadata">
        <div>
          <dt>Tags</dt>
          <dd>{sample.tags.length}</dd>
        </div>
        <div>
          <dt>Source</dt>
          <dd>GitHub</dd>
        </div>
      </dl>
    </div>
    {
      resolvedThumbnail && (
        <figure class="sample-thumbnail">
          <Image
            src={resolvedThumbnail}
            alt={`Screenshot of the ${sample.title} sample`}
            widths={[480, 720, 960, 1200]}
            sizes="(min-width: 72rem) 42vw, (min-width: 48rem) 72vw, 100vw"
          />
        </figure>
      )
    }
  </div>

  <section class="sample-readme" aria-label={`${sample.title} README`}>
    {
      readmeBlocks.map((block) => {
        if (block.type === 'space') {
          return null;
        }

        if (block.type === 'code') {
          const code = getCodeProps(block);
          return <Code code={code.code} lang={code.lang} meta={code.meta} />;
        }

        const image = getStandaloneImage(block);
        if (image) {
          return (
            <figure class="sample-readme-image">
              <Image
                src={image.src}
                alt={image.alt}
                loading="lazy"
                widths={[480, 800, 1200]}
                sizes="(min-width: 72rem) 52rem, 100vw"
              />
              {image.alt && <figcaption>{image.alt}</figcaption>}
            </figure>
          );
        }

        return <Fragment set:html={renderBlockHtml(block)} />;
      })
    }
  </section>
</article>

<style>
  .sample-detail {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .sample-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    padding: clamp(1rem, 3vw, 2rem);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.1rem;
    background:
      radial-gradient(
        circle at 0% 0%,
        color-mix(in srgb, var(--sl-color-accent) 24%, transparent),
        transparent 38%
      ),
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--sl-color-gray-6) 94%, var(--sl-color-accent)),
        color-mix(in srgb, var(--sl-color-gray-6) 78%, var(--sl-color-black))
      );
    box-shadow: var(--sl-shadow-md);
  }

  @media (min-width: 64rem) {
    .sample-hero {
      grid-template-columns: minmax(18rem, 0.86fr) minmax(24rem, 1.14fr);
      align-items: center;
    }
  }

  .sample-hero-copy {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sample-kicker {
    color: var(--sl-color-accent-high);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sample-hero-title {
    max-width: 42rem;
    margin: 0;
    color: var(--sl-color-white);
    font-size: clamp(1.35rem, 4vw, 2.15rem);
    line-height: 1.08;
  }

  .sample-summary {
    max-width: 44rem;
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: clamp(0.98rem, 2vw, 1.1rem);
    line-height: 1.65;
  }

  .sample-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .sample-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .sample-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      filter 0.2s ease,
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .sample-action.primary {
    background: var(--sl-color-accent-high);
    color: var(--sl-color-black);
  }

  .sample-action.secondary {
    border: 1px solid var(--sl-color-gray-4);
    color: var(--sl-color-white);
  }

  .sample-action:hover {
    text-decoration: none;
    filter: brightness(1.08);
    transform: translateY(-1px);
  }

  .sample-meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    max-width: 24rem;
    margin: 0;
  }

  .sample-meta div {
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.65rem;
    background: color-mix(in srgb, var(--sl-color-gray-6) 76%, transparent);
  }

  .sample-meta dt {
    margin: 0 0 0.15rem;
    color: var(--sl-color-gray-3);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .sample-meta dd {
    margin: 0;
    color: var(--sl-color-white);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .sample-thumbnail {
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.95rem;
    background: var(--sl-color-gray-6);
    box-shadow: var(--sl-shadow-sm);
    margin: 0;
  }

  .sample-thumbnail img {
    display: block;
    width: 100%;
    height: auto;
  }

  .sample-readme {
    min-width: 0;
    max-width: 56rem;
  }

  .sample-readme :global(.expressive-code) {
    margin: 1.25rem 0;
  }

  .sample-readme-image {
    display: block;
    margin: 1.25rem 0;
  }

  .sample-readme-image img {
    display: block;
    max-width: 100%;
    height: auto;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    box-shadow: var(--sl-shadow-sm);
  }

  .sample-readme-image figcaption {
    margin-top: 0.45rem;
    color: var(--sl-color-gray-3);
    font-size: 0.85rem;
    text-align: center;
  }

  .sample-readme :global(h2:first-child) {
    margin-top: 0;
  }

  @media (max-width: 36rem) {
    .sample-actions,
    .sample-action {
      width: 100%;
    }

    .sample-meta {
      grid-template-columns: 1fr;
      max-width: none;
    }
  }
</style>

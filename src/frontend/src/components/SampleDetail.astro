---
import { Badge, Icon } from '@astrojs/starlight/components';
import { Image } from 'astro:assets';
import { Code } from 'astro-expressive-code/components';
import { marked } from 'marked';

import { tagLabel } from '@utils/sample-tags';
import type { Sample } from '@utils/samples';

interface Props {
  sample: Sample;
  samplesHref: string;
}

const { sample, samplesHref } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/samples/**/*.{png,jpg,jpeg,gif,svg,webp}',
  { eager: true }
);

type SampleImage = {
  src: ImageMetadata;
  alt: string;
};

function escapeAttribute(value: string): string {
  return value
    .replace(/&/g, '&amp;')
    .replace(/"/g, '&quot;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function escapeHtml(value: string): string {
  return escapeAttribute(value).replace(/'/g, '&#39;');
}

function stripReadmeTitle(readme: string): string {
  return readme.replace(/^#\s+.+\r?\n+/, '');
}

function resolveReadmeHref(href: string): string {
  if (/^(?:https?:|mailto:|tel:|#|\/)/i.test(href)) {
    return href;
  }

  const relativeHref = href.replace(/^\.\//, '');
  return `${sample.href}/${relativeHref}`;
}

function createRenderer(): marked.Renderer {
  const renderer = new marked.Renderer();
  const headingCounts = new Map<string, number>();

  renderer.link = function ({ href, title, tokens }) {
    if (!href) {
      return '';
    }

    const resolvedHref = resolveReadmeHref(href);
    const isExternal = /^(?:https?:)?\/\//i.test(resolvedHref);
    const text = tokens?.map((token: any) => token.raw || token.text || '').join('') || href;
    const titleAttr = title ? ` title="${escapeAttribute(title)}"` : '';
    const targetAttrs = isExternal ? ' target="_blank" rel="noopener noreferrer"' : '';

    return `<a href="${escapeAttribute(resolvedHref)}"${titleAttr}${targetAttrs}>${text}</a>`;
  };

  renderer.heading = function ({ tokens, depth }) {
    const text = tokens?.map((token: any) => token.text || token.raw || '').join('') || '';
    const innerHtml = marked
      .parser([{ type: 'paragraph', raw: text, text, tokens } as marked.Tokens.Paragraph], {
        renderer,
      })
      .replace(/^<p>|<\/p>\n?$/g, '');
    const baseSlug = slugifyHeading(text);
    const seen = headingCounts.get(baseSlug) ?? 0;
    headingCounts.set(baseSlug, seen + 1);
    const slug = seen === 0 ? baseSlug : `${baseSlug}-${seen}`;

    return `<div class="sl-heading-wrapper level-h${depth}"><h${depth} id="${slug}">${innerHtml}</h${depth}><a class="sl-anchor-link" href="#${slug}"><span aria-hidden="true" class="sl-anchor-icon"><svg width="16" height="16" viewBox="0 0 24 24"><path fill="currentcolor" d="m12.11 15.39-3.88 3.88a2.52 2.52 0 0 1-3.5 0 2.47 2.47 0 0 1 0-3.5l3.88-3.88a1 1 0 0 0-1.42-1.42l-3.88 3.89a4.48 4.48 0 0 0 6.33 6.33l3.89-3.88a1 1 0 1 0-1.42-1.42Zm8.58-12.08a4.49 4.49 0 0 0-6.33 0l-3.89 3.88a1 1 0 0 0 1.42 1.42l3.88-3.88a2.52 2.52 0 0 1 3.5 0a2.47 2.47 0 0 1 0 3.5l-3.88 3.88a1 1 0 1 0 1.42 1.42l3.88-3.89a4.48 4.48 0 0 0 0-6.33Zm-6.36 5a1 1 0 0 0-1.41 0l-4.6 4.6a1 1 0 0 0 1.41 1.41l4.6-4.6a1 1 0 0 0 0-1.4Z"/></svg></span><span class="sr-only">Section titled ${escapeHtml(text)}</span></a></div>`;
  };

  return renderer;
}

function slugifyHeading(value: string): string {
  const slug = value
    .toLowerCase()
    .trim()
    .replace(/<[^>]*>/g, '')
    .replace(/[^\p{Letter}\p{Number}\s-]/gu, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');

  return slug || 'section';
}

const markdownRenderer = createRenderer();

function renderBlockHtml(token: marked.Token): string {
  return marked.parser([token], { renderer: markdownRenderer });
}

function getStandaloneImage(token: marked.Token): SampleImage | null {
  if (token.type !== 'paragraph') {
    return null;
  }

  const paragraph = token as marked.Tokens.Paragraph;
  const tokens = paragraph.tokens ?? [];
  if (tokens.length !== 1 || tokens[0]?.type !== 'image') {
    return null;
  }

  const imageToken = tokens[0] as marked.Tokens.Image;
  const importPath = imageToken.href.replace('~/assets/', '/src/assets/');
  const entry = imageToken.href.startsWith('~/assets/') ? allImages[importPath] : undefined;
  if (!entry) {
    return null;
  }

  return {
    src: entry.default,
    alt: imageToken.text || `Screenshot of the ${sample.title} sample`,
  };
}

function getCodeProps(token: marked.Token): { code: string; lang: string; meta: string } {
  const codeToken = token as marked.Tokens.Code;
  const [lang = 'text', ...meta] = (codeToken.lang || 'text').trim().split(/\s+/);

  return {
    code: codeToken.text,
    lang,
    meta: meta.join(' '),
  };
}

const readmeBlocks = marked.lexer(stripReadmeTitle(sample.readme), { gfm: true });
const readmeImages = readmeBlocks
  .map((block) => getStandaloneImage(block))
  .filter((image): image is SampleImage => image !== null);
const visibleTags = sample.tags;
const sampleSummary = sample.description
  ?.split('\n')
  .find((line) => line.trim().length > 0)
  ?.trim();
---

<article class="sample-detail">
  <div class="sample-hero not-content">
    <div class="sample-hero-copy">
      <div class="sample-kicker">Aspire sample</div>
      <h2 class="sample-hero-title">Clone, run, and explore this sample</h2>
      {sampleSummary && <p class="sample-summary">{sampleSummary}</p>}
      {
        visibleTags.length > 0 && (
          <div class="sample-tags" aria-label="Sample tags">
            {visibleTags.map((tag) => (
              <Badge text={tagLabel(tag)} size="small" />
            ))}
          </div>
        )
      }
      <div class="sample-actions">
        <a
          class="sample-action primary"
          href={sample.href}
          target="_blank"
          rel="noopener noreferrer"
        >
          View on GitHub
          <Icon name="external" size="1rem" />
        </a>
        <a class="sample-action secondary" href={samplesHref}>Browse all samples</a>
      </div>
    </div>
  </div>

  <section class="sample-readme" aria-label={`${sample.title} README`}>
    {
      readmeBlocks.map((block) => {
        if (block.type === 'space') {
          return null;
        }

        if (block.type === 'code') {
          const code = getCodeProps(block);
          if (code.lang.toLowerCase() === 'mermaid') {
            return <pre class="mermaid">{code.code}</pre>;
          }

          return <Code code={code.code} lang={code.lang} meta={code.meta} />;
        }

        const image = getStandaloneImage(block);
        if (image) {
          return null;
        }

        return <Fragment set:html={renderBlockHtml(block)} />;
      })
    }
  </section>

  {
    readmeImages.length > 0 && (
      <section class="sample-media not-content" aria-labelledby="sample-media-heading">
        <div class="sample-media-header">
          <div>
            <div class="sample-kicker">Preview</div>
            <h2 id="sample-media-heading">Sample screenshots</h2>
          </div>
          <p>
            {readmeImages.length === 1
              ? 'Select the image to zoom in.'
              : 'Select an image to zoom in.'}
          </p>
        </div>
        <div class="sample-media-grid">
          {readmeImages.map((image) => (
            <figure class="sample-readme-image">
              <starlight-image-zoom-zoomable>
                <Image
                  src={image.src}
                  alt={image.alt}
                  loading="lazy"
                  widths={[480, 800, 1200]}
                  sizes="(min-width: 72rem) 52rem, 100vw"
                />
                <button
                  aria-label={`Zoom image${image.alt ? `: ${image.alt}` : ''}`}
                  class="starlight-image-zoom-control"
                  type="button"
                >
                  <svg aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
                    <use href="#starlight-image-zoom-icon-zoom" />
                  </svg>
                </button>
              </starlight-image-zoom-zoomable>
              {image.alt && <figcaption>{image.alt}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    )
  }
</article>

<style>
  .sample-detail {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .sample-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    gap: clamp(1rem, 3vw, 2rem);
    padding: clamp(1rem, 3vw, 2rem);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.1rem;
    background:
      radial-gradient(
        circle at 0% 0%,
        color-mix(in srgb, var(--sl-color-accent) 24%, transparent),
        transparent 38%
      ),
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--sl-color-gray-6) 94%, var(--sl-color-accent)),
        color-mix(in srgb, var(--sl-color-gray-6) 78%, var(--sl-color-black))
      );
    box-shadow: var(--sl-shadow-md);
  }

  .sample-hero::after {
    content: '';
    position: absolute;
    inset: auto -4rem -5rem auto;
    width: min(28rem, 45vw);
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
    border-radius: 999px;
    background:
      radial-gradient(
        circle,
        color-mix(in srgb, var(--sl-color-accent) 22%, transparent),
        transparent 58%
      ),
      repeating-linear-gradient(
        135deg,
        color-mix(in srgb, var(--sl-color-accent) 14%, transparent) 0 1px,
        transparent 1px 14px
      );
    opacity: 0.55;
    pointer-events: none;
  }

  .sample-hero-copy {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 52rem;
  }

  .sample-kicker {
    color: var(--sl-color-accent-high);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sample-hero-title {
    max-width: 42rem;
    margin: 0;
    color: var(--sl-color-white);
    font-size: clamp(1.35rem, 4vw, 2.15rem);
    line-height: 1.08;
  }

  .sample-summary {
    max-width: 48rem;
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: clamp(0.98rem, 2vw, 1.1rem);
    line-height: 1.65;
  }

  .sample-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .sample-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .sample-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      filter 0.2s ease,
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .sample-action.primary {
    background: var(--sl-color-accent-high);
    color: var(--sl-color-black);
  }

  .sample-action.secondary {
    border: 1px solid var(--sl-color-gray-4);
    color: var(--sl-color-white);
  }

  .sample-action:hover {
    text-decoration: none;
    filter: brightness(1.08);
    transform: translateY(-1px);
  }

  .sample-readme {
    min-width: 0;
    max-width: 56rem;
  }

  .sample-readme :global(.expressive-code) {
    margin: 1.25rem 0;
  }

  .sample-media {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1rem, 3vw, 1.5rem);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-gray-6) 90%, var(--sl-color-black));
  }

  .sample-media-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    align-items: end;
  }

  .sample-media-header h2 {
    margin: 0.25rem 0 0;
    color: var(--sl-color-white);
    font-size: clamp(1.2rem, 3vw, 1.55rem);
  }

  .sample-media-header p {
    max-width: 18rem;
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
  }

  .sample-media-grid {
    display: grid;
    gap: 1rem;
  }

  .sample-readme-image {
    display: block;
    margin: 0;
  }

  .sample-readme-image img {
    display: block;
    max-width: 100%;
    height: auto;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    box-shadow: var(--sl-shadow-sm);
  }

  .sample-readme-image :global(starlight-image-zoom-zoomable) {
    display: block;
  }

  .sample-readme-image figcaption {
    margin-top: 0.45rem;
    color: var(--sl-color-gray-3);
    font-size: 0.85rem;
    text-align: center;
  }

  .sample-readme :global(h2:first-child) {
    margin-top: 0;
  }

  @media (max-width: 36rem) {
    .sample-actions,
    .sample-action {
      width: 100%;
    }

    .sample-hero::after {
      opacity: 0.35;
    }
  }
</style>

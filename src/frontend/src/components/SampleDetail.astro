---
import { Badge, Icon } from '@astrojs/starlight/components';
import { Image } from 'astro:assets';
import { marked } from 'marked';

import SampleReadmeBlocks from '@components/SampleReadmeBlocks.astro';
import { tagLabel } from '@utils/sample-tags';
import type { Sample } from '@utils/samples';

interface Props {
  sample: Sample;
  samplesHref: string;
}

const { sample, samplesHref } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/samples/**/*.{png,jpg,jpeg,gif,svg,webp}',
  { eager: true }
);

type SampleImage = {
  src: ImageMetadata;
  alt: string;
};

function stripReadmeTitle(readme: string): string {
  return readme.replace(/^#\s+.+\r?\n+/, '');
}

function getStandaloneImage(token: marked.Token): SampleImage | null {
  if (token.type !== 'paragraph') {
    return null;
  }

  const paragraph = token as marked.Tokens.Paragraph;
  const tokens = paragraph.tokens ?? [];
  const imageTokens = tokens.filter((child) => child.type === 'image') as marked.Tokens.Image[];
  const hasOnlyImageAndWhitespace = tokens.every(
    (child: any) => child.type === 'image' || (child.type === 'text' && child.text.trim() === '')
  );

  if (imageTokens.length !== 1 || !hasOnlyImageAndWhitespace) {
    return null;
  }

  const imageToken = imageTokens[0];
  const importPath = imageToken.href.replace('~/assets/', '/src/assets/');
  const entry = imageToken.href.startsWith('~/assets/') ? allImages[importPath] : undefined;
  if (!entry) {
    return null;
  }

  return {
    src: entry.default,
    alt: imageToken.text || `Screenshot of the ${sample.title} sample`,
  };
}

function collectStandaloneImages(tokens: marked.Token[]): SampleImage[] {
  const images: SampleImage[] = [];

  for (const token of tokens) {
    const image = getStandaloneImage(token);
    if (image) {
      images.push(image);
      continue;
    }

    if (token.type === 'list') {
      for (const item of (token as marked.Tokens.List).items ?? []) {
        images.push(...collectStandaloneImages(item.tokens ?? []));
      }
    } else if (token.type === 'blockquote') {
      images.push(...collectStandaloneImages((token as marked.Tokens.Blockquote).tokens ?? []));
    }
  }

  return images;
}

const readmeBlocks = marked.lexer(stripReadmeTitle(sample.readme), { gfm: true });
const readmeImages = collectStandaloneImages(readmeBlocks);
const visibleTags = sample.tags;
const sampleSummary = sample.description
  ?.split('\n')
  .find((line) => line.trim().length > 0)
  ?.trim();
---

<article class="sample-detail">
  <div class="sample-hero not-content">
    <div class="sample-hero-copy">
      <div class="sample-kicker">Aspire sample</div>
      <h2 class="sample-hero-title">Clone, run, and explore this sample</h2>
      {sampleSummary && <p class="sample-summary">{sampleSummary}</p>}
      {
        visibleTags.length > 0 && (
          <div class="sample-tags" aria-label="Sample tags">
            {visibleTags.map((tag) => (
              <Badge text={tagLabel(tag)} size="small" />
            ))}
          </div>
        )
      }
      <div class="sample-actions">
        <a
          class="sample-action primary"
          href={sample.href}
          target="_blank"
          rel="noopener noreferrer"
        >
          View on GitHub
          <Icon name="external" size="1rem" />
        </a>
        <a class="sample-action secondary" href={samplesHref}>Browse all samples</a>
      </div>
    </div>
  </div>

  <section class="sample-readme" aria-label={`${sample.title} README`}>
    <SampleReadmeBlocks blocks={readmeBlocks} sampleHref={sample.href} />
  </section>

  {
    readmeImages.length > 0 && (
      <section class="sample-media not-content" aria-labelledby="sample-media-heading">
        <div class="sample-media-header">
          <div>
            <div class="sample-kicker">Preview</div>
            <h2 id="sample-media-heading">Sample screenshots</h2>
          </div>
          <p>
            {readmeImages.length === 1
              ? 'Select the image to zoom in.'
              : 'Select an image to zoom in.'}
          </p>
        </div>
        <div class="sample-media-grid">
          {readmeImages.map((image) => (
            <figure class="sample-readme-image">
              <starlight-image-zoom-zoomable>
                <Image
                  src={image.src}
                  alt={image.alt}
                  loading="lazy"
                  widths={[480, 800, 1200]}
                  sizes="(min-width: 72rem) 52rem, 100vw"
                />
                <button
                  aria-label={`Zoom image${image.alt ? `: ${image.alt}` : ''}`}
                  class="starlight-image-zoom-control"
                  type="button"
                >
                  <svg aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
                    <use href="#starlight-image-zoom-icon-zoom" />
                  </svg>
                </button>
              </starlight-image-zoom-zoomable>
              {image.alt && <figcaption>{image.alt}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    )
  }
</article>

<style>
  .sample-detail {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .sample-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    gap: clamp(1rem, 3vw, 2rem);
    padding: clamp(1rem, 3vw, 2rem);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background:
      radial-gradient(
        circle at 0% 0%,
        color-mix(in srgb, var(--sl-color-accent) 24%, transparent),
        transparent 38%
      ),
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--sl-color-gray-6) 94%, var(--sl-color-accent)),
        color-mix(in srgb, var(--sl-color-gray-6) 78%, var(--sl-color-black))
      );
    box-shadow: var(--sl-shadow-md);
  }

  .sample-hero::after {
    content: '';
    position: absolute;
    inset: auto -4rem -5rem auto;
    width: min(28rem, 45vw);
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
    border-radius: 999px;
    background:
      radial-gradient(
        circle,
        color-mix(in srgb, var(--sl-color-accent) 22%, transparent),
        transparent 58%
      ),
      repeating-linear-gradient(
        135deg,
        color-mix(in srgb, var(--sl-color-accent) 14%, transparent) 0 1px,
        transparent 1px 14px
      );
    opacity: 0.55;
    pointer-events: none;
  }

  .sample-hero-copy {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 52rem;
  }

  .sample-kicker {
    color: var(--sl-color-accent-high);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sample-hero-title {
    max-width: 42rem;
    margin: 0;
    color: var(--sl-color-white);
    font-size: clamp(1.35rem, 4vw, 2.15rem);
    line-height: 1.08;
  }

  .sample-summary {
    max-width: 48rem;
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: clamp(0.98rem, 2vw, 1.1rem);
    line-height: 1.65;
  }

  .sample-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .sample-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .sample-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      filter 0.2s ease,
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .sample-action.primary {
    background: var(--sl-color-accent-high);
    color: var(--sl-color-black);
  }

  .sample-action.secondary {
    border: 1px solid var(--sl-color-gray-4);
    color: var(--sl-color-white);
  }

  .sample-action:hover {
    text-decoration: none;
    filter: brightness(1.08);
    transform: translateY(-1px);
  }

  .sample-readme {
    min-width: 0;
    max-width: 56rem;
  }

  .sample-readme :global(.expressive-code) {
    margin: 1.25rem 0;
  }

  .sample-media {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1rem, 3vw, 1.5rem);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-gray-6) 90%, var(--sl-color-black));
  }

  .sample-media-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    align-items: end;
  }

  .sample-media-header h2 {
    margin: 0.25rem 0 0;
    color: var(--sl-color-white);
    font-size: clamp(1.2rem, 3vw, 1.55rem);
  }

  .sample-media-header p {
    max-width: 18rem;
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
  }

  .sample-media-grid {
    display: grid;
    gap: 1rem;
  }

  .sample-readme-image {
    display: block;
    margin: 0;
  }

  .sample-readme-image img {
    display: block;
    max-width: 100%;
    height: auto;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    box-shadow: var(--sl-shadow-sm);
  }

  .sample-readme-image :global(starlight-image-zoom-zoomable) {
    display: block;
  }

  .sample-readme-image figcaption {
    margin-top: 0.45rem;
    color: var(--sl-color-gray-3);
    font-size: 0.85rem;
    text-align: center;
  }

  .sample-readme :global(h2:first-child) {
    margin-top: 0;
  }

  @media (max-width: 36rem) {
    .sample-actions,
    .sample-action {
      width: 100%;
    }

    .sample-hero::after {
      opacity: 0.35;
    }
  }
</style>

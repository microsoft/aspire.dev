---
import { Badge, Icon } from '@astrojs/starlight/components';
import { Image } from 'astro:assets';
import type { StarlightIcon } from '@astrojs/starlight/types';
import { marked } from 'marked';

import SampleReadmeBlocks from '@components/SampleReadmeBlocks.astro';
import { tagLabel } from '@utils/sample-tags';
import {
  appHostLabel,
  sampleDescriptionText,
  type AppHostKind,
  type Sample,
} from '@utils/samples';

interface Props {
  sample: Sample;
  samplesHref: string;
}

const { sample, samplesHref } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/samples/**/*.{png,jpg,jpeg,gif,svg,webp}',
  { eager: true }
);

type SampleImage = {
  src: ImageMetadata;
  alt: string;
};

function stripReadmeTitle(readme: string): string {
  return readme.replace(/^#\s+.+\r?\n+/, '');
}

function getStandaloneImage(token: marked.Token): SampleImage | null {
  if (token.type !== 'paragraph') {
    return null;
  }

  const paragraph = token as marked.Tokens.Paragraph;
  const tokens = paragraph.tokens ?? [];
  const imageTokens = tokens.filter((child) => child.type === 'image') as marked.Tokens.Image[];
  const hasOnlyImageAndWhitespace = tokens.every(
    (child: any) => child.type === 'image' || (child.type === 'text' && child.text.trim() === '')
  );

  if (imageTokens.length !== 1 || !hasOnlyImageAndWhitespace) {
    return null;
  }

  const imageToken = imageTokens[0];
  const importPath = imageToken.href.replace('~/assets/', '/src/assets/');
  const entry = imageToken.href.startsWith('~/assets/') ? allImages[importPath] : undefined;
  if (!entry) {
    return null;
  }

  return {
    src: entry.default,
    alt: imageToken.text || `Screenshot of the ${sample.title} sample`,
  };
}

function collectStandaloneImages(tokens: marked.Token[]): SampleImage[] {
  const images: SampleImage[] = [];

  for (const token of tokens) {
    const image = getStandaloneImage(token);
    if (image) {
      images.push(image);
      continue;
    }

    if (token.type === 'list') {
      for (const item of (token as marked.Tokens.List).items ?? []) {
        images.push(...collectStandaloneImages(item.tokens ?? []));
      }
    } else if (token.type === 'blockquote') {
      images.push(...collectStandaloneImages((token as marked.Tokens.Blockquote).tokens ?? []));
    }
  }

  return images;
}

const readmeBlocks = marked.lexer(stripReadmeTitle(sample.readme), { gfm: true });
const readmeImages = collectStandaloneImages(readmeBlocks);
const visibleTags = sample.tags;
const sampleSummary = sampleDescriptionText(sample.description)
  ?.split('\n')
  .find((line) => line.trim().length > 0)
  ?.trim();

const DATABASE_TAGS = new Set([
  'postgresql',
  'mysql',
  'sql-server',
  'mongodb',
  'redis',
  'databases',
  'ef-core',
]);

function pickHeroIcon(tags: readonly string[]): StarlightIcon {
  for (const tag of tags) {
    if (tag === 'docker' || tag === 'containers') return 'seti:docker';
    if (DATABASE_TAGS.has(tag)) return 'seti:db';
    if (tag === 'azure' || tag.startsWith('azure-')) return 'cloud-download';
    if (tag === 'dashboard' || tag === 'metrics' || tag === 'health-checks') {
      return 'magnifier';
    }
    if (tag === 'csharp' || tag === 'blazor' || tag === 'orleans') {
      return 'seti:c-sharp';
    }
    if (tag === 'typescript') return 'seti:typescript';
  }
  return 'rocket';
}

function hashString(value: string): number {
  let hash = 0;
  for (let index = 0; index < value.length; index++) {
    hash = ((hash << 5) - hash + value.charCodeAt(index)) | 0;
  }
  return Math.abs(hash);
}

const heroIcon = pickHeroIcon(visibleTags);
const appHostKind: AppHostKind | null = sample.appHost ?? null;
const appHostIcon: StarlightIcon | null =
  appHostKind === 'typescript'
    ? 'seti:typescript'
    : appHostKind
      ? 'seti:c-sharp'
      : null;
// 5 nodes in the resource-graph backdrop; pick which one pulses based on the
// sample slug so every sample's hero feels subtly different.
const nodeCount = 5;
const primaryNodeIndex = hashString(sample.name) % nodeCount;
---

<article class="sample-detail">
  <div class="sample-hero not-content">
    <div class="sample-hero-glow" aria-hidden="true"></div>
    <svg
      class="sample-hero-mesh"
      aria-hidden="true"
      viewBox="0 0 480 260"
      preserveAspectRatio="xMaxYMid slice"
    >
      <path class="mesh-edge" d="M 60 80 Q 150 60 230 110" />
      <path class="mesh-edge mesh-edge-strong" d="M 230 110 Q 320 70 410 130" />
      <path class="mesh-edge" d="M 60 80 Q 110 160 200 200" />
      <path class="mesh-edge" d="M 200 200 Q 290 180 410 130" />
      <path class="mesh-edge mesh-edge-soft" d="M 230 110 Q 220 160 200 200" />
      <path class="mesh-edge mesh-edge-soft" d="M 410 130 Q 440 200 380 230" />

      <circle class={`mesh-node ${primaryNodeIndex === 0 ? 'is-primary' : ''}`} cx="60" cy="80" r="9" />
      <circle class={`mesh-node ${primaryNodeIndex === 1 ? 'is-primary' : ''}`} cx="230" cy="110" r="13" />
      <circle class={`mesh-node ${primaryNodeIndex === 2 ? 'is-primary' : ''}`} cx="410" cy="130" r="10" />
      <circle class={`mesh-node ${primaryNodeIndex === 3 ? 'is-primary' : ''}`} cx="200" cy="200" r="11" />
      <circle class={`mesh-node mesh-node-small ${primaryNodeIndex === 4 ? 'is-primary' : ''}`} cx="380" cy="230" r="6" />
    </svg>

    <div class="sample-hero-copy">
      <div class="sample-hero-tags">
        <div class="sample-hero-tag">
          <Icon name={heroIcon} size="0.95rem" />
          <span>Aspire sample</span>
        </div>
        {
          appHostKind && appHostIcon && (
            <div class="sample-hero-tag sample-hero-apphost" data-apphost={appHostKind}>
              <Icon name={appHostIcon} size="0.95rem" />
              <span>{appHostLabel(appHostKind)}</span>
            </div>
          )
        }
      </div>
      <h2 class="sample-hero-title">Clone, run, and explore this sample</h2>
      {sampleSummary && <p class="sample-summary">{sampleSummary}</p>}
      {
        visibleTags.length > 0 && (
          <div class="sample-tags" aria-label="Sample tags">
            {visibleTags.map((tag) => (
              <Badge text={tagLabel(tag)} size="small" />
            ))}
          </div>
        )
      }
      <div class="sample-actions">
        <a
          class="sample-action primary"
          href={sample.href}
          target="_blank"
          rel="noopener noreferrer"
        >
          View on GitHub
          <Icon name="external" size="1rem" />
        </a>
        <a class="sample-action secondary" href={samplesHref}>Browse all samples</a>
      </div>
    </div>
  </div>

  <section class="sample-readme" aria-label={`${sample.title} README`}>
    <SampleReadmeBlocks blocks={readmeBlocks} sampleHref={sample.href} />
  </section>

  {
    readmeImages.length > 0 && (
      <section class="sample-media not-content" aria-labelledby="sample-media-heading">
        <div class="sample-media-header">
          <div>
            <div class="sample-kicker">Preview</div>
            <h2 id="sample-media-heading">Sample screenshots</h2>
          </div>
          <p>
            {readmeImages.length === 1
              ? 'Select the image to zoom in.'
              : 'Select an image to zoom in.'}
          </p>
        </div>
        <div class="sample-media-grid">
          {readmeImages.map((image) => (
            <figure class="sample-readme-image">
              <starlight-image-zoom-zoomable>
                <Image
                  src={image.src}
                  alt={image.alt}
                  loading="lazy"
                  widths={[480, 800, 1200]}
                  sizes="(min-width: 72rem) 52rem, 100vw"
                />
                <button
                  aria-label={`Zoom image${image.alt ? `: ${image.alt}` : ''}`}
                  class="starlight-image-zoom-control"
                  type="button"
                >
                  <svg aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
                    <use href="#starlight-image-zoom-icon-zoom" />
                  </svg>
                </button>
              </starlight-image-zoom-zoomable>
              {image.alt && <figcaption>{image.alt}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    )
  }
</article>

<style>
  .sample-detail {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .sample-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    gap: clamp(1rem, 3vw, 2rem);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--aspire-color-primary) 25%, transparent);
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--aspire-color-primary) 10%, transparent),
      color-mix(in srgb, var(--aspire-color-secondary) 5%, transparent),
      transparent 70%
    );
    box-shadow: var(--sl-shadow-md);
    isolation: isolate;
  }

  .sample-hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 60% 80% at 100% 50%,
        color-mix(in srgb, var(--aspire-color-primary) 18%, transparent),
        transparent 70%
      ),
      radial-gradient(
        ellipse 50% 70% at 0% 100%,
        color-mix(in srgb, var(--aspire-color-secondary) 12%, transparent),
        transparent 65%
      );
    pointer-events: none;
  }

  .sample-hero-mesh {
    position: absolute;
    inset: 0 0 0 auto;
    width: min(72%, 38rem);
    height: 100%;
    pointer-events: none;
    mask-image: linear-gradient(to left, black 35%, transparent 95%);
    -webkit-mask-image: linear-gradient(to left, black 35%, transparent 95%);
  }

  .mesh-edge {
    fill: none;
    stroke: color-mix(in srgb, var(--aspire-color-primary) 42%, transparent);
    stroke-width: 1.25;
    stroke-linecap: round;
    stroke-dasharray: 3 7;
    animation: mesh-flow 14s linear infinite;
  }

  .mesh-edge-strong {
    stroke: color-mix(in srgb, var(--aspire-color-secondary) 60%, transparent);
    stroke-width: 1.5;
    animation-duration: 9s;
  }

  .mesh-edge-soft {
    stroke: color-mix(in srgb, var(--aspire-color-primary) 22%, transparent);
    stroke-dasharray: 2 9;
    animation-duration: 18s;
  }

  @keyframes mesh-flow {
    to {
      stroke-dashoffset: -120;
    }
  }

  .mesh-node {
    fill: color-mix(in srgb, var(--aspire-color-primary) 22%, var(--sl-color-bg));
    stroke: color-mix(in srgb, var(--aspire-color-primary) 65%, transparent);
    stroke-width: 1.5;
    transform-box: fill-box;
    transform-origin: center;
  }

  .mesh-node-small {
    fill: color-mix(in srgb, var(--aspire-color-secondary) 18%, var(--sl-color-bg));
    stroke: color-mix(in srgb, var(--aspire-color-secondary) 50%, transparent);
    opacity: 0.75;
  }

  .mesh-node.is-primary {
    fill: color-mix(in srgb, var(--aspire-color-primary) 38%, var(--sl-color-bg));
    stroke: var(--aspire-color-secondary);
    stroke-width: 2;
    filter: drop-shadow(
      0 0 6px color-mix(in srgb, var(--aspire-color-primary) 60%, transparent)
    );
    animation: mesh-pulse 3.6s ease-in-out infinite;
  }

  @keyframes mesh-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.18);
      opacity: 0.82;
    }
  }

  .sample-hero-copy {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 52rem;
  }

  .sample-hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-self: flex-start;
  }

  .sample-hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.3rem 0.7rem 0.3rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--aspire-color-primary) 18%, var(--sl-color-bg));
    border: 1px solid color-mix(in srgb, var(--aspire-color-primary) 40%, transparent);
    color: color-mix(in srgb, var(--aspire-color-secondary) 80%, var(--sl-color-white));
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
  }

  .sample-hero-tag :global(svg) {
    color: var(--aspire-color-secondary);
  }

  :global([data-theme='light']) .sample-hero-tag {
    color: color-mix(in srgb, var(--aspire-color-primary) 75%, var(--sl-color-black));
    background: color-mix(in srgb, var(--aspire-color-primary) 14%, white);
    border-color: color-mix(in srgb, var(--aspire-color-primary) 45%, transparent);
  }

  :global([data-theme='light']) .sample-hero-tag :global(svg) {
    color: var(--aspire-color-primary);
  }

  .sample-hero-apphost[data-apphost='typescript'] {
    background: color-mix(in srgb, var(--color-cyan, #2dd4bf) 16%, var(--sl-color-bg));
    border-color: color-mix(in srgb, var(--color-cyan, #2dd4bf) 50%, transparent);
    color: color-mix(in srgb, var(--color-cyan, #2dd4bf) 75%, var(--sl-color-white));
  }

  .sample-hero-apphost[data-apphost='typescript'] :global(svg) {
    color: var(--color-cyan, #2dd4bf);
  }

  :global([data-theme='light']) .sample-hero-apphost[data-apphost='typescript'] {
    color: color-mix(in srgb, var(--color-cyan, #2dd4bf) 70%, var(--sl-color-black));
    background: color-mix(in srgb, var(--color-cyan, #2dd4bf) 12%, white);
    border-color: color-mix(in srgb, var(--color-cyan, #2dd4bf) 55%, transparent);
  }

  .sample-hero-title {
    max-width: 42rem;
    margin: 0;
    color: var(--sl-color-white);
    font-size: clamp(1.35rem, 4vw, 2.15rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .sample-summary {
    max-width: 48rem;
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: clamp(0.98rem, 2vw, 1.1rem);
    line-height: 1.65;
  }

  .sample-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .sample-kicker {
    color: var(--sl-color-accent-high);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sample-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .sample-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      filter 0.2s ease,
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .sample-action.primary {
    background: var(--sl-color-accent-high);
    color: var(--sl-color-black);
  }

  .sample-action.secondary {
    border: 1px solid var(--sl-color-gray-4);
    color: var(--sl-color-white);
  }

  .sample-action:hover {
    text-decoration: none;
    filter: brightness(1.08);
    transform: translateY(-1px);
  }

  .sample-readme {
    min-width: 0;
    max-width: 56rem;
  }

  .sample-readme :global(.expressive-code) {
    margin: 1.25rem 0;
  }

  .sample-media {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1rem, 3vw, 1.5rem);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-gray-6) 90%, var(--sl-color-black));
  }

  .sample-media-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    align-items: end;
  }

  .sample-media-header h2 {
    margin: 0.25rem 0 0;
    color: var(--sl-color-white);
    font-size: clamp(1.2rem, 3vw, 1.55rem);
  }

  .sample-media-header p {
    max-width: 18rem;
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
  }

  .sample-media-grid {
    display: grid;
    gap: 1rem;
  }

  .sample-readme-image {
    display: block;
    margin: 0;
  }

  .sample-readme-image img {
    display: block;
    max-width: 100%;
    height: auto;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    box-shadow: var(--sl-shadow-sm);
  }

  .sample-readme-image :global(starlight-image-zoom-zoomable) {
    display: block;
  }

  .sample-readme-image figcaption {
    margin-top: 0.45rem;
    color: var(--sl-color-gray-3);
    font-size: 0.85rem;
    text-align: center;
  }

  .sample-readme :global(h2:first-child) {
    margin-top: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .mesh-edge {
      animation: none;
    }

    .mesh-node.is-primary {
      animation: none;
    }

    .sample-action {
      transition: none;
    }

    .sample-action:hover {
      transform: none;
    }
  }

  @media (max-width: 48rem) {
    .sample-hero-mesh {
      width: 60%;
      opacity: 0.85;
    }
  }

  @media (max-width: 36rem) {
    .sample-actions,
    .sample-action {
      width: 100%;
    }

    .sample-hero {
      padding: clamp(1.25rem, 5vw, 1.75rem);
    }

    .sample-hero-mesh {
      width: 72%;
      opacity: 0.5;
    }
  }
</style>

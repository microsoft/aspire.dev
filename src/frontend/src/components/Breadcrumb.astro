---
/**
 * Reusable breadcrumb navigation component.
 *
 * Usage:
 * ```astro
 * <Breadcrumb crumbs={[
 *   { label: 'Docs', href: '/docs/', icon: 'docs' },
 *   { label: 'Reference', href: '/reference/overview/' },
 *   { label: 'C# APIs', href: '/reference/api/csharp/' },
 *   { label: 'Aspire.Hosting' },
 * ]} />
 * ```
 *
 * The last crumb is always rendered as the current page (no link).
 * Pass `icon: 'docs'` on any crumb to prefix it with a book icon.
 */

export interface BreadcrumbItem {
  /** Display label */
  label: string;
  /** Link target — omit for the current (last) crumb */
  href?: string;
  /** Optional icon identifier. Currently supports 'docs'. */
  icon?: 'docs';
}

interface Props {
  crumbs: BreadcrumbItem[];
}

import cornerIconRaw from '@assets/icons/subdirectory-arrow.svg?raw';
import { Icon } from '@astrojs/starlight/components';

const cornerIcon = cornerIconRaw.replace('<svg ', '<svg class="bc-corner" aria-hidden="true" ');

const { crumbs } = Astro.props;
const allButLast = crumbs.slice(0, -1);
const current = crumbs[crumbs.length - 1];
---

<nav class="breadcrumb not-content" aria-label="Breadcrumb">
  {/* ── Desktop: inline crumb trail ────────────────────────────── */}
  <div class="bc-inline">
    {allButLast.map((crumb) => (
      <>
        {crumb.href ? (
          <a href={crumb.href} class:list={[{ 'bc-icon': !!crumb.icon }]}>
            {crumb.icon === 'docs' && <Icon name='open-book' size="0.875em" />}
            {crumb.label}
          </a>
        ) : (
          <span>{crumb.label}</span>
        )}
        <span class="sep" aria-hidden="true">/</span>
      </>
    ))}
    {current && <span class="current">{current.label}</span>}
  </div>

  {/* ── Mobile: native collapsible (no JS required) ────────────── */}
  <details class="bc-collapse">
    <summary>
      <span class="bc-toggle-label">{current?.label}</span>
      <svg class="bc-chevron" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
    </summary>
    <div class="bc-dropdown">
      {allButLast.map((crumb, i) => (
        crumb.href ? (
          <a href={crumb.href} class:list={[{ 'bc-icon': !!crumb.icon }]} style={`--bc-depth: ${i}`}>
            {i > 0 && <Fragment set:html={cornerIcon} />}
            {crumb.icon === 'docs' && <Icon name='open-book' size="0.875em" />}
            {crumb.label}
          </a>
        ) : (
          <span style={`--bc-depth: ${i}`}>
            {i > 0 && <Fragment set:html={cornerIcon} />}
            {crumb.label}
          </span>
        )
      ))}
      {current && (
        <span class="bc-current" style={`--bc-depth: ${allButLast.length}`}>
          {allButLast.length > 0 && <Fragment set:html={cornerIcon} />}
          {current.label}
        </span>
      )}
    </div>
  </details>
</nav>

<style>
  /* ── Base ─────────────────────────────────────────────────────── */
  .breadcrumb {
    font-size: var(--api-text-base, 1rem);
    margin-bottom: 1.25rem;
    color: var(--sl-color-gray-3);
  }

  /* ── Desktop: inline trail, collapse hidden ──────────────────── */
  .bc-collapse {
    display: none;
  }

  .bc-inline {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: nowrap;
    overflow: hidden;
    min-width: 0;
  }

  .breadcrumb a {
    color: var(--sl-color-gray-3);
    text-decoration: none;
    transition: color 0.15s;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex-shrink: 1;
    min-width: 0;
  }

  .breadcrumb a.bc-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    flex-shrink: 1;
    min-width: 0;
  }

  .breadcrumb a.bc-icon svg {
    flex-shrink: 0;
  }

  .breadcrumb a:hover {
    color: var(--api-accent-text, var(--sl-color-text-accent));
  }

  .sep {
    opacity: 0.35;
    user-select: none;
    flex-shrink: 0;
  }

  .current {
    color: var(--sl-color-text);
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex-shrink: 1;
    min-width: 0;
  }

  /* ── Tablet (≤768px) ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .bc-inline {
      gap: 0.25rem;
    }
  }

  /* ── Phone (≤480px) — swap to collapsible ────────────────────── */
  @media (max-width: 480px) {
    .breadcrumb {
      font-size: var(--api-text-sm, 0.875rem);
    }

    .bc-inline {
      display: none;
    }

    .bc-collapse {
      display: block;
    }

    /* Summary row (toggle) */
    .bc-collapse summary {
      display: flex;
      align-items: center;
      gap: 0.3rem;
      list-style: none;
      cursor: pointer;
      border: 1px solid var(--sl-color-hairline-light);
      border-radius: 0.5rem;
      padding: 0.35rem 0.6rem;
      color: var(--sl-color-text);
      font-weight: 600;
      width: 100%;
      box-sizing: border-box;
    }

    /* Hide default marker in WebKit/Blink */
    .bc-collapse summary::-webkit-details-marker {
      display: none;
    }

    .bc-toggle-label {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      flex: 1 1 0;
      min-width: 0;
    }

    .bc-chevron {
      flex-shrink: 0;
      margin-left: auto;
      transition: transform 0.2s ease;
    }

    .bc-collapse[open] .bc-chevron {
      transform: rotate(180deg);
    }

    /* Dropdown panel */
    .bc-dropdown {
      display: flex;
      flex-direction: column;
      margin-top: 0.35rem;
      padding: 0.35rem 0;
      border: 1px solid var(--sl-color-hairline-light);
      border-radius: 0.5rem;
      background: var(--sl-color-bg);
    }

    .bc-dropdown a,
    .bc-dropdown span,
    .bc-current {
      display: flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.4rem 0.75rem;
      padding-left: calc(0.75rem + var(--bc-depth, 0) * 0.75rem);
      color: var(--sl-color-gray-3);
      text-decoration: none;
    }

    .bc-dropdown :global(.bc-corner) {
      flex-shrink: 0;
      width: 14px;
      height: 14px;
      opacity: 0.4;
    }

    .bc-dropdown a:hover {
      background: var(--sl-color-gray-6);
      color: var(--api-accent-text, var(--sl-color-text-accent));
    }

    .bc-current {
      color: var(--sl-color-text);
      font-weight: 600;
      background: color-mix(in srgb, var(--sl-color-text-accent) 10%, transparent);
    }
  }
</style>

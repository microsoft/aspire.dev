---
import { Tabs, TabItem } from '@astrojs/starlight/components';
import YouTubeEmbed from '@components/YouTubeEmbed.astro';
import TwitchEmbed from '@components/TwitchEmbed.astro';

export interface Props {
  youtubeChannelId: string;
  twitchChannel: string;
}

const { youtubeChannelId, twitchChannel } = Astro.props;
---

<div id="aspire-live-tabs" data-active-source="none">
  <Tabs syncKey="stream-source">
    <TabItem label="YouTube" icon="youtube">
      <div class="live-embed-wrapper" data-source="youtube" data-live="false">
        <YouTubeEmbed channelId={youtubeChannelId} title="Aspire on YouTube" />
      </div>
      <p class="muted">When we&rsquo;re not live, this shows the channel placeholder. Browse all past streams on <a href="https://youtube.com/@aspiredotdev">youtube.com/@aspiredotdev</a>.</p>
    </TabItem>
    <TabItem label="Twitch" icon="twitch">
      <div class="live-embed-wrapper" data-source="twitch" data-live="false">
        <TwitchEmbed channel={twitchChannel} title="Aspire on Twitch" />
      </div>
      <p class="muted">When we&rsquo;re not live, the Twitch player shows the offline screen. Follow <a href={`https://twitch.tv/${twitchChannel}`}>twitch.tv/{twitchChannel}</a> to get notified.</p>
    </TabItem>
  </Tabs>
</div>

<script>
  import { subscribe, type LiveSnapshot } from '@components/live-status.ts';

  const PAGE_SELECTOR = '#aspire-live-tabs';
  let userSticky = false;

  function findTabRoot(): HTMLElement | null {
    return document.querySelector<HTMLElement>(PAGE_SELECTOR);
  }

  function activateTab(label: 'YouTube' | 'Twitch'): void {
    const root = findTabRoot();
    if (!root) return;
    const tabBtn = Array.from(
      root.querySelectorAll<HTMLElement>('[role="tab"]'),
    ).find((b) => b.textContent?.trim() === label);
    tabBtn?.click();
  }

  function setEmbedLive(source: 'youtube' | 'twitch', live: boolean): void {
    const root = findTabRoot();
    if (!root) return;
    const wrapper = root.querySelector<HTMLElement>(
      `.live-embed-wrapper[data-source="${source}"]`,
    );
    if (!wrapper) return;
    if (wrapper.dataset.live === (live ? 'true' : 'false')) return;
    wrapper.dataset.live = live ? 'true' : 'false';
  }

  function applySnapshot(snap: LiveSnapshot): void {
    setEmbedLive('youtube', snap.youtube.live);
    setEmbedLive('twitch', snap.twitch.live);
    const root = findTabRoot();
    if (root) root.dataset.activeSource = snap.primarySource ?? 'none';

    if (userSticky) return;
    if (snap.primarySource === 'twitch') activateTab('Twitch');
    else if (snap.primarySource === 'youtube') activateTab('YouTube');
  }

  function init(): void {
    const root = findTabRoot();
    if (!root || root.dataset.bound === '1') return;
    root.dataset.bound = '1';
    userSticky = false;
    root.querySelectorAll<HTMLElement>('[role="tab"]').forEach((tab) => {
      tab.addEventListener('click', () => {
        userSticky = true;
      });
    });
    subscribe(applySnapshot);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
  document.addEventListener('astro:after-swap', init);
</script>

<style>
  #aspire-live-tabs .live-embed-wrapper {
    position: relative;
    border-radius: 0.75rem;
  }

  #aspire-live-tabs .muted {
    margin-top: 0.75rem;
    color: var(--sl-color-gray-3);
    font-size: 0.9rem;
  }

  @media (prefers-reduced-motion: reduce) {
    #aspire-live-tabs .live-embed-wrapper {
      transition: none;
    }
  }
</style>

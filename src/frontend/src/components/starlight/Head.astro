---
import { Tooltips } from 'astro-tooltips';
import DefaultHead from '@astrojs/starlight/components/Head.astro';
import AccessibleCodeButtons from '../AccessibleCodeButtons.astro';
import SiteTour from '../SiteTour.astro';
import { getStructuredData } from '@utils/structured-data';

const repoUrl = (
  import.meta.env.PUBLIC_REPO_URL ||
  import.meta.env.REPO_URL ||
  'https://github.com/microsoft/aspire.dev'
).replace(/\/$/, '');
const commit = import.meta.env.PUBLIC_GIT_COMMIT_ID || import.meta.env.GIT_COMMIT_ID || '';

const route = Astro.locals?.starlightRoute;
const entryId = route?.entry?.id;
const path = route?.entry?.filePath;
const isSiteTourEnabled = import.meta.env.PUBLIC_ENABLE_SITE_TOUR === 'true';
const structuredData = route ? getStructuredData(route, Astro.url, Astro.site) : undefined;

function computeRepoPath() {
  if (path) {
    return `src/frontend/${path}`; // final path inside repository
  }

  return `unknown-${entryId}`;
}

function computeSourceUrl() {
  if (!repoUrl || !commit) return '';
  const path = computeRepoPath();
  return path ? `${repoUrl}/blob/${commit}/${path}` : '';
}
---

<meta name="git-commit-id" content={commit} />
<meta name="git-source-url" content={computeSourceUrl()} />

<DefaultHead {...Astro.props} />
{structuredData && <script type="application/ld+json" is:inline set:html={structuredData} />}

<!-- Restore persisted sidebar state before paint and keep legacy AppHost pages readable -->
<script is:inline>
  (function () {
    function normalizeAppHostLang(value) {
      var normalized = (value || '').toLowerCase();
      if (normalized.indexOf('typescript') !== -1) {
        return 'typescript';
      }
      if (normalized.indexOf('c#') !== -1 || normalized.indexOf('csharp') !== -1) {
        return 'csharp';
      }
      return '';
    }

    try {
      var rawAppHostLang =
        localStorage.getItem('aspire-lang') ||
        localStorage.getItem('aspire-apphost-lang') ||
        localStorage.getItem('starlight-synced-tabs__aspire-lang') ||
        localStorage.getItem('starlight-synced-tabs__apphost-lang') ||
        localStorage.getItem('starlight-synced-tabs__apphost-implementation-lang') ||
        'csharp';
      var appHostLang = normalizeAppHostLang(rawAppHostLang) || 'csharp';
      document.documentElement.setAttribute('data-apphost-lang', appHostLang);

      var path = window.location.pathname.replace(/\/$/, '');
      if (
        localStorage.getItem('api-sidebar-collapsed') === '1' &&
        path.indexOf('/reference/api') !== -1
      ) {
        document.documentElement.setAttribute('data-sidebar-collapsed', '');
      }

      if (
        localStorage.getItem('topic-sidebar-collapsed') === '1' &&
        path.indexOf('/reference/api') === -1
      ) {
        document.documentElement.setAttribute('data-topic-sidebar-collapsed', '');
      }
    } catch (e) {}
  })();
</script>

<!-- Auto-detect language for first-time visitors -->
<script is:inline>
  (function () {
    // Only run on first visit (check if user has a language preference stored)
    const hasVisited = localStorage.getItem('aspire-visited');
    if (hasVisited) return;

    // Mark as visited
    localStorage.setItem('aspire-visited', 'true');

    // Get browser language
    const browserLang = navigator.language || navigator.languages?.[0] || 'en';
    const langCode = browserLang.split('-')[0].toLowerCase();

    // Supported languages (matching the site's locales)
    const supportedLangs = [
      'en',
      'de',
      'es',
      'ja',
      'fr',
      'it',
      'id',
      'zh',
      'pt',
      'ko',
      'tr',
      'ru',
      'hi',
      'da',
      'uk',
    ];

    // Check if current path already has a language prefix
    const currentPath = window.location.pathname;
    const hasLangPrefix = /^\/[a-z]{2}(?:-[A-Z]{2})?\//.test(currentPath);

    // If user is on English version (no prefix) and their browser prefers another supported language
    if (!hasLangPrefix && langCode !== 'en' && supportedLangs.includes(langCode)) {
      // Redirect to their preferred language
      const newPath = '/' + langCode + currentPath;
      window.location.href = newPath;
    }
  })();
</script>

<Tooltips
  interactive={false}
  allowHTML={true}
  delay={[0, 0]}
  duration={[0, 0]}
  hideOnClick={true}
  animation="scale"
  onClickOutside={function (instance, event) {
    if (instance) {
      instance.hide();
    }
  }}
/>

<script is:inline>
  (function () {
    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') {
        const activeElement = document.activeElement;
        if (activeElement && activeElement._tippy) {
          activeElement._tippy.hide();
        }
      }
    });
  })();
</script>

<!--
  Workaround for expressive-code-twoslash@0.6.1 runtime bug where the popup is
  rendered as a child of .twoslash-hover but the shipped script looks for it
  as nextElementSibling and falls back to brittle indexOf pairing. The fallback
  breaks after the first mouseleave detaches popups, so tooltips stop showing.
  We replace each hover with a clone (stripping the plugin's listeners), park
  the popup in .expressive-code (to escape <pre> overflow clipping), and wire
  correct show/hide handlers.
-->
<script is:inline>
  (function () {
    if (window.__aspireTwoslashFixInitialized) return;
    window.__aspireTwoslashFixInitialized = true;

    function position(popup, hover, ec) {
      // Position absolutely inside .expressive-code (our positioning context).
      // This keeps popup inside the CSS-variable scope (so background/color/
      // z-index vars apply) while escaping the <pre overflow:auto> clip.
      var hoverRect = hover.getBoundingClientRect();
      var ecRect = ec.getBoundingClientRect();
      var popupRect = popup.getBoundingClientRect();
      var gap = 4;
      var top = hoverRect.bottom - ecRect.top + gap;
      var left = hoverRect.left - ecRect.left;
      // Clamp horizontally within .expressive-code bounds.
      var maxLeft = Math.max(0, ecRect.width - popupRect.width - 8);
      if (left > maxLeft) left = maxLeft;
      if (left < 0) left = 0;
      popup.style.position = 'absolute';
      popup.style.top = top + 'px';
      popup.style.left = left + 'px';
      popup.style.right = 'auto';
      popup.style.margin = '0';
    }

    function initHover(hover) {
      var popup = hover.querySelector(':scope > .twoslash-popup-container');
      if (!popup) return;
      var ec = hover.closest('.expressive-code');
      if (!ec) return;

      // Park popup as a direct child of .expressive-code so it escapes the
      // <pre overflow:auto> clip while keeping the plugin's CSS variables in
      // scope. Make .expressive-code a positioning context AND a stacking
      // context (via isolation:isolate) so the popup's z-index:999 stays
      // contained below the site nav (z-index:10) instead of bubbling up to
      // the root stacking context.
      ec.style.position = ec.style.position || 'relative';
      ec.style.isolation = 'isolate';
      if (popup.parentNode !== ec) ec.appendChild(popup);
      popup.style.display = 'none';
      popup.setAttribute('aria-hidden', 'true');
      popup.setAttribute('role', 'tooltip');

      var hideTimer;
      var hoveringPopup = false;

      function show() {
        clearTimeout(hideTimer);
        popup.style.display = 'block';
        popup.setAttribute('aria-hidden', 'false');
        position(popup, hover, ec);
      }
      function scheduleHide() {
        clearTimeout(hideTimer);
        hideTimer = setTimeout(function () {
          if (hoveringPopup || hover.matches(':hover')) return;
          popup.style.display = 'none';
          popup.setAttribute('aria-hidden', 'true');
        }, 100);
      }

      hover.addEventListener('mouseenter', show);
      hover.addEventListener('mouseleave', scheduleHide);
      hover.addEventListener('focus', show);
      hover.addEventListener('blur', scheduleHide);
      popup.addEventListener('mouseenter', function () {
        clearTimeout(hideTimer);
        hoveringPopup = true;
      });
      popup.addEventListener('mouseleave', function () {
        hoveringPopup = false;
        scheduleHide();
      });
    }

    function fixAll() {
      var hovers = document.querySelectorAll('.twoslash-hover');
      for (var i = 0; i < hovers.length; i++) {
        var hover = hovers[i];
        if (hover.dataset.tsFixed === '1') continue;
        var clone = hover.cloneNode(true);
        clone.dataset.tsFixed = '1';
        hover.parentNode.replaceChild(clone, hover);
        initHover(clone);
      }
    }

    function scheduleFix() {
      // Run after the plugin's own astro:page-load / initial pass.
      setTimeout(fixAll, 0);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', scheduleFix);
    } else {
      scheduleFix();
    }
    document.addEventListener('astro:page-load', scheduleFix);
    document.addEventListener('astro:after-swap', function () {
      setTimeout(fixAll, 150);
    });
  })();
</script>

<AccessibleCodeButtons />
{isSiteTourEnabled && <SiteTour />}

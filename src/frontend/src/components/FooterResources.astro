---
const t = Astro.locals.t as unknown as (key: string) => string;
---

<nav class="footer-column" aria-labelledby="footer-resources-heading">
  <p id="footer-resources-heading" class="footer-heading">
    {t('footer.resources') || 'Resources'}
  </p>
  <ul class="footer-links">
    <li>
      <a href="/reference/overview/">
        {t('footer.reference') || 'Reference'}
      </a>
    </li>
    <li>
      <a href="/community/contributor-guide/">
        {t('footer.contributorGuide')}
      </a>
    </li>
    <li>
      <a
        href="https://github.com/microsoft/aspire/releases"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t('footer.releases') || 'Releases'}
      </a>
    </li>
    <li>
      <a
        href="https://microsoft.github.io/aspire-brand/"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t('footer.aspireBrand') || 'Aspire brand'}
      </a>
    </li>
    <li>
      <a
        href="https://support.microsoft.com/en-US/contactus/"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t('footer.contact')}
      </a>
    </li>
  </ul>
</nav>

<style>
  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-heading {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--sl-color-white);
    margin: 0 0 0.25rem 0;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    font-size: var(--sl-text-sm);
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: var(--sl-color-white);
  }
</style>

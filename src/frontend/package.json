    "@fontsource-variable/rubik": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@jop-software/astro-cookieconsent": "^3.0.1",
    "@lunariajs/core": "^0.1.1",
    "@lunariajs/starlight": "^0.1.1",
    "asciinema-player": "^3.16.0",
    "astro": "^7.0.3",
    "astro-contributors": "^0.9.0",
    "astro-expressive-code": "^0.44.0",
    "astro-mermaid": "^2.1.0",
    "astro-tooltips": "^0.6.2",
    "hast-util-to-html": "^9.0.5",
    "mdast-util-to-hast": "^13.2.1",
    "mermaid": "^11.16.0",
    "remark-directive": "^4.0.0",
    "satori": "^0.26.0",
    "satteri": "^0.9.4",
    "sharp": "^0.35.2",
    "starlight-github-alerts": "^0.3.0",
    "starlight-image-zoom": "^0.15.0",
    "starlight-kbd": "^0.4.0",
    "starlight-links-validator": "^0.25.1",
    "starlight-llms-txt": "^0.10.0",
    "starlight-page-actions": "^0.6.2",
    "starlight-plugin-icons": "^1.1.6",
    "starlight-scroll-to-top": "^1.0.1",
    "starlight-sidebar-topics": "^0.8.0",
    "vanilla-cookieconsent": "^3.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@ec-ts/twoslash": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "@iconify-json/material-icon-theme": "^1.2.68",
    "@playwright/test": "^1.61.1",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@unocss/astro": "66.6.8",
    "astro-embed": "^0.13.0",
    "astro-vtbot": "^3.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "expressive-code-twoslash": "^0.6.1",
    "globals": "^17.7.0",
    "hast-util-select": "^6.0.4",
    "http-proxy-agent": "^9.1.0",
    "https-proxy-agent": "^9.1.0",
    "node-fetch": "^3.3.2",
    "prettier": "^3.9.1",
    "prettier-plugin-astro": "^0.14.1",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "unified": "^11.0.5",
    "unist-util-remove": "^4.0.0",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "@anthropic-ai/claude-code@<2.0.31": ">=2.0.31",

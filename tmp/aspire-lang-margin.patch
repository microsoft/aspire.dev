-    { id: 'typescript', title: 'TypeScript' },
-  ]}
-/>
-<Pivot id="csharp">
-```csharp title="AppHost.cs"
-var builder = DistributedApplication.CreateBuilder(args);
-
-builder.AddNodeApp("api", "../api")
-    .WithCertificateTrustScope(CertificateTrustScope.Append);
-
-builder.Build().Run();
-```
-</Pivot>
-<Pivot id="typescript">
